</style>

@code {
    private bool showResetConsole = false;
    private bool showFileEditor = false;
    private bool isLoadingFiles = false;
    private string currentPath = "";
    private string rootPath = "";
    private string editingFileName = "";
    private string editingContent = "";
    private string editingFilePath = "";
    private List<FileSystemItem> directoryItems = new();
    private List<string> consoleLines = new();
    private string commandInput = "";
    private ElementReference consoleRef;
    private DateTime startTime = DateTime.Now;
    
    private int projectCount => GetDirectoryCount(Path.Combine(rootPath, "wwwroot", "projects"));
    private int gameCount => GetDirectoryCount(Path.Combine(rootPath, "wwwroot", "games"));
    private int whitelistedIPs => IPWhitelist.GetAllowedIPs().Count;
    private double uptime => (DateTime.Now - startTime).TotalHours;
    private string passwordFilePath => Path.Combine(rootPath, "bin", "Debug", "net8.0-windows", "Data", "current_password.txt");

    protected override void OnInitialized()
    {
        rootPath = @"D:\PackArcade";
        currentPath = rootPath;
        consoleLines.Add($"SUCCESS: Admin panel initialized at {DateTime.Now}");
        consoleLines.Add($"INFO: Root path: {rootPath}");
        consoleLines.Add("INFO: Type 'help' for available commands");
        LoadDirectory();
    }

    private int GetDirectoryCount(string path)
    {
        try
        {
            if (Directory.Exists(path))
                return Directory.GetDirectories(path).Length;
        }
        catch { }
        return 0;
    }

    private string GetMemoryUsage()
    {
        try
        {
            using var process = Process.GetCurrentProcess();
            var memory = process.WorkingSet64 / 1024 / 1024;
            return $"{memory} MB";
        }
        catch
        {
            return "N/A";
        }
    }

    private string GetFileIcon(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLower();
        return ext switch
        {
            ".html" => "🌐",
            ".css" => "🎨",
            ".js" => "⚡",
            ".cs" => "🔷",
            ".py" => "🐍",
            ".php" => "🐘",
            ".json" => "📋",
            ".txt" => "📄",
            ".log" => "📝",
            ".zip" => "📦",
            ".exe" => "⚙️",
            ".razor" => "🎯",
            ".csproj" => "📁",
            _ => "📄"
        };
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private void LoadDirectory()
    {
        try
        {
            isLoadingFiles = true;
            StateHasChanged();
            
            directoryItems.Clear();
            var dir = new DirectoryInfo(currentPath);
            
            foreach (var subDir in dir.GetDirectories())
            {
                directoryItems.Add(new FileSystemItem
                {
                    Name = subDir.Name,
                    FullPath = subDir.FullName,
                    IsDirectory = true,
                    Size = 0
                });
            }
            
            foreach (var file in dir.GetFiles())
            {
                directoryItems.Add(new FileSystemItem
                {
                    Name = file.Name,
                    FullPath = file.FullName,
                    IsDirectory = false,
                    Size = file.Length
                });
            }
            
            directoryItems = directoryItems.OrderByDescending(x => x.IsDirectory)
                .ThenBy(x => x.Name)
                .ToList();
                
            consoleLines.Add($"INFO: Loaded {directoryItems.Count} items from {currentPath}");
        }
        catch (Exception ex)
        {
            consoleLines.Add($"ERROR: Failed to load directory: {ex.Message}");
        }
        finally
        {
            isLoadingFiles = false;
            StateHasChanged();
        }
    }

    private void RefreshDirectory()
    {
        LoadDirectory();
    }

    private void GoUp()
    {
        var parent = Directory.GetParent(currentPath);
        if (parent != null && parent.FullName.Length >= rootPath.Length)
        {
            currentPath = parent.FullName;
            LoadDirectory();
        }
        else
        {
            consoleLines.Add("WARN: Already at root directory");
        }
    }

    private void NavigateTo(FileSystemItem item)
    {
        if (item.IsDirectory)
        {
            currentPath = item.FullPath;
            LoadDirectory();
        }
    }

    private void EditFile(FileSystemItem item)
    {
        try
        {
            editingFilePath = item.FullPath;
            editingFileName = item.Name;
            editingContent = File.ReadAllText(item.FullPath);
            showFileEditor = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            consoleLines.Add($"ERROR: Failed to open file: {ex.Message}");
        }
    }

    private async Task SaveFile()
    {
        try
        {
            await File.WriteAllTextAsync(editingFilePath, editingContent);
            consoleLines.Add($"SUCCESS: Saved {editingFileName}");
            CloseEditor();
            LoadDirectory();
        }
        catch (Exception ex)
        {
            consoleLines.Add($"ERROR: Failed to save file: {ex.Message}");
        }
    }

    private void DeleteFile(FileSystemItem item)
    {
        try
        {
            File.Delete(item.FullPath);
            consoleLines.Add($"SUCCESS: Deleted {item.Name}");
            LoadDirectory();
        }
        catch (Exception ex)
        {
            consoleLines.Add($"ERROR: Failed to delete file: {ex.Message}");
        }
    }

    private void CloseEditor()
    {
        showFileEditor = false;
        editingContent = "";
        editingFileName = "";
        editingFilePath = "";
        StateHasChanged();
    }

    private void HandleEditorKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "s" && e.CtrlKey)
        {
            _ = SaveFile();
        }
    }

    private void ClearConsole()
    {
        consoleLines.Clear();
        consoleLines.Add("Console cleared");
        StateHasChanged();
    }

    private async Task ExecuteCommand()
    {
        if (string.IsNullOrWhiteSpace(commandInput)) return;
        
        var input = commandInput.Trim();
        consoleLines.Add($">>> {input}");
        commandInput = "";
        
        await ProcessCommand(input);
        StateHasChanged();
        
        await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('.console-output')?.scrollTo(0, document.querySelector('.console-output')?.scrollHeight);");
    }

    private async Task ExecuteCommandOnEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ExecuteCommand();
        }
    }

    private async Task ProcessCommand(string input)
    {
        var parts = input.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var cmd = parts[0].ToLower();
        var args = parts.Skip(1).ToArray();

        switch (cmd)
        {
            case "help":
                consoleLines.Add("Available commands:");
                consoleLines.Add("  help           - Show this help");
                consoleLines.Add("  clear          - Clear console");
                consoleLines.Add("  ls             - List current directory");
                consoleLines.Add("  cd <path>      - Change directory");
                consoleLines.Add("  pwd            - Show current path");
                consoleLines.Add("  cat <file>     - Show file content");
                consoleLines.Add("  mkdir <name>   - Create directory");
                consoleLines.Add("  rm <file>      - Delete file");
                consoleLines.Add("  ip-list        - Show whitelisted IPs");
                consoleLines.Add("  ip-reset       - Reset IP whitelist");
                consoleLines.Add("  stats          - Show system stats");
                consoleLines.Add("  restart        - Restart server");
                break;
                
            case "clear":
                ClearConsole();
                break;
                
            case "ls":
                foreach (var item in directoryItems.Take(50))
                {
                    consoleLines.Add($"  {(item.IsDirectory ? "📁" : GetFileIcon(item.Name))} {item.Name}{(item.IsDirectory ? "/" : "")} {(item.IsDirectory ? "" : FormatFileSize(item.Size))}");
                }
                if (directoryItems.Count > 50)
                    consoleLines.Add($"  ... and {directoryItems.Count - 50} more items");
                break;
                
            case "cd":
                if (args.Length == 0)
                {
                    currentPath = rootPath;
                }
                else
                {
                    var newPath = Path.Combine(currentPath, args[0]);
                    if (Directory.Exists(newPath))
                    {
                        currentPath = newPath;
                    }
                    else
                    {
                        consoleLines.Add($"ERROR: Directory not found: {args[0]}");
                        return;
                    }
                }
                LoadDirectory();
                consoleLines.Add($"Changed to: {currentPath}");
                break;
                
            case "pwd":
                consoleLines.Add(currentPath);
                break;
                
            case "cat":
                if (args.Length == 0)
                {
                    consoleLines.Add("ERROR: No file specified");
                    return;
                }
                var filePath = Path.Combine(currentPath, args[0]);
                if (File.Exists(filePath))
                {
                    var content = await File.ReadAllTextAsync(filePath);
                    var lines = content.Split('\n');
                    foreach (var line in lines.Take(20))
                    {
                        consoleLines.Add($"  {line.TrimEnd()}");
                    }
                    if (lines.Length > 20)
                        consoleLines.Add($"  ... and {lines.Length - 20} more lines");
                }
                else
                {
                    consoleLines.Add($"ERROR: File not found: {args[0]}");
                }
                break;
                
            case "mkdir":
                if (args.Length == 0)
                {
                    consoleLines.Add("ERROR: No directory name specified");
                    return;
                }
                var newDir = Path.Combine(currentPath, args[0]);
                Directory.CreateDirectory(newDir);
                consoleLines.Add($"SUCCESS: Created directory {args[0]}");
                LoadDirectory();
                break;
                
            case "rm":
                if (args.Length == 0)
                {
                    consoleLines.Add("ERROR: No file specified");
                    return;
                }
                var delPath = Path.Combine(currentPath, args[0]);
                if (File.Exists(delPath))
                {
                    File.Delete(delPath);
                    consoleLines.Add($"SUCCESS: Deleted {args[0]}");
                    LoadDirectory();
                }
                else
                {
                    consoleLines.Add($"ERROR: File not found: {args[0]}");
                }
                break;
                
            case "ip-list":
                var ips = IPWhitelist.GetAllowedIPs();
                if (ips.Count == 0)
                {
                    consoleLines.Add("No IPs are currently whitelisted");
                }
                else
                {
                    consoleLines.Add($"Whitelisted IPs ({ips.Count}):");
                    foreach (var ip in ips)
                    {
                        consoleLines.Add($"  {ip}");
                    }
                }
                break;
                
            case "ip-reset":
                consoleLines.Add("WARN: This will reset the IP whitelist. Use the Reset IP Whitelist button to confirm.");
                break;
                
            case "stats":
                consoleLines.Add($"Projects: {projectCount}");
                consoleLines.Add($"Games: {gameCount}");
                consoleLines.Add($"Whitelisted IPs: {whitelistedIPs}");
                consoleLines.Add($"Uptime: {uptime:F1} hours");
                consoleLines.Add($"Memory: {GetMemoryUsage()}");
                consoleLines.Add($"Current Path: {currentPath}");
                break;
                
            case "restart":
                consoleLines.Add("WARN: Restarting server...");
                await Task.Delay(1000);
                var currentExe = Process.GetCurrentProcess().MainModule?.FileName;
                if (!string.IsNullOrEmpty(currentExe))
                {
                    Process.Start(currentExe);
                    System.Environment.Exit(0);
                }
                else
                {
                    consoleLines.Add("ERROR: Could not determine executable path for restart");
                }
                break;
                
            default:
                consoleLines.Add($"ERROR: Unknown command: {cmd}. Type 'help' for available commands.");
                break;
        }
    }

    private void ShowResetConsole()
    {
        showResetConsole = true;
        StateHasChanged();
    }
    
    private void CloseResetConsole()
    {
        showResetConsole = false;
        LoadDirectory();
        StateHasChanged();
    }
    
    private async Task Logout()
    {
        await AuthService.SignOut();
        Navigation.NavigateTo("/", true);
    }

    private class FileSystemItem
    {
        public string Name { get; set; } = "";
        public string FullPath { get; set; } = "";
        public bool IsDirectory { get; set; }
        public long Size { get; set; }
    }
}