@page "/admin/panel"
@attribute [AdminAuthorize]
@using PackArcade2.Services
@using System.IO
@using System.Diagnostics
@using System.Text
@using Microsoft.AspNetCore.Hosting
@inject AdminAuthenticationService AuthService
@inject NavigationManager Navigation
@inject IWebHostEnvironment WebEnv
@inject IJSRuntime JSRuntime
@inject ILogger<AdminPanel> Logger
@inject IPWhitelistService IPWhitelist

<PageTitle>Admin Panel - PackArcade2</PageTitle>

<div class="admin-container">
    <div class="admin-header">
        <div class="admin-title">
            <span class="icon">🔒</span>
            PackArcade2 Administrator Console
        </div>
        <div class="admin-actions">
            <button class="btn-reset-ip" @onclick="ShowResetConsole">
                <span>⚠️</span> Reset IP Whitelist
            </button>
            <button class="btn-logout" @onclick="Logout">
                <span>🚪</span> Logout
            </button>
        </div>
    </div>
    
    <div class="admin-content">
        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">@projectCount</div>
                <div class="stat-label">Projects</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@gameCount</div>
                <div class="stat-label">Games</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@whitelistedIPs</div>
                <div class="stat-label">Whitelisted IPs</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@uptime</div>
                <div class="stat-label">Uptime (hours)</div>
            </div>
        </div>

        <!-- Two Column Layout -->
        <div class="admin-grid">
            <!-- File Explorer -->
            <div class="panel-card file-explorer-card">
                <div class="card-header">
                    <h3>📁 File Explorer</h3>
                    <div class="path-bar">
                        <span class="path-text">@currentPath</span>
                        <button class="btn-icon" @onclick="GoUp" title="Go Up">⬆</button>
                        <button class="btn-icon" @onclick="RefreshDirectory" title="Refresh">⟳</button>
                    </div>
                </div>
                <div class="file-list">
                    @if (isLoadingFiles)
                    {
                        <div class="loading">Loading...</div>
                    }
                    else
                    {
                        @foreach (var item in directoryItems)
                        {
                            <div class="file-item" @onclick="() => NavigateTo(item)">
                                <span class="file-icon">@(item.IsDirectory ? "📁" : GetFileIcon(item.Name))</span>
                                <span class="file-name">@item.Name</span>
                                @if (!item.IsDirectory)
                                {
                                    <span class="file-size">@FormatFileSize(item.Size)</span>
                                    <button class="btn-icon-small" @onclick.stop="() => EditFile(item)">✏️</button>
                                    <button class="btn-icon-small" @onclick.stop="() => DeleteFile(item)">🗑</button>
                                }
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- System Console -->
            <div class="panel-card console-card">
                <div class="card-header">
                    <h3>📟 System Console</h3>
                    <button class="btn-icon" @onclick="ClearConsole" title="Clear">🗑</button>
                </div>
                <div class="console-output" @ref="consoleRef">
                    @foreach (var line in consoleLines.TakeLast(100))
                    {
                        if (line.StartsWith("ERROR:"))
                        {
                            <div class="console-error">@line</div>
                        }
                        else if (line.StartsWith("WARN:"))
                        {
                            <div class="console-warn">@line</div>
                        }
                        else if (line.StartsWith("SUCCESS:"))
                        {
                            <div class="console-success">@line</div>
                        }
                        else
                        {
                            <div>@line</div>
                        }
                    }
                </div>
                <div class="console-input">
                    <span class="prompt">$></span>
                    <input @bind="commandInput" @onkeypress="ExecuteCommandOnEnter" placeholder="Enter command..." />
                    <button class="btn-sm" @onclick="ExecuteCommand">Run</button>
                </div>
            </div>
        </div>

        <!-- Server Info -->
        <div class="info-card">
            <h3>📊 Server Information</h3>
            <div class="info-grid">
                <div><strong>Server Time:</strong> @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")</div>
                <div><strong>OS:</strong> @System.Runtime.InteropServices.RuntimeInformation.OSDescription</div>
                <div><strong>Framework:</strong> @System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</div>
                <div><strong>Memory Used:</strong> @GetMemoryUsage()</div>
                <div><strong>Root Path:</strong> @rootPath</div>
                <div><strong>Password File:</strong> @passwordFilePath</div>
            </div>
        </div>
    </div>
</div>

@if (showResetConsole)
{
    <div class="console-overlay">
        <ResetIPConsole OnComplete="@CloseResetConsole" />
    </div>
}

@if (showFileEditor)
{
    <div class="editor-overlay">
        <div class="editor-modal">
            <div class="editor-header">
                <h4>Editing: @editingFileName</h4>
                <button class="close-btn" @onclick="CloseEditor">✖</button>
            </div>
            <textarea @bind="editingContent" class="editor-textarea" @onkeydown="HandleEditorKeydown"></textarea>
            <div class="editor-footer">
                <button class="btn-primary" @onclick="SaveFile">💾 Save</button>
                <button class="btn-secondary" @onclick="CloseEditor">Cancel</button>
            </div>
        </div>
    </div>
}

<style>
