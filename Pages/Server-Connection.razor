@code {
    private bool hasApiKey = false;
    private string apiKey = "";
    private bool isLoading = false;
    private bool isDeploying = false;
    private List<UserServer> servers = new();
    private string newServerName = "";
    private bool installNode = false;
    private bool installPython = false;
    private bool installPhp = false;
    private string startCommand = "";
    private int port = 3000;
    private byte[]? serverFileData;
    private string selectedFileName = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                apiKey = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "pk_api_key");
                if (!string.IsNullOrEmpty(apiKey))
                {
                    hasApiKey = true;
                    await LoadServers();
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"OnAfterRenderAsync error: {ex.Message}");
            }
        }
    }

    private void GoToPKStorage()
    {
        Navigation.NavigateTo("/pk-storage");
    }

    private async Task LoadServers()
    {
        if (string.IsNullOrEmpty(apiKey)) return;
        
        isLoading = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.Add("X-PK-API-Key", apiKey);
            var response = await client.GetAsync("http://localhost:5000/api/server-connection/list");
            
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                servers = JsonSerializer.Deserialize<List<UserServer>>(json) ?? new();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"LoadServers failed: {response.StatusCode} - {errorContent}");
                await ShowAlert($"Failed to load servers: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"LoadServers error: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            await ShowAlert($"Error loading servers: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task DeployServer()
    {
        if (string.IsNullOrEmpty(newServerName))
        {
            await ShowAlert("Please enter a server name");
            return;
        }
        
        var hasFile = await JSRuntime.InvokeAsync<bool>("eval", "document.getElementById('serverFileInput').files.length > 0");
        
        if (!hasFile)
        {
            await ShowAlert("Please select a ZIP file containing your server");
            return;
        }
        
        isDeploying = true;
        StateHasChanged();
        
        try
        {
            var config = new ServerConfig
            {
                InstallNode = installNode,
                InstallPython = installPython,
                InstallPhp = installPhp,
                StartCommand = startCommand,
                Port = port
            };
            
            var configJson = JsonSerializer.Serialize(config);
            
            var result = await JSRuntime.InvokeAsync<DeploymentResult>("deployServerDirect", 
                apiKey, newServerName, configJson);
            
            if (result != null && result.Success)
            {
                await ShowAlert($"Server deployed! Security scan queued.\n\nServer URL: {result.ServerUrl}");
                
                if (!string.IsNullOrEmpty(result.ScriptContent))
                {
                    await DownloadScriptContent(result.ScriptContent, newServerName);
                }
                
                if (!string.IsNullOrEmpty(result.AgentScriptContent))
                {
                    await DownloadAgentScriptContent(result.AgentScriptContent, newServerName);
                }
                
                await LoadServers();
                
                newServerName = "";
                serverFileData = null;
                selectedFileName = "";
                
                await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('serverFileInput').value = ''");
            }
            else
            {
                await ShowAlert($"Deployment failed: {result?.Message ?? "Unknown error"}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"DeployServer error: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            await ShowAlert($"Error: {ex.Message}");
        }
        finally
        {
            isDeploying = false;
            StateHasChanged();
        }
    }

    private async Task StartServer(string serverId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.Add("X-PK-API-Key", apiKey);
            var response = await client.PostAsync($"http://localhost:5000/api/server-connection/start/{serverId}", null);
            var result = await response.Content.ReadAsStringAsync();
            
            if (response.IsSuccessStatusCode)
            {
                await ShowAlert($"Server started successfully!\n{result}");
                await LoadServers();
            }
            else
            {
                await ShowAlert($"Failed to start server: {result}");
            }
        }
        catch (Exception ex)
        {
