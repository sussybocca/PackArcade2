@page "/server-connection"
@using PackArcade2.Services
@using System.Text.Json
@using System.Net.Http
@using System.Text
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Server Connection - PackArcade2</PageTitle>

<div class="sc-container">
    <div class="sc-header">
        <h1>🚀 SERVER CONNECTION</h1>
        <p>Deploy your own server on PackArcade2 infrastructure | 24-Hour Security Scan | Live File Sync with Agent</p>
    </div>

    @if (!hasApiKey)
    {
        <div class="warning-card">
            <div class="warning-icon">⚠️</div>
            <h2>API Key Required</h2>
            <p>You need a PK Storage API key to deploy servers.</p>
            <button class="goto-pk-btn" @onclick="GoToPKStorage">Go to PK Storage →</button>
        </div>
    }
    else
    {
        <div class="server-dashboard">
            <!-- Server List -->
            <div class="server-list-card">
                <h3>📡 Your Servers</h3>
                <button class="refresh-servers-btn" @onclick="LoadServers">🔄 Refresh</button>
                
                @if (isLoading)
                {
                    <div class="loading">Loading servers...</div>
                }
                else if (servers.Count == 0)
                {
                    <div class="empty-state">
                        <span class="empty-icon">🚀</span>
                        <p>No servers deployed yet. Click "Deploy New Server" to get started!</p>
                    </div>
                }
                else
                {
                    <div class="server-list">
                        @foreach (var server in servers)
                        {
                            <div class="server-item">
                                <div class="server-info">
                                    <div class="server-name">📁 @server.ServerName</div>
                                    <div class="server-id">ID: @server.ServerId</div>
                                    <div class="server-url">
                                        🌐 URL: <a href="@($"https://{server.ServerId}.packarcade.win")" target="_blank">@($"https://{server.ServerId}.packarcade.win")</a>
                                    </div>
                                    <div class="server-status">
                                        Status: 
                                        <span class="status-badge status-@(server.Status?.ToLower() ?? "pending")">@(server.Status ?? "Pending")</span>
                                    </div>
                                    <div class="server-scan">
                                        Scan: 
                                        <span class="scan-badge scan-@(server.ScanStatus?.ToLower() ?? "pending")">@(server.ScanStatus ?? "Pending")</span>
                                    </div>
                                    <div class="server-agent">
                                        Agent: 
                                        <span class="agent-badge @(server.HasAgent ? "connected" : "disconnected")">
                                            @(server.HasAgent ? "🟢 Connected" : "⚫ Disconnected")
                                        </span>
                                    </div>
                                    <div class="server-date">Deployed: @server.DeployedAt.ToString("yyyy-MM-dd HH:mm")</div>
                                    @if (server.Pid.HasValue && server.Pid > 0)
                                    {
                                        <div class="server-pid">PID: @server.Pid</div>
                                    }
                                    @if (server.StartedAt.HasValue)
                                    {
                                        <div class="server-started">Started: @server.StartedAt.Value.ToString("HH:mm:ss")</div>
                                    }
                                    @if (!string.IsNullOrEmpty(server.ScanMessage))
                                    {
                                        <div class="server-message">⚠️ @server.ScanMessage</div>
                                    }
                                    @if (server.LastOutput != null && server.LastOutput.Any())
                                    {
                                        <div class="server-logs">
                                            <details>
                                                <summary>📋 Recent Logs</summary>
                                                @foreach (var log in server.LastOutput.TakeLast(5))
                                                {
                                                    <div class="log-line">@log</div>
                                                }
                                            </details>
                                        </div>
                                    }
                                </div>
                                <div class="server-actions">
                                    @if (server.Status == "Running")
                                    {
                                        <button class="stop-server-btn" @onclick="() => StopServer(server.ServerId)">⏹️ Stop</button>
                                        <button class="restart-server-btn" @onclick="() => RestartServer(server.ServerId)">🔄 Restart</button>
                                    }
                                    else if (server.Status == "Stopped" || server.Status == "Error")
                                    {
                                        <button class="start-server-btn" @onclick="() => StartServer(server.ServerId)">▶️ Start</button>
                                    }
                                    @if (server.Status == "Active" || server.Status == "Running")
                                    {
                                        <button class="download-script-btn" @onclick="() => DownloadScript(server.ServerId, server.ServerName)">📜 Download Script</button>
                                        <button class="download-agent-btn" @onclick="() => DownloadAgentScript(server.ServerId, server.ServerName)">🤖 Download Agent</button>
                                        <button class="update-server-btn" @onclick="() => TriggerUpdate(server.ServerId)">🔄 Update</button>
                                    }
                                    @if (server.ScanStatus == "Quarantined")
                                    {
                                        <div class="quarantine-warning">⛔ Server Quarantined - Malware Detected</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Deploy New Server -->
            <div class="deploy-card">
                <h3>🚀 Deploy New Server</h3>
                <div class="deploy-form">
                    <input @bind="newServerName" placeholder="Server Name" class="server-input" />
                    
                    <div class="config-section">
                        <h4>Dependencies</h4>
                        <label>
                            <input type="checkbox" @bind="installNode" />
                            Install Node.js
                        </label>
                        <label>
                            <input type="checkbox" @bind="installPython" />
                            Install Python
                        </label>
                        <label>
                            <input type="checkbox" @bind="installPhp" />
                            Install PHP
                        </label>
                    </div>
                    
                    <div class="config-section">
                        <h4>Startup Configuration</h4>
                        <input @bind="startCommand" placeholder="Start command (e.g., node server.js)" class="server-input" />
                        <input @bind="port" type="number" placeholder="Port (default: 3000)" class="server-input" />
                    </div>
                    
                    <div class="config-section">
                        <h4>Upload Server Files</h4>
                       <input type="file" id="serverFileInput" accept=".zip" class="file-input" />
                        <button class="upload-file-btn" @onclick="TriggerFileUpload">📁 Select ZIP File</button>
                        @if (!string.IsNullOrEmpty(selectedFileName))
                        {
                            <div class="selected-file">Selected: @selectedFileName</div>
                        }
                    </div>
                    
                    <button class="deploy-btn" @onclick="DeployServer" disabled="@isDeploying">
                        @(isDeploying ? "Deploying..." : "🚀 Deploy Server")
                    </button>
                </div>
            </div>

            <!-- Agent Info Card -->
            <div class="agent-info-card">
                <h3>🤖 PackArcade2 Agent</h3>
                <p>Run the Agent script on your local machine for live file sync and real-time updates!</p>
                <div class="agent-features">
                    <div class="agent-feature">
                        <span class="feature-icon">🔄</span>
                        <span>Real-time file sync between your local machine and cloud server</span>
                    </div>
                    <div class="agent-feature">
                        <span class="feature-icon">📁</span>
                        <span>Automatic file watcher - changes sync instantly</span>
                    </div>
                    <div class="agent-feature">
                        <span class="feature-icon">🔒</span>
                        <span>Secure WebSocket connection with admin privileges</span>
                    </div>
                    <div class="agent-feature">
                        <span class="feature-icon">⚡</span>
                        <span>Live development - edit locally, see changes on your subdomain immediately</span>
                    </div>
                </div>
                <div class="agent-instructions">
                    <h4>How to use:</h4>
                    <ol>
                        <li>Deploy a server (or use an existing one)</li>
                        <li>Click "Download Agent" next to your server</li>
                        <li>Save the .ps1 file to your local machine</li>
                        <li>Right-click and select "Run with PowerShell" (as Administrator)</li>
                        <li>The agent will connect and start syncing your local files</li>
                        <li>Any changes you make locally will be instantly reflected on your live server!</li>
                    </ol>
                </div>
            </div>

            <!-- Info Card -->
            <div class="info-card">
                <h3>ℹ️ How It Works</h3>
                <ul>
                    <li><strong>1. Upload</strong> - Upload your server files as a ZIP</li>
                    <li><strong>2. Scan</strong> - Quick malware scan and sandbox test</li>
                    <li><strong>3. Deploy</strong> - Server files are stored on VHD storage</li>
                    <li><strong>4. Script</strong> - Download Server-Connect.ps1 and run as Admin</li>
                    <li><strong>5. Agent</strong> - Download Agent-Connect.ps1 for live file sync</li>
                    <li><strong>6. Scan</strong> - 24-hour full security scan in background</li>
                    <li><strong>7. Active</strong> - Server becomes active after passing scan</li>
                </ul>
                <div class="warning-note">
                    ⚠️ The Server-Connect.ps1 and Agent-Connect.ps1 scripts require Administrator privileges to run!
                </div>
                <div class="info-note">
                    💡 Your server will be accessible at: <strong>https://[server-id].packarcade.win</strong>
                </div>
                <div class="agent-note">
                    🤖 The Agent script provides live file sync - edit files locally, see changes instantly on your live server!
                </div>
            </div>
        </div>
    }
</div>

