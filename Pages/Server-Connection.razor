    private async Task OnServerFileSelected(ChangeEventArgs e)
    {
        try
        {
            Console.WriteLine("========================================");
            Console.WriteLine("FILE SELECTION STARTED");
            Console.WriteLine($"Timestamp: {DateTime.Now:HH:mm:ss.fff}");
            Console.WriteLine($"Event value: {e.Value}");
            
            var fileSize = await JSRuntime.InvokeAsync<long>("eval", "document.getElementById('serverFileInput').files[0]?.size || 0");
            Console.WriteLine($"File size: {fileSize} bytes ({fileSize / 1024 / 1024:F2} MB)");
            
            if (fileSize > 1024 * 1024)
            {
                string errorMsg = $"FILE TOO LARGE: {fileSize / 1024 / 1024:F2} MB exceeds the 1MB limit.\nAlternative: Click 'Deploy Server' directly - it handles large files.";
                Console.WriteLine($"ERROR: {errorMsg}");
                await ShowAlert($"❌ {errorMsg}");
                serverFileData = null;
                selectedFileName = "";
                return;
            }
            
            selectedFileName = await JSRuntime.InvokeAsync<string>("getFileName", "serverFileInput");
            Console.WriteLine($"getFileName result: '{selectedFileName}'");
            
            if (string.IsNullOrEmpty(selectedFileName))
            {
                string errorMsg = "No file selected - getFileName returned empty or null";
                Console.WriteLine($"ERROR: {errorMsg}");
                await ShowAlert(errorMsg);
                return;
            }
            
            Console.WriteLine($"Selected file: {selectedFileName}");
            
            var connectionQuality = await JSRuntime.InvokeAsync<string>("eval", "navigator.connection ? navigator.connection.downlink + ' Mbps' : 'unknown'");
            Console.WriteLine($"Network speed: {connectionQuality}");
            
            Console.WriteLine("Attempting to read file with readFileFromInput...");
            var startTime = DateTime.Now;
            var readTask = JSRuntime.InvokeAsync<byte[]>("readFileFromInput", "serverFileInput").AsTask();
            
            double estimatedSeconds = fileSize / (1024 * 1024) / 2;
            int timeoutSeconds = Math.Max(30, (int)Math.Ceiling(estimatedSeconds * 2));
            
            Console.WriteLine($"File size: {fileSize} bytes, Estimated transfer time: {estimatedSeconds:F1}s, Using timeout: {timeoutSeconds}s");
            
            var timeoutTask = Task.Delay(timeoutSeconds * 1000);
            var completedTask = await Task.WhenAny(readTask, timeoutTask);
            var elapsed = DateTime.Now - startTime;
            
            if (completedTask == readTask)
            {
                var fileData = await readTask;
                Console.WriteLine($"File read completed. Data length: {fileData?.Length ?? 0} bytes, Time: {elapsed.TotalSeconds:F1}s");
                
                if (fileData != null && fileData.Length > 0)
                {
                    serverFileData = fileData;
                    await ShowAlert($"✅ File ready: {selectedFileName} ({serverFileData.Length:N0} bytes)\n⏱️ Transfer time: {elapsed.TotalSeconds:F1} seconds");
                    Console.WriteLine("SUCCESS: File loaded successfully");
                }
                else
                {
                    string errorMsg = $"File read returned empty data (size: {fileData?.Length ?? 0})";
                    Console.WriteLine($"ERROR: {errorMsg}");
                    await ShowAlert($"❌ {errorMsg}");
                    serverFileData = null;
                    selectedFileName = "";
                }
            }
            else
            {
                string errorMsg = $"FILE READ TIMEOUT after {timeoutSeconds} seconds for file: {selectedFileName}\n" +
                                 $"File size: {fileSize / 1024 / 1024:F2} MB\n" +
                                 $"Network speed: {connectionQuality}\n" +
                                 $"Elapsed time: {elapsed.TotalSeconds:F1} seconds\n" +
                                 $"Solution: Use 'Deploy Server' button directly - it uploads via HTTP POST and can handle large files.";
                Console.WriteLine($"ERROR: {errorMsg}");
                await ShowAlert($"❌ {errorMsg}");
                serverFileData = null;
                selectedFileName = "";
            }
        }
        catch (OperationCanceledException ex)
        {
            string errorMsg = $"CANCELLED: {ex.Message}\nStack: {ex.StackTrace}";
            Console.WriteLine($"CANCELLED: {errorMsg}");
            await ShowAlert($"❌ {errorMsg}");
            serverFileData = null;
            selectedFileName = "";
        }
        catch (Exception ex)
        {
            string fullError = $"Exception Type: {ex.GetType().FullName}\n" +
                              $"Message: {ex.Message}\n" +
                              $"Stack Trace: {ex.StackTrace}";
            
            if (ex.InnerException != null)
            {
                fullError += $"\n\nINNER EXCEPTION:\n" +
                            $"Type: {ex.InnerException.GetType().FullName}\n" +
                            $"Message: {ex.InnerException.Message}\n" +
                            $"Stack: {ex.InnerException.StackTrace}";
            }
            
            Console.WriteLine($"EXCEPTION DETAILS:\n{fullError}");
            await ShowAlert($"❌ ERROR:\n\n{fullError}");
            serverFileData = null;
            selectedFileName = "";
        }
        finally
        {
            Console.WriteLine("FILE SELECTION ENDED");
            Console.WriteLine("========================================");
            StateHasChanged();
        }
    }

    private async Task TriggerUpdate(string serverId)
    {
        try
        {
            await ShowAlert("Please select updated ZIP file");
            await TriggerFileUpload();
            
            if (serverFileData != null)
            {
                var client = HttpClientFactory.CreateClient();
                client.DefaultRequestHeaders.Add("X-PK-API-Key", apiKey);
                
                using var content = new MultipartFormDataContent();
                content.Add(new ByteArrayContent(serverFileData), "file", "update.zip");
                
                var response = await client.PostAsync($"http://localhost:5000/api/server-connection/update/{serverId}", content);
                
                if (response.IsSuccessStatusCode)
                {
                    await ShowAlert("Server updated successfully!");
                    await LoadServers();
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    Console.WriteLine($"Update failed: {response.StatusCode} - {errorContent}");
                    await ShowAlert("Update failed");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"TriggerUpdate error: {ex.Message}");
            await ShowAlert($"Update error: {ex.Message}");
        }
    }

