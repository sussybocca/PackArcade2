@page "/"
@namespace PackArcade2.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PackArcade2 - Create, Play, Host</title>
    <meta name="description" content="PackArcade2: The ultimate platform to create games, build websites, and host them instantly with your own subdomain." />
    <meta name="author" content="PackArcade" />
    <base href="~/" />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Google Font for immersive typography -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">

    <!-- Custom site CSS -->
    <link rel="stylesheet" href="css/site.css" />

    <!-- Advanced logo: SVG favicon with gradient -->
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Cdefs%3E%3ClinearGradient id='grad' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%23667eea'/%3E%3Cstop offset='100%25' stop-color='%23764ba2'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='100' height='100' rx='20' fill='url(%23grad)'/%3E%3Ctext x='50' y='70' font-size='70' text-anchor='middle' fill='white' font-family='Orbitron, sans-serif' font-weight='bold'%3E🎮%3C/text%3E%3C/svg%3E">
    <!-- Fallback standard favicon -->
    <link rel="alternate icon" href="favicon.ico">

    <!-- Optional: Apple touch icon -->
    <link rel="apple-touch-icon" href="icon-192.png">
</head>
<body>
    <component type="typeof(PackArcade2.Pages.App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <script src="_framework/blazor.server.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="js/exe-runner.js"></script>
    <script src="js/editor.js"></script>
    

    <script>
        // File reader helper for reading uploaded files as byte arrays
        window.readFile = function (file) {
            return new Promise((resolve, reject) => {
                var reader = new FileReader();
                reader.onload = function (e) {
                    var array = new Uint8Array(e.target.result);
                    resolve(Array.from(array));
                };
                reader.onerror = function (e) {
                    reject(e);
                };
                reader.readAsArrayBuffer(file);
            });
        };
        
        // Read the selected file directly from the file input
        window.readSelectedFile = function() {
            return new Promise((resolve, reject) => {
                var fileInput = document.getElementById('serverFileInput');
                if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
                    reject(new Error('No file selected'));
                    return;
                }
                
                var file = fileInput.files[0];
                var reader = new FileReader();
                reader.onload = function(e) {
                    var array = new Uint8Array(e.target.result);
                    resolve(Array.from(array));
                };
                reader.onerror = function(e) {
                    reject(e);
                };
                reader.readAsArrayBuffer(file);
            });
        };
        
        // Get the selected file name
        window.getSelectedFileName = function() {
            var fileInput = document.getElementById('serverFileInput');
            if (fileInput && fileInput.files && fileInput.files.length > 0) {
                return fileInput.files[0].name;
            }
            return "";
        };
        
        // NEW: Get file name by input ID
        window.getFileName = function(inputId) {
            console.log("getFileName called for input: " + inputId);
            var input = document.getElementById(inputId);
            console.log("Input element found: " + (input != null));
            if (input && input.files && input.files.length > 0) {
                console.log("File name: " + input.files[0].name);
                return input.files[0].name;
            }
            console.log("No file selected");
            return "";
        };
        
        // NEW: Read file from input by ID
        window.readFileFromInput = function(inputId) {
            console.log("readFileFromInput called for input: " + inputId);
            return new Promise((resolve, reject) => {
                var input = document.getElementById(inputId);
                if (!input) {
                    console.error("Input element not found: " + inputId);
                    reject("Input element not found: " + inputId);
                    return;
                }
                
                if (!input.files || input.files.length === 0) {
                    console.error("No file selected in input");
                    reject("No file selected");
                    return;
                }
                
                var file = input.files[0];
                console.log("Reading file: " + file.name + ", size: " + file.size + " bytes");
                
                var reader = new FileReader();
                reader.onload = function(e) {
                    console.log("File read successful, data length: " + e.target.result.byteLength);
                    var bytes = new Uint8Array(e.target.result);
                    resolve(Array.from(bytes));
                };
                reader.onerror = function(e) {
                    console.error("FileReader error: " + e.target.error);
                    reject("FileReader error: " + (e.target.error ? e.target.error.message : "Unknown error"));
                };
                reader.readAsArrayBuffer(file);
                console.log("FileReader started");
            });
        };
        
        // NEW: Direct file upload that bypasses Blazor/SignalR
        window.deployServerDirect = async function(apiKey, serverName, configJson) {
            try {
                var fileInput = document.getElementById('serverFileInput');
                if (!fileInput.files || fileInput.files.length === 0) {
                    return { Success: false, Message: "No file selected" };
                }
                
                var file = fileInput.files[0];
                console.log("Uploading file:", file.name, "size:", file.size, "bytes");
                
                var formData = new FormData();
                formData.append('serverName', serverName);
                formData.append('config', configJson);
                formData.append('file', file);
                
                var response = await fetch('/api/server-connection/deploy', {
                    method: 'POST',
                    headers: {
                        'X-PK-API-Key': apiKey
                    },
                    body: formData
                });
                
                var result = await response.json();
                console.log("Upload result:", result);
                return result;
            } catch (error) {
                console.error('Upload error:', error);
                return { Success: false, Message: error.message };
            }
        };
        
        // Save file helper for downloading files from byte arrays
        window.saveAsFile = function (filename, base64Data) {
            var link = document.createElement('a');
            var byteCharacters = atob(base64Data);
            var byteNumbers = new Array(byteCharacters.length);
            for (var i = 0; i < byteCharacters.length; i++) {
                byteNumbers[i] = byteCharacters.charCodeAt(i);
            }
            var byteArray = new Uint8Array(byteNumbers);
            var blob = new Blob([byteArray], { type: 'application/octet-stream' });
            var url = URL.createObjectURL(blob);
            link.href = url;
            link.download = filename;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
        };
        
        // Ensure all scripts are loaded
        window.addEventListener('load', function() {
            console.log('PackArcade2 fully loaded');
            document.body.classList.add('loaded');
        });
        // Direct file upload to PK Storage (same pattern as deployServerDirect)
window.uploadToPKStorage = async function(apiKey, fileInputId) {
    try {
        var fileInput = document.getElementById(fileInputId);
        if (!fileInput.files || fileInput.files.length === 0) {
            return { success: false, message: "No file selected" };
        }
        
        var results = [];
        
        for (var i = 0; i < fileInput.files.length; i++) {
            var file = fileInput.files[i];
            console.log(`Uploading file: ${file.name}, size: ${file.size} bytes`);
            
            var formData = new FormData();
            formData.append('file', file);
            
            try {
                var response = await fetch('/api/pk-storage/upload', {
                    method: 'POST',
                    headers: {
                        'X-PK-API-Key': apiKey
                    },
                    body: formData
                });
                
                var result = await response.json();
                results.push({
                    name: file.name,
                    success: response.ok,
                    message: response.ok ? "Uploaded" : (result.message || "Upload failed")
                });
            } catch (error) {
                results.push({
                    name: file.name,
                    success: false,
                    message: error.message
                });
            }
        }
        
        return results;
    } catch (error) {
        console.error('Upload error:', error);
        return [{ success: false, message: error.message }];
    }
};
    </script>
</body>
</html>