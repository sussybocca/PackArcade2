            font-size: 24px;
            margin-bottom: 20px;
        }}
        .video-player {{
            width: 100%;
            background: #000;
            border-radius: 8px;
            margin-bottom: 20px;
        }}
        .video-description {{
            background: rgba(0,0,0,0.4);
            padding: 16px;
            border-radius: 8px;
            margin-top: 20px;
            white-space: pre-wrap;
        }}
        .scene-timeline {{
            margin-top: 20px;
            padding: 16px;
            background: rgba(0,255,170,0.1);
            border-radius: 8px;
        }}
        .scene {{
            padding: 12px;
            margin: 8px 0;
            background: rgba(0,0,0,0.3);
            border-left: 3px solid #00ffaa;
        }}
        .timestamp {{
            color: #00ffaa;
            font-weight: bold;
        }}
        .controls {{
            text-align: center;
            margin-top: 20px;
        }}
        button {{
            background: #00ffaa;
            color: #0a0e1a;
            border: none;
            padding: 10px 20px;
            margin: 0 10px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
        }}
        button:hover {{
            background: #88ffaa;
        }}
    </style>
</head>
<body>
    <div class='video-container'>
        <div class='video-title'>🎬 AI Generated Video: {videoId}</div>
        <video controls class='video-player' width='100%'>
            <source src='' type='video/mp4'>
            <p>Video content generated by {selectedVideoModel}</p>
        </video>
        <div class='video-description'>
            <strong>📝 Video Description:</strong><br>
            {videoDescription}
        </div>
        <div class='scene-timeline'>
            <strong>🎬 Scene Timeline:</strong>
            <div id='scenes'></div>
        </div>
        <div class='controls'>
            <button onclick='window.location.reload()'>🔄 Reload</button>
            <button onclick='window.print()'>🖨️ Print Script</button>
        </div>
    </div>
    <script>
        const scenes = {JsonSerializer.Serialize(script.Split('\n').Where(l => l.Trim().Length > 20).Take(20).ToList())};
        const scenesDiv = document.getElementById('scenes');
        scenes.forEach((scene, i) => {{
            const sceneDiv = document.createElement('div');
            sceneDiv.className = 'scene';
            sceneDiv.innerHTML = `<span class='timestamp'>⏱️ Scene ${{i+1}}:</span><br>${{scene.replace(/</g, '&lt;').replace(/>/g, '&gt;')}}`;
            scenesDiv.appendChild(sceneDiv);
        }});
    </script>
</body>
</html>";
            
            var htmlPath = Path.Combine(videosBasePath, $"{videoId}.html");
            await File.WriteAllTextAsync(htmlPath, htmlContent);
            
            await AddSystemMessage($"✅ Video generated successfully using {selectedVideoModel}!");
            await AddSystemMessage($"🎬 View your interactive video at: /videos/{videoId}.html");
            await AddSystemMessage($"📝 The AI has created a detailed storyboard with {script.Split('\n').Where(l => l.Trim().Length > 20).Count()} scenes");
            
            return $"/videos/{videoId}.html";
        }
        catch (Exception ex)
        {
            await AddSystemMessage($"❌ Video generation error: {ex.Message}");
