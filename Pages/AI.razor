    private async Task RunCodeInSandbox(CodeBlock codeBlock)
    {
        try
        {
            isSandboxRunning = true;
            StateHasChanged();
            
            await AddSystemMessage($"🚀 Running {codeBlock.Language} code in sandbox (D: drive)...");
            
            var projectName = $"ai_sandbox_{Guid.NewGuid():N}"[..20];
            var subdomain = Regex.Replace(projectName.ToLower(), @"[^a-z0-9-]", "");
            var projectDir = Path.Combine(projectsBasePath, subdomain);
            Directory.CreateDirectory(projectDir);
            
            string fileName = codeBlock.Language switch
            {
                "html" => "index.html",
                "javascript" => "script.js",
                "css" => "style.css",
                "python" => "server.py",
                "csharp" => "Program.cs",
                "php" => "index.php",
                "json" => "package.json",
                _ => "index.html"
            };
            
            await File.WriteAllTextAsync(Path.Combine(projectDir, fileName), codeBlock.Code);
            
            if (codeBlock.Language == "javascript" && !File.Exists(Path.Combine(projectDir, "index.html")))
            {
                var htmlWrapper = @"<!DOCTYPE html>
<html>
<head><title>AI Generated Code</title></head>
<body>
    <script src=""script.js""></script>
</body>
</html>";
                await File.WriteAllTextAsync(Path.Combine(projectDir, "index.html"), htmlWrapper);
            }
            
            if (codeBlock.Language == "css" && !File.Exists(Path.Combine(projectDir, "index.html")))
            {
                var htmlWrapper = @"<!DOCTYPE html>
<html>
<head><link rel=""stylesheet"" href=""style.css""></head>
<body>
    <h1>AI Generated Style</h1>
    <p>This page uses your CSS</p>
</body>
</html>";
                await File.WriteAllTextAsync(Path.Combine(projectDir, "index.html"), htmlWrapper);
            }
            
            var projectInfo = new ProjectInfo
            {
                Name = projectName,
                Subdomain = subdomain,
                Created = DateTime.Now,
                LastSaved = DateTime.Now
            };
            
            await ProjectService.SaveProject(subdomain, projectInfo, new List<ProjectComponent>());
            
            var previewUrl = $"/projects/{subdomain}/index.html";
            codeBlock.SandboxUrl = previewUrl;
            
            await AddSystemMessage($"✅ Sandbox running at: {previewUrl}");
            await AddSystemMessage($"📁 Project location: {projectDir}");
            
            if (codeBlock.Language == "python" || codeBlock.Language == "csharp" || codeBlock.Language == "php")
            {
                int port = codeBlock.Language switch
                {
                    "python" => 5000,
                    "csharp" => 5005,
                    "php" => 8000,
                    _ => 3000
                };
                
                BackendTracker.RegisterBackend(subdomain, port, codeBlock.Language);
                await AddSystemMessage($"🌐 Backend registered with reverse proxy on port {port}");
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await AddSystemMessage($"❌ Sandbox error: {ex.Message}");
        }
        finally
        {
            isSandboxRunning = false;
            StateHasChanged();
        }
    }

    private async Task TestCode(CodeBlock codeBlock)
    {
        try
        {
            await AddSystemMessage($"🧪 Testing {codeBlock.Language} code on D: drive...");
            
            var testDir = Path.Combine(testBasePath, Guid.NewGuid().ToString());
            Directory.CreateDirectory(testDir);
            
            string fileName = codeBlock.Language switch
            {
                "python" => "test.py",
                "javascript" => "test.js",
                "csharp" => "test.cs",
                "php" => "test.php",
                _ => "test.txt"
            };
            
            var filePath = Path.Combine(testDir, fileName);
            await File.WriteAllTextAsync(filePath, codeBlock.Code);
            
            var output = new StringBuilder();
            
            if (codeBlock.Language == "python")
            {
                var process = new Process
                {
                    StartInfo = new ProcessStartInfo
                    {
                        FileName = "python",
                        Arguments = $"test.py",
                        WorkingDirectory = testDir,
                        UseShellExecute = false,
                        RedirectStandardOutput = true,
                        RedirectStandardError = true,
                        CreateNoWindow = true
                    }
                };
                
                process.Start();
                output.AppendLine(await process.StandardOutput.ReadToEndAsync());
                output.AppendLine(await process.StandardError.ReadToEndAsync());
                await process.WaitForExitAsync();
            }
            else if (codeBlock.Language == "javascript")
            {
                var process = new Process
                {
                    StartInfo = new ProcessStartInfo
                    {
                        FileName = "node",
                        Arguments = $"test.js",
                        WorkingDirectory = testDir,
                        UseShellExecute = false,
                        RedirectStandardOutput = true,
                        RedirectStandardError = true,
                        CreateNoWindow = true
                    }
                };
                
                process.Start();
                output.AppendLine(await process.StandardOutput.ReadToEndAsync());
                output.AppendLine(await process.StandardError.ReadToEndAsync());
                await process.WaitForExitAsync();
            }
            else
            {
                output.AppendLine("Test only available for Python and JavaScript at this time.");
            }
            
            codeBlock.TestOutput = output.ToString();
            await AddSystemMessage("✅ Test completed!");
            StateHasChanged();
            
            _ = Task.Run(async () =>
            {
                await Task.Delay(TimeSpan.FromMinutes(5));
                try { Directory.Delete(testDir, true); } catch { }
            });
        }
        catch (Exception ex)
        {
            codeBlock.TestOutput = $"Error: {ex.Message}";
            await AddSystemMessage($"❌ Test failed: {ex.Message}");
            StateHasChanged();
        }
    }

