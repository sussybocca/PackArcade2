    private async Task ExecuteModalAction()
    {
        if (modalType == "invite")
        {
            var subdomain = GetSubdomain();
            var projectUrl = GetProjectUrl();
            var subject = $"Invitation to collaborate on {projectName}";
            var body = $@"
                <h2>You've been invited to collaborate on {projectName}</h2>
                <p>Join the project at: <a href='{projectUrl}'>{projectUrl}</a></p>
                <p>Your permission level: {invitePermission}</p>
                <p>Collaborate and build amazing things together!</p>
            ";
            
            try
            {
                await SendEmailAsync(inviteEmail, subject, body);
                
                var newCollaborator = new Collaborator
                {
                    UserId = inviteEmail,
                    Username = inviteEmail.Split('@')[0],
                    JoinedAt = DateTime.Now,
                    Permission = invitePermission
                };
                activeCollaborators.Add(newCollaborator);
                await SaveCollaborators();
                statusMessage = $"Invitation sent to {inviteEmail}";
            }
            catch (Exception ex)
            {
                statusMessage = $"Failed to send invitation: {ex.Message}";
            }
        }
        else if (modalType == "comment" || modalType == "reply")
        {
            var comment = new ProjectComment
            {
                Id = Guid.NewGuid().ToString(),
                Author = clientIp ?? "anonymous",
                Text = newCommentText,
                FileName = commentFile,
                Timestamp = DateTime.Now,
                Replies = new List<ProjectComment>()
            };
            
            projectComments.Add(comment);
            await SaveComments();
            statusMessage = "Comment added";
        }
        
        await JSRuntime.InvokeVoidAsync("hideModal", "collaborationModal");
        StateHasChanged();
    }
    
