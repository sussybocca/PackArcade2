    private async Task TogglePlugin(Plugin plugin)
    {
        try
        {
            var subdomain = GetSubdomain();
            var installedFile = Path.Combine(dataPath, "plugins", $"{subdomain}_installed.json");
            List<string> installedIds = new();
            
            if (File.Exists(installedFile))
            {
                var json = await File.ReadAllTextAsync(installedFile);
                installedIds = JsonSerializer.Deserialize<List<string>>(json) ?? new();
            }
            
            if (plugin.Installed)
            {
                installedIds.Remove(plugin.Id);
                statusMessage = $"Plugin '{plugin.Name}' uninstalled";
                
                // Remove plugin files from project
                var pluginPath = Path.Combine(Environment.WebRootPath, "projects", subdomain, ".plugins", plugin.Id);
                if (Directory.Exists(pluginPath))
                {
                    Directory.Delete(pluginPath, true);
                }
            }
            else
            {
                installedIds.Add(plugin.Id);
                statusMessage = $"Plugin '{plugin.Name}' installed";
                
                // Create plugin configuration
                var pluginPath = Path.Combine(Environment.WebRootPath, "projects", subdomain, ".plugins", plugin.Id);
                Directory.CreateDirectory(pluginPath);
                
                var configFile = Path.Combine(pluginPath, "config.json");
                var config = new { id = plugin.Id, name = plugin.Name, enabled = true, installedAt = DateTime.Now };
                var configJson = JsonSerializer.Serialize(config, new JsonSerializerOptions { WriteIndented = true });
                await File.WriteAllTextAsync(configFile, configJson);
            }
            
            plugin.Installed = !plugin.Installed;
            
            var newJson = JsonSerializer.Serialize(installedIds, new JsonSerializerOptions { WriteIndented = true });
            await File.WriteAllTextAsync(installedFile, newJson);
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            statusMessage = $"Error toggling plugin: {ex.Message}";
        }
    }
    
    private async Task ConnectAPI(APIEndpoint api)
    {
        try
        {
            var subdomain = GetSubdomain();
            var connectedFile = Path.Combine(dataPath, "apis", $"{subdomain}_connected.json");
            List<string> connectedIds = new();
            
            if (File.Exists(connectedFile))
            {
                var json = await File.ReadAllTextAsync(connectedFile);
                connectedIds = JsonSerializer.Deserialize<List<string>>(json) ?? new();
            }
            
            if (api.Connected)
            {
                connectedIds.Remove(api.Id);
                statusMessage = $"API '{api.Name}' disconnected";
                
                // Remove API credentials
                var apiCredFile = Path.Combine(Environment.WebRootPath, "projects", subdomain, ".apis", $"{api.Id}.json");
                if (File.Exists(apiCredFile))
                {
                    File.Delete(apiCredFile);
                }
            }
            else
            {
                // Show API key input modal
                var apiKey = await JSRuntime.InvokeAsync<string>("prompt", $"Enter API key for {api.Name}:");
                if (!string.IsNullOrEmpty(apiKey))
                {
                    connectedIds.Add(api.Id);
                    statusMessage = $"API '{api.Name}' connected";
                    
                    // Save API credentials
                    var apiCredPath = Path.Combine(Environment.WebRootPath, "projects", subdomain, ".apis");
                    Directory.CreateDirectory(apiCredPath);
                    var apiCredFile = Path.Combine(apiCredPath, $"{api.Id}.json");
                    var credentials = new { apiId = api.Id, apiKey = apiKey, connectedAt = DateTime.Now };
                    var credJson = JsonSerializer.Serialize(credentials, new JsonSerializerOptions { WriteIndented = true });
                    await File.WriteAllTextAsync(apiCredFile, credJson);
                }
                else
                {
                    statusMessage = "API key required to connect";
                    return;
                }
            }
            
            api.Connected = !api.Connected;
            
            var newJson = JsonSerializer.Serialize(connectedIds, new JsonSerializerOptions { WriteIndented = true });
            await File.WriteAllTextAsync(connectedFile, newJson);
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            statusMessage = $"Error connecting API: {ex.Message}";
        }
    }
    
