    private string GetFileIcon(string fileName)
    {
        if (fileName.EndsWith(".html")) return "🌐";
        if (fileName.EndsWith(".css")) return "🎨";
        if (fileName.EndsWith(".js")) return "⚡";
        if (fileName.EndsWith(".cs")) return "🔷";
        if (fileName.EndsWith(".py")) return "🐍";
        if (fileName.EndsWith(".php")) return "🐘";
        if (fileName.EndsWith(".json")) return "📋";
        if (fileName.EndsWith(".fn.js")) return "⚡";
        if (!Path.HasExtension(fileName)) return "📁";
        return "📄";
    }

    private string GetSubdomain() => Regex.Replace(projectName.ToLower(), @"[^a-z0-9-]", "");

    private string GetProjectUrl() => $"http://{GetSubdomain()}.packarcade.win";

    private async Task SelectFile(string fileName)
    {
        selectedFile = fileName;
        var file = projectFiles.FirstOrDefault(f => f.Name == fileName);
        if (file != null)
        {
            fileContent = file.Content;
            await JSRuntime.InvokeVoidAsync("setEditorContent", fileContent);
        }
    }

    private async Task AddNewFile()
    {
        var fileName = await JSRuntime.InvokeAsync<string>("prompt", "Enter file name (e.g., script.js, hello.fn.js for functions):");
        if (!string.IsNullOrEmpty(fileName))
        {
            var extension = Path.GetExtension(fileName).ToLower();
            string type;
            
            if (fileName.EndsWith(".fn.js"))
            {
                type = "function";
                consoleOutput.Add($"> Function file created: {fileName}");
            }
            else if (string.IsNullOrEmpty(extension))
            {
                type = "apprunner";
                string appRunnerFolder = Path.Combine(appRunnersPath, fileName);
                Directory.CreateDirectory(appRunnerFolder);
                string tsFilePath = Path.Combine(appRunnerFolder, $"{fileName}.ts");
                await File.WriteAllTextAsync(tsFilePath, @"// TypeScript AppRunner
console.log('AppRunner started: ' + __filename);
setInterval(() => {
    console.log('Heartbeat...');
}, 30000);");
                consoleOutput.Add($"> Created AppRunner folder: {fileName}");
            }
            else
            {
                type = extension switch
                {
                    ".html" => "html",
                    ".css" => "css",
                    ".js" => "js",
                    ".cs" => "cs",
                    ".py" => "py",
                    ".php" => "php",
                    ".json" => "json",
                    _ => "text"
                };
            }

            projectFiles.Add(new ProjectFile
            {
                Name = fileName,
                Type = type,
                Content = GetDefaultContent(type)
            });
            
            selectedFile = fileName;
            fileContent = GetDefaultContent(type);
            await JSRuntime.InvokeVoidAsync("setEditorContent", fileContent);
            StateHasChanged();
        }
    }

