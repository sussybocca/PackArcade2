    private async void StopBackend()
    {
        if (backendProcess != null && !backendProcess.HasExited)
        {
            terminationCts?.Cancel();
            
            consoleOutput.Add("");
            consoleOutput.Add("⏹️ Stopping backend server...");
            
            bool terminated = await TerminateProcessWithMultipleFallbacks(backendProcess.Id, currentBackendPort, backendProcess, currentJob);
            
            if (terminated)
            {
                consoleOutput.Add("✅ Backend server stopped successfully.");
            }
            else
            {
                consoleOutput.Add("⚠️ Backend server may not have stopped completely.");
            }
            
            backendProcess = null;
        }
        else
        {
            consoleOutput.Add("> No backend server running.");
        }
        
        if (!string.IsNullOrEmpty(currentTempDir) && Directory.Exists(currentTempDir))
        {
            try
            {
                Directory.Delete(currentTempDir, true);
                consoleOutput.Add("> Temp folder cleaned up");
            }
            catch { }
            currentTempDir = null;
        }
        
        isBackendRunning = false;
        currentBackendPort = 0;
        StateHasChanged();
    }
    
    // ========== LONG-TERM APP ==========
    private async Task StartLongTermApp()
    {
        if (selectedFramework == "static")
        {
            consoleOutput.Add("> Static site has no backend to start as Long-Term App.");
            return;
        }

        await SaveProject();
        
        var subdomain = GetSubdomain();
        var projectDir = Path.Combine(Environment.WebRootPath, "projects", subdomain);
        
        consoleOutput.Clear();
        consoleOutput.Add($"> Starting Long-Term App ({selectedFramework}) for {subdomain}...");
        consoleOutput.Add($"> Project directory: {projectDir}");
        consoleOutput.Add($"> This app will run for 20 minutes with full sandboxing.");
        
        if (longTermAppProcess != null && !longTermAppProcess.HasExited)
        {
            consoleOutput.Add($"> Stopping existing Long-Term App...");
            await TerminateProcessWithMultipleFallbacks(longTermAppProcess.Id, longTermAppPort, longTermAppProcess, longTermAppJob);
        }
        
        if (!string.IsNullOrEmpty(longTermAppTempDir) && Directory.Exists(longTermAppTempDir))
        {
            try { Directory.Delete(longTermAppTempDir, true); } catch { }
            longTermAppTempDir = null;
        }
        
        switch (selectedFramework)
        {
            case "node":
                await StartLongTermNodeBackend(projectDir);
                break;
            case "python":
                await StartLongTermPythonBackend(projectDir);
                break;
            case "csharp":
                await StartLongTermCSharpBackend(projectDir);
                break;
            case "php":
                await StartLongTermPHPBackend(projectDir);
                break;
            case "apprunner":
                await StartLongTermAppRunner(projectDir);
                break;
            default:
                consoleOutput.Add($"> Unknown framework for Long-Term App: {selectedFramework}");
                break;
        }
        
        selectedTab = "console";
        StateHasChanged();
    }
    
