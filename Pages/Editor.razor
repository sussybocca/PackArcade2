    private async Task LaunchWindowsSandbox()
    {
        try
        {
            await SaveProject();
            var subdomain = GetSubdomain();
            var projectPath = Path.Combine(Environment.WebRootPath, "projects", subdomain);
            
            if (!Directory.Exists(projectPath))
            {
                consoleOutput.Add("[OSRunners] Project directory not found. Please save the project first.");
                return;
            }

            string sandboxExe = @"C:\Windows\System32\WindowsSandbox.exe";
            if (!File.Exists(sandboxExe))
            {
                consoleOutput.Add("[OSRunners] Windows Sandbox is not installed or not found.");
                consoleOutput.Add("[OSRunners] Please enable Windows Sandbox in Windows Features (Windows 10/11 Pro/Enterprise).");
                consoleOutput.Add("[OSRunners] Go to: Control Panel -> Programs -> Turn Windows Features on or off -> Check 'Windows Sandbox'");
                return;
            }

            string sandboxConfigDir = Path.Combine(Path.GetTempPath(), "PackArcade2_OSRunners", Guid.NewGuid().ToString());
            Directory.CreateDirectory(sandboxConfigDir);
            
            string welcomePage = $@"<!DOCTYPE html>
<html>
<head><title>PackArcade2 - {projectName}</title></head>
<body>
<h1>Your project '{projectName}' is ready!</h1>
<p>The project folder has been mounted to <code>C:\Users\WDAGUtilityAccount\Desktop\Project</code>.</p>
<p>You can open it in Explorer or run your backend from there.</p>
<p>Project URL: <a href='{GetProjectUrl()}'>{GetProjectUrl()}</a></p>
<script>
    setTimeout(function() {{
        window.open('file:///C:/Users/WDAGUtilityAccount/Desktop/Project', '_blank');
    }}, 2000);
</script>
</body>
</html>";
            string welcomePath = Path.Combine(sandboxConfigDir, "welcome.html");
            await File.WriteAllTextAsync(welcomePath, welcomePage);
            
            string wsbPath = Path.Combine(sandboxConfigDir, "sandbox.wsb");
            string wsbContent = $@"<Configuration>
  <VGpu>Disable</VGpu>
  <Networking>Enable</Networking>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>{projectPath}</HostFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
    <MappedFolder>
      <HostFolder>{sandboxConfigDir}</HostFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>cmd.exe /c start C:\Users\WDAGUtilityAccount\Desktop\welcome.html</Command>
  </LogonCommand>
</Configuration>";
            
            await File.WriteAllTextAsync(wsbPath, wsbContent);
            
            consoleOutput.Add("[OSRunners] Windows Sandbox configuration created.");
            consoleOutput.Add("[OSRunners] Launching Windows Sandbox...");
            consoleOutput.Add("[OSRunners] A new window will open with a full Windows environment.");
            consoleOutput.Add("[OSRunners] Your project files are mounted on the desktop.");
            
            var startInfo = new ProcessStartInfo
            {
                FileName = sandboxExe,
                Arguments = $"\"{wsbPath}\"",
                UseShellExecute = true,
                CreateNoWindow = false
            };
            
            Process.Start(startInfo);
            
            consoleOutput.Add("[OSRunners] Windows Sandbox launched. Enjoy testing in a full OS!");
            
            _ = Task.Delay(10000).ContinueWith(_ =>
            {
                try { Directory.Delete(sandboxConfigDir, true); } catch { }
            });
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"[OSRunners] ERROR: {ex.Message}");
            consoleOutput.Add("[OSRunners] Make sure Windows Sandbox is enabled in Windows Features (Windows 10/11 Pro/Enterprise).");
        }
    }
    
