    private string GeneratePreviewHtml()
    {
        var htmlFile = projectFiles.FirstOrDefault(f => f.Name.EndsWith(".html"));
        if (htmlFile == null) return "<h1>No HTML file found</h1>";

        var html = htmlFile.Content;
        
        var cssFiles = projectFiles.Where(f => f.Name.EndsWith(".css"));
        foreach (var css in cssFiles)
        {
            var styleTag = $"<style>{css.Content}</style>";
            html = html.Replace("</head>", $"{styleTag}</head>");
        }

        var jsFiles = projectFiles.Where(f => f.Name.EndsWith(".js") && !f.Name.EndsWith(".fn.js"));
        foreach (var js in jsFiles)
        {
            var scriptTag = $"<script>{js.Content}</script>";
            html = html.Replace("</body>", $"{scriptTag}</body>");
        }

        return html;
    }

    // ========== ENHANCED TERMINATION METHODS (PRESERVED) ==========
    private async Task<bool> TerminateProcessWithMultipleFallbacks(int pid, int port, Process? process = null, IntPtr? job = null)
    {
        consoleOutput.Add($"⏰ TERMINATION STARTED: Ending process PID {pid} on port {port}...");
        
        bool success = false;
        
        if (job.HasValue && job.Value != IntPtr.Zero)
        {
            try
            {
                success = TerminateJobObject(job.Value, 1);
                if (success)
                {
                    consoleOutput.Add($"✅ Method 1 SUCCESS: Terminated via Job Object (PID: {pid})");
                    return true;
                }
                else
                {
                    consoleOutput.Add($"⚠️ Method 1 FAILED: Job Object termination failed");
                }
            }
            catch (Exception ex)
            {
                consoleOutput.Add($"⚠️ Method 1 ERROR: {ex.Message}");
            }
        }
        
        try
        {
            bool ctrlSuccess = GenerateConsoleCtrlEvent(CTRL_C_EVENT, (uint)pid);
            if (ctrlSuccess)
            {
                await Task.Delay(2000);
                try
                {
                    var checkProcess = Process.GetProcessById(pid);
                    if (checkProcess != null && !checkProcess.HasExited)
                    {
                        consoleOutput.Add($"⚠️ Ctrl+C sent but process still running after 2 seconds");
                    }
                    else
                    {
                        consoleOutput.Add($"✅ Method 2 SUCCESS: Sent Ctrl+C to process (PID: {pid})");
                        return true;
                    }
                }
                catch (ArgumentException)
                {
                    consoleOutput.Add($"✅ Method 2 SUCCESS: Process PID {pid} already terminated");
                    return true;
                }
            }
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"⚠️ Method 2 ERROR: {ex.Message}");
        }
        
        try
        {
            if (process != null && !process.HasExited)
            {
                process.Kill();
                await process.WaitForExitAsync();
                if (process.HasExited)
                {
                    consoleOutput.Add($"✅ Method 3 SUCCESS: Process.Kill() terminated PID {pid}");
                    return true;
                }
            }
            else
            {
                try
                {
                    var proc = Process.GetProcessById(pid);
                    proc.Kill();
                    await proc.WaitForExitAsync();
                    consoleOutput.Add($"✅ Method 3 SUCCESS: Process.Kill() terminated PID {pid}");
                    return true;
                }
                catch (ArgumentException)
                {
                    consoleOutput.Add($"✅ Method 3: Process PID {pid} already gone");
                    return true;
                }
            }
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"⚠️ Method 3 ERROR: {ex.Message}");
        }
        
        try
        {
            var taskkillPsi = new ProcessStartInfo
            {
                FileName = "taskkill",
                Arguments = $"/F /PID {pid} /T",
                UseShellExecute = false,
                RedirectStandardOutput = true,
                RedirectStandardError = true,
                CreateNoWindow = true
            };
            
            var taskkillProcess = Process.Start(taskkillPsi);
            if (taskkillProcess != null)
            {
                await taskkillProcess.WaitForExitAsync();
                if (taskkillProcess.ExitCode == 0)
                {
                    consoleOutput.Add($"✅ Method 4 SUCCESS: taskkill /F terminated PID {pid}");
                    return true;
                }
            }
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"⚠️ Method 4 ERROR: {ex.Message}");
        }
        
        if (port > 0)
        {
            try
            {
                consoleOutput.Add($"🔍 Method 5: Finding processes on port {port}...");
                
                var netstatPsi = new ProcessStartInfo
                {
                    FileName = "netstat",
                    Arguments = "-ano | findstr :" + port,
                    UseShellExecute = false,
                    RedirectStandardOutput = true,
                    CreateNoWindow = true
                };
                
                var netstatProcess = Process.Start(netstatPsi);
                if (netstatProcess != null)
                {
                    string netstatOutput = await netstatProcess.StandardOutput.ReadToEndAsync();
                    await netstatProcess.WaitForExitAsync();
                    
                    var pidMatches = Regex.Matches(netstatOutput, @"\s+(\d+)\s*$", RegexOptions.Multiline);
                    var pids = new HashSet<int>();
                    
                    foreach (Match match in pidMatches)
                    {
                        if (int.TryParse(match.Groups[1].Value, out int foundPid))
                        {
                            pids.Add(foundPid);
                        }
                    }
                    
                    foreach (var foundPid in pids)
                    {
                        consoleOutput.Add($"   Found PID {foundPid} using port {port}");
                        var killByPortPsi = new ProcessStartInfo
                        {
                            FileName = "taskkill",
                            Arguments = $"/F /PID {foundPid} /T",
                            UseShellExecute = false,
                            RedirectStandardOutput = true,
                            RedirectStandardError = true,
                            CreateNoWindow = true
                        };
                        
                        var killProcess = Process.Start(killByPortPsi);
                        if (killProcess != null)
                        {
                            await killProcess.WaitForExitAsync();
                            if (killProcess.ExitCode == 0)
                            {
                                consoleOutput.Add($"✅ Method 5 SUCCESS: Killed PID {foundPid} on port {port}");
                                success = true;
                            }
                        }
                    }
                    if (success) return true;
                }
            }
            catch (Exception ex)
            {
                consoleOutput.Add($"⚠️ Method 5 ERROR: {ex.Message}");
            }
        }
        
        consoleOutput.Add($"❌ ALL TERMINATION METHODS FAILED for PID {pid}");
        return false;
    }

    private async Task ScheduleAutoTermination(int pid, int port, Process process, IntPtr job, int timeoutSeconds, string label)
    {
        var cts = new CancellationTokenSource();
        if (label == "backend")
        {
            terminationCts?.Cancel();
            terminationCts = cts;
        }
        else if (label == "longterm")
        {
            longTermAppTerminationCts?.Cancel();
            longTermAppTerminationCts = cts;
        }
        else if (label == "localdev")
        {
            localDevTerminationCts?.Cancel();
            localDevTerminationCts = cts;
        }
        
        consoleOutput.Add($"⏱️ Auto-termination scheduled in {timeoutSeconds / 60} minutes for {label} PID {pid}");
        
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(timeoutSeconds * 1000, cts.Token);
                
                await InvokeAsync(async () =>
                {
                    consoleOutput.Add("");
                    consoleOutput.Add($"════════════════════════════════════════════════════════════");
                    consoleOutput.Add($"⚠️ {timeoutSeconds / 60} MINUTE TIMEOUT REACHED - Terminating {label}...");
                    consoleOutput.Add($"════════════════════════════════════════════════════════════");
                    
                    bool terminated = await TerminateProcessWithMultipleFallbacks(pid, port, process, job);
                    
                    if (terminated)
                    {
                        consoleOutput.Add("");
                        consoleOutput.Add($"✅ {label.ToUpper()} TERMINATED SUCCESSFULLY");
                        
                        if (label == "backend")
                        {
                            try { BackendTracker.UnregisterBackend(GetSubdomain()); } catch { }
                            isBackendRunning = false;
                            backendProcess = null;
                            currentJob = null;
                            currentBackendPort = 0;
                        }
                        else if (label == "longterm")
                        {
                            isLongTermAppRunning = false;
                            longTermAppProcess = null;
                            longTermAppJob = null;
                            longTermAppPort = 0;
                        }
                        else if (label == "localdev")
                        {
                            isLocalDevRunning = false;
                            localDevProcess = null;
                            localDevJob = null;
                        }
                        StateHasChanged();
                    }
                    else
                    {
                        consoleOutput.Add("");
                        consoleOutput.Add($"❌ CRITICAL: Could not terminate {label} process!");
                        consoleOutput.Add($"   Please run: taskkill /F /PID {pid} /T");
                    }
                });
            }
            catch (OperationCanceledException)
            {
                consoleOutput.Add($"⏹️ Auto-termination cancelled for {label} PID {pid}");
            }
            catch (Exception ex)
            {
                await InvokeAsync(() =>
                {
                    consoleOutput.Add($"⚠️ Auto-termination error: {ex.Message}");
                });
            }
        });
    }

    // ========== ROBUST FILE COPYING METHODS ==========
    private async Task CopyFileWithRetry(string sourcePath, string destPath, int maxRetries = 3)
    {
        for (int i = 0; i < maxRetries; i++)
        {
            try
            {
                using (var sourceStream = new FileStream(sourcePath, FileMode.Open, FileAccess.Read, FileShare.ReadWrite, 4096, true))
                using (var destStream = new FileStream(destPath, FileMode.Create, FileAccess.Write, FileShare.None, 4096, true))
                {
                    await sourceStream.CopyToAsync(destStream);
                }
                return;
            }
            catch (IOException ex)
            {
                if (i == maxRetries - 1)
                {
                    consoleOutput.Add($"⚠️ Failed to copy file {sourcePath} after {maxRetries} attempts: {ex.Message}");
                    throw;
                }
                await Task.Delay(500 * (i + 1));
            }
            catch (Exception ex)
            {
                consoleOutput.Add($"⚠️ Unexpected error copying {sourcePath}: {ex.Message}");
                throw;
            }
        }
    }

    private async Task CopyDirectoryAsync(string sourceDir, string destinationDir)
    {
        Directory.CreateDirectory(destinationDir);
        
        var files = Directory.GetFiles(sourceDir, "*", SearchOption.TopDirectoryOnly);
        foreach (var file in files)
        {
            var destFile = Path.Combine(destinationDir, Path.GetFileName(file));
            await CopyFileWithRetry(file, destFile);
        }
        
        var subDirs = Directory.GetDirectories(sourceDir);
        foreach (var subDir in subDirs)
        {
            var dirName = Path.GetFileName(subDir);
            var destSubDir = Path.Combine(destinationDir, dirName);
            await CopyDirectoryAsync(subDir, destSubDir);
        }
    }

    // ========== CUSTOM SANDBOXED PROCESS LAUNCHER ==========
    private async Task<Process> StartSandboxedProcess(ProcessStartInfo startInfo, bool isFunction = false, int? customTimeoutSeconds = null, string? customTempDir = null, bool? disableNetworkOverride = null, string? customPriority = null)
    {
        string tempDir = customTempDir ?? Path.Combine(Path.GetTempPath(), "PackArcade2", Guid.NewGuid().ToString());
        Directory.CreateDirectory(tempDir);
        if (customTempDir == null)
            currentTempDir = tempDir;
        else
            localDevTempDir = tempDir;
        
        if (Directory.Exists(startInfo.WorkingDirectory))
        {
            await CopyDirectoryAsync(startInfo.WorkingDirectory, tempDir);
        }
        
        startInfo.WorkingDirectory = tempDir;
        startInfo.LoadUserProfile = false;
        startInfo.CreateNoWindow = true;
        startInfo.WindowStyle = ProcessWindowStyle.Hidden;
        
        if ((disableNetworkOverride ?? disableNetwork) && startInfo.FileName != "node" && startInfo.FileName != "python")
        {
            consoleOutput.Add("[SANDBOX] Network disabling requested - not fully implemented, but process is isolated.");
        }
        
        var process = new Process { StartInfo = startInfo };
        process.Start();
        
        IntPtr job = CreateJobObject(IntPtr.Zero, null);
        
        int timeout = customTimeoutSeconds ?? (isFunction ? maxFunctionTimeSeconds : sandboxTimeoutMinutes * 60);
        
        uint limitFlags = JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE | JOB_OBJECT_LIMIT_PROCESS_TIME | 
                          JOB_OBJECT_LIMIT_JOB_TIME | JOB_OBJECT_LIMIT_PROCESS_MEMORY;
        
        uint priorityClass = BELOW_NORMAL_PRIORITY_CLASS;
        string effectivePriority = customPriority ?? sandboxCpuPriority;
        switch (effectivePriority)
        {
            case "Idle": priorityClass = IDLE_PRIORITY_CLASS; break;
            case "BelowNormal": priorityClass = BELOW_NORMAL_PRIORITY_CLASS; break;
            case "Normal": priorityClass = NORMAL_PRIORITY_CLASS; break;
        }
        
        var limits = new JOBOBJECT_EXTENDED_LIMIT_INFORMATION
        {
            BasicLimitInformation = new JOBOBJECT_BASIC_LIMIT_INFORMATION
            {
                LimitFlags = limitFlags,
                PerProcessUserTimeLimit = timeout * 10000000L,
                PerJobUserTimeLimit = timeout * 10000000L * 2,
                PriorityClass = priorityClass
            },
            ProcessMemoryLimit = new UIntPtr((ulong)sandboxMemoryMB * 1024 * 1024),
            JobMemoryLimit = new UIntPtr((ulong)sandboxMemoryMB * 1024 * 1024 * 2)
        };
        
        SetInformationJobObject(job, 9, ref limits, (uint)Marshal.SizeOf(limits));
        AssignProcessToJobObject(job, process.Handle);
        
        if (customTimeoutSeconds == LONG_TERM_APP_TIMEOUT_SECONDS)
        {
            longTermAppJob = job;
        }
        else if (customTempDir != null)
        {
            localDevJob = job;
        }
        else
        {
            currentJob = job;
        }
        
        return process;
    }

    // ========== BACKUP METHODS ==========
    private async Task CreateBackup(string subdomain)
    {
        try
        {
            string timestamp = DateTime.Now.ToString("yyyy-MM-dd_HH-mm-ss");
            string backupName = $"{subdomain}_{timestamp}.zip";
            string backupFilePath = Path.Combine(backupPath, backupName);
            string projectDir = Path.Combine(Environment.WebRootPath, "projects", subdomain);
            
            if (Directory.Exists(projectDir))
            {
                ZipFile.CreateFromDirectory(projectDir, backupFilePath);
                consoleOutput.Add($"> ✅ Auto-backup created: {backupName}");
                await CleanOldBackups(subdomain);
            }
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"> ⚠️ Backup warning: {ex.Message}");
        }
    }
    
    private async Task CleanOldBackups(string subdomain)
    {
        try
        {
            var backups = Directory.GetFiles(backupPath, $"{subdomain}_*.zip")
                                   .OrderByDescending(f => f)
                                   .ToList();
            
            if (backups.Count > 10)
            {
                foreach (var oldBackup in backups.Skip(10))
                {
                    File.Delete(oldBackup);
                }
                consoleOutput.Add($"> 🧹 Cleaned old backups (kept last 10)");
            }
        }
        catch { }
        await Task.CompletedTask;
    }

    // ========== BACKEND START METHODS (PRESERVED) ==========
    private async Task StartBackend()
    {
        if (selectedFramework == "static")
        {
            consoleOutput.Add("> Static site has no backend to start.");
            return;
        }

        await SaveProject();
        
        var subdomain = GetSubdomain();
        var projectDir = Path.Combine(Environment.WebRootPath, "projects", subdomain);
        
        consoleOutput.Clear();
        consoleOutput.Add($"> Starting {selectedFramework} backend server for {subdomain}...");
        consoleOutput.Add($"> Project directory: {projectDir}");
        
        if (backendProcess != null && !backendProcess.HasExited)
        {
            consoleOutput.Add($"> Stopping existing server...");
            await TerminateProcessWithMultipleFallbacks(backendProcess.Id, currentBackendPort, backendProcess, currentJob);
        }
        
        if (!string.IsNullOrEmpty(currentTempDir) && Directory.Exists(currentTempDir))
        {
            try { Directory.Delete(currentTempDir, true); } catch { }
            currentTempDir = null;
        }
        
        switch (selectedFramework)
        {
            case "node":
                await StartNodeBackend(projectDir);
                break;
            case "python":
                await StartPythonBackend(projectDir);
                break;
            case "csharp":
                await StartCSharpBackend(projectDir);
                break;
            case "php":
                await StartPHPBackend(projectDir);
                break;
            case "apprunner":
                await StartAppRunner(projectDir);
                break;
            case "function":
                await StartFunction(projectDir);
                break;
            default:
                consoleOutput.Add($"> Unknown framework: {selectedFramework}");
                break;
        }
        
        selectedTab = "console";
        StateHasChanged();
    }
    
    private async Task StartAppRunner(string projectDir)
    {
        try
        {
            consoleOutput.Add($"> Starting AppRunner...");
            isBackendRunning = true;
            currentBackendPort = 3008;
            
            var appRunners = projectFiles.Where(f => f.Type == "apprunner").ToList();
            
            if (!appRunners.Any())
            {
                consoleOutput.Add($"> No AppRunner files found. Create an extensionless file to run a long-term app.");
                isBackendRunning = false;
                return;
            }

            foreach (var app in appRunners)
            {
                string appFolder = Path.Combine(appRunnersPath, app.Name);
                Directory.CreateDirectory(appFolder);
                
                var startInfo = new ProcessStartInfo
                {
                    FileName = "node",
                    Arguments = $"{app.Name}.ts",
                    WorkingDirectory = appFolder,
                    UseShellExecute = false,
                    RedirectStandardOutput = true,
                    RedirectStandardError = true,
                    CreateNoWindow = true
                };
                
                backendProcess = await StartSandboxedProcess(startInfo, isFunction: false);
                
                backendProcess.OutputDataReceived += (s, e) =>
                {
                    if (!string.IsNullOrEmpty(e.Data))
                    {
                        InvokeAsync(() =>
                        {
                            consoleOutput.Add($"> [{app.Name}] {e.Data}");
                            StateHasChanged();
                        });
                    }
                };
                
                backendProcess.ErrorDataReceived += (s, e) =>
                {
                    if (!string.IsNullOrEmpty(e.Data))
                    {
                        InvokeAsync(() =>
                        {
                            consoleOutput.Add($"> [{app.Name}] ERROR: {e.Data}");
                            StateHasChanged();
                        });
                    }
                };
                
                backendProcess.BeginOutputReadLine();
                backendProcess.BeginErrorReadLine();
                
                consoleOutput.Add($"> AppRunner '{app.Name}' started (PID: {backendProcess.Id}) with Windows Job Object sandboxing");
            }
            
            if (enableReverseProxy)
            {
                try
                {
                    BackendTracker.RegisterBackend(GetSubdomain(), currentBackendPort, "apprunner");
                    consoleOutput.Add($"> Registered with reverse proxy on port {currentBackendPort}");
                }
                catch (Exception ex)
                {
                    consoleOutput.Add($"> Warning: Failed to register with reverse proxy: {ex.Message}");
                }
            }
            else
            {
                consoleOutput.Add($"> Reverse proxy disabled - app will not be publicly accessible");
            }
            
            consoleOutput.Add($"> AppRunner started successfully");
            
            if (backendProcess != null)
            {
                await ScheduleAutoTermination(backendProcess.Id, currentBackendPort, backendProcess, currentJob.Value, sandboxTimeoutMinutes * 60, "backend");
            }
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"> Error starting AppRunner: {ex.Message}");
            isBackendRunning = false;
        }
    }
    
