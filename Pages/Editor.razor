@page "/editor/{ProjectName?}"
@using PackArcade2
@using Microsoft.JSInterop
@using System.Text
@using System.Text.Json
@using System.IO
@using System.Diagnostics
@using System.IO.Compression
@using System.Text.RegularExpressions
@using System.Runtime.InteropServices
@using System.Net.Mail
@using System.Net
@inject ProjectService ProjectService
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment
@inject IJSRuntime JSRuntime
@inject BackendTracker BackendTracker
@inject PackArcade2.Services.PointsService PointsService
@inject IConfiguration Configuration

<PageTitle>@(string.IsNullOrEmpty(ProjectName) ? "New Project" : ProjectName) - PackArcade2 Editor</PageTitle>

<div class="container-fluid p-0">
   <!-- Top Toolbar -->
<div class="toolbar bg-dark text-white p-2 d-flex align-items-center flex-wrap" style="border-bottom: 1px solid #444; gap: 8px;">
    <button class="btn btn-sm btn-success" @onclick="SaveProject">💾 Save</button>
    <button class="btn btn-sm btn-primary" @onclick="PublishProject">🚀 Publish</button>
    <button class="btn btn-sm btn-info" @onclick="RunPreview">▶ Run</button>
    <button class="btn btn-sm btn-secondary" @onclick="AddNewFile">📄 New File</button>
    
    <!-- Framework Selection Dropdown -->
    <div class="d-flex align-items-center" style="gap: 8px;">
        <span class="text-white">Framework:</span>
        <select @bind="selectedFramework" class="form-select form-select-sm bg-dark text-white" style="width: 130px;">
            <option value="node">Node.js</option>
            <option value="python">Python</option>
            <option value="csharp">C#</option>
            <option value="php">PHP</option>
            <option value="apprunner">AppRunner</option>
            <option value="function">Function (Short-term)</option>
            <option value="static">Static (No Backend)</option>
        </select>
    </div>
    
    <!-- Backend control buttons -->
    <button class="btn btn-sm btn-warning" @onclick="StartBackend" disabled="@(selectedFramework == "static" || isBackendRunning)">
        @(isBackendRunning ? "Running..." : "🚀 Start Backend")
    </button>
    <button class="btn btn-sm btn-danger" @onclick="StopBackend" disabled="@(!isBackendRunning)">
        ⏹️ Stop Backend
    </button>
    
    <!-- Long-Term App button -->
    <button class="btn btn-sm btn-info" @onclick="StartLongTermApp" disabled="@(selectedFramework == "static" || isLongTermAppRunning)">
        @(isLongTermAppRunning ? "Long‑Term (20min)" : "🚀 Long‑Term (20min)")
    </button>
    <button class="btn btn-sm btn-danger" @onclick="StopLongTermApp" disabled="@(!isLongTermAppRunning)">
        ⏹️ Stop Long‑Term
    </button>
    
    <!-- Local Dev Mode -->
    <button class="btn btn-sm btn-secondary" @onclick="StartLocalDevMode" disabled="@(selectedFramework == "static" || isLocalDevRunning)">
        @(isLocalDevRunning ? "Local Dev Running" : "💻 Local Dev Mode")
    </button>
    <button class="btn btn-sm btn-danger" @onclick="StopLocalDevMode" disabled="@(!isLocalDevRunning)">
        ⏹️ Stop Local Dev
    </button>
    
    <!-- Collaboration Dropdown -->
    <div class="dropdown">
        <button class="btn btn-sm btn-dark dropdown-toggle" type="button" id="collaborationDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            👥 Collaborate
        </button>
        <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="collaborationDropdown">
            <li><button class="dropdown-item" @onclick="ShowTeamInvite">👥 Invite Team Member</button></li>
            <li><button class="dropdown-item" @onclick="ShowComments">💬 View Comments</button></li>
            <li><button class="dropdown-item" @onclick="AddComment">✏️ Add Comment</button></li>
            <li><button class="dropdown-item" @onclick="ForkProject">🍴 Fork Project</button></li>
            <li><hr class="dropdown-divider"></li>
            <li><div class="dropdown-item-text">Active Collaborators: <span class="badge bg-info">@activeCollaborators.Count</span></div></li>
        </ul>
    </div>
    
    <!-- Ecosystem Dropdown -->
    <div class="dropdown">
        <button class="btn btn-sm btn-dark dropdown-toggle" type="button" id="ecosystemDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            🧩 Ecosystem
        </button>
        <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="ecosystemDropdown">
            <li><button class="dropdown-item" @onclick="ShowTemplateMarketplace">📚 Template Marketplace</button></li>
            <li><button class="dropdown-item" @onclick="ShowPluginManager">🔌 Plugin Manager</button></li>
            <li><button class="dropdown-item" @onclick="ShowAPIMarketplace">🔗 API Marketplace</button></li>
            <li><button class="dropdown-item" @onclick="OpenCommunityForum">💬 Community Forum</button></li>
        </ul>
    </div>
    
    <!-- Dev Tools Dropdown -->
    <div class="dropdown">
        <button class="btn btn-sm btn-dark dropdown-toggle" type="button" id="devToolsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            🛠️ Dev Tools
        </button>
        <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="devToolsDropdown">
            <li><button class="dropdown-item" @onclick="ExportToGit">📦 Export to Git</button></li>
            <li><button class="dropdown-item" @onclick="SetupLocalCICD">⚙️ Setup Local CI/CD</button></li>
            <li><button class="dropdown-item" @onclick="OpenDebugger">🐛 Open Debugger</button></li>
            <li><button class="dropdown-item" @onclick="RunTests">🧪 Run Tests</button></li>
            <li><hr class="dropdown-divider"></li>
            <li><button class="dropdown-item" @onclick="ViewAnalytics">📊 View Analytics</button></li>
            <li><button class="dropdown-item" @onclick="ViewErrorLogs">⚠️ Error Tracking</button></li>
        </ul>
    </div>
    
    <!-- Advanced Settings Dropdown -->
    <div class="dropdown">
        <button class="btn btn-sm btn-dark dropdown-toggle" type="button" id="advancedSettingsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            ⚙️ Advanced
        </button>
        <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="advancedSettingsDropdown">
            <li><h6 class="dropdown-header">Sandbox Limits</h6></li>
            <li><div class="dropdown-item-text">Memory (MB): <input type="number" @bind="sandboxMemoryMB" class="form-control form-control-sm" style="width: 80px; display: inline-block;" min="64" max="4096" step="64" /></div></li>
            <li><div class="dropdown-item-text">CPU Priority: 
                <select @bind="sandboxCpuPriority" class="form-select form-select-sm" style="width: 100px;">
                    <option value="Idle">Idle</option>
                    <option value="BelowNormal">Below Normal</option>
                    <option value="Normal">Normal</option>
                </select>
            </div></li>
            <li><div class="dropdown-item-text">Timeout (minutes): <input type="number" @bind="sandboxTimeoutMinutes" class="form-control form-control-sm" style="width: 80px; display: inline-block;" min="1" max="60" step="1" /></div></li>
            <li><hr class="dropdown-divider"></li>
            <li><h6 class="dropdown-header">Network</h6></li>
            <li><div class="dropdown-item-text"><input type="checkbox" @bind="disableNetwork" /> Disable Network Access</div></li>
            <li><div class="dropdown-item-text"><input type="checkbox" @bind="enableReverseProxy" /> Enable Reverse Proxy (Hosted)</div></li>
            <li><hr class="dropdown-divider"></li>
            <li><button class="dropdown-item" @onclick="RequestIPPermission">🔑 Request IP Permission</button></li>
            <li><button class="dropdown-item" @onclick="LaunchWindowsSandbox">🪟 Windows Sandbox (OSRunners)</button></li>
        </ul>
    </div>
    
    <!-- Project Name - pushes to the right -->
    <div class="ms-auto d-flex align-items-center" style="gap: 8px;">
        <span class="text-white">Project:</span>
        <input @bind="projectName" class="form-control form-control-sm bg-dark text-white" style="width: 180px;" placeholder="Project Name" />
        <span class="text-muted small">@GetProjectUrl()</span>
        <span class="badge bg-info" @onclick="ToggleCollaboratorStatus" style="cursor: pointer;">👥 @(isCollaboratorMode ? "Collaborating" : "Private")</span>
    </div>
</div>

    <!-- Main Editor Area -->
    <div class="row g-0" style="height: calc(100vh - 110px);">
        <!-- File Explorer -->
        <div class="col-md-2 bg-dark text-white p-2" style="overflow-y: auto; border-right: 1px solid #444;">
            <h6 class="mb-3">Files</h6>
            <div class="file-list">
                @foreach (var file in projectFiles)
                {
                    <div class="file-item @(selectedFile == file.Name ? "active" : "")" 
                         @onclick="@(() => SelectFile(file.Name))">
                        <span class="file-icon">@GetFileIcon(file.Name)</span>
                        @file.Name
                        <button class="btn-close btn-close-white float-end" style="font-size: 0.5rem;" 
                                @onclick="@(() => DeleteFile(file.Name))"></button>
                    </div>
                }
            </div>
            <button class="btn btn-sm btn-secondary w-100 mt-2" @onclick="AddNewFile">+ Add File</button>
        </div>

        <!-- Code Editor -->
        <div class="col-md-6 p-0" style="background: #1e1e1e;">
            <div id="editorContainer" style="width: 100%; height: 100%;"></div>
        </div>

        <!-- Live Preview / Console / Collaboration -->
        <div class="col-md-4 p-0" style="background: white; border-left: 1px solid #444;">
            <div class="preview-header bg-light p-2 border-bottom d-flex justify-content-between">
                <div>
                    <button class="btn btn-sm @(selectedTab == "preview" ? "btn-primary" : "btn-outline-secondary") me-1" @onclick="@(() => selectedTab = "preview")">Preview</button>
                    <button class="btn btn-sm @(selectedTab == "console" ? "btn-primary" : "btn-outline-secondary") me-1" @onclick="@(() => selectedTab = "console")">Console</button>
                    <button class="btn btn-sm @(selectedTab == "collaboration" ? "btn-primary" : "btn-outline-secondary")" @onclick="@(() => selectedTab = "collaboration")">💬 Comments</button>
                </div>
                @if (selectedTab == "preview")
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshPreview">Refresh</button>
                }
                else if (selectedTab == "console")
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearConsole">Clear</button>
                }
                else if (selectedTab == "collaboration")
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddComment">Add Comment</button>
                }
            </div>
            
            @if (selectedTab == "preview")
            {
                <iframe id="previewFrame" style="width: 100%; height: calc(100% - 40px); border: none;"></iframe>
            }
            else if (selectedTab == "collaboration")
            {
                <div class="comments-panel bg-light p-3" style="height: calc(100% - 40px); overflow-y: auto;">
                    @foreach (var comment in projectComments)
                    {
                        <div class="card mb-2">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <strong>@comment.Author</strong>
                                    <small class="text-muted">@comment.Timestamp.ToString("g")</small>
                                </div>
                                <p class="mt-2">@comment.Text</p>
                                @if (!string.IsNullOrEmpty(comment.FileName))
                                {
                                    <small class="text-muted">File: @comment.FileName</small>
                                }
                                <div class="mt-2">
                                    <button class="btn btn-sm btn-link" @onclick="@(() => ReplyToComment(comment))">Reply</button>
                                    @if (comment.Replies.Any())
                                    {
                                        <button class="btn btn-sm btn-link" @onclick="@(() => ToggleReplies(comment))">Show @comment.Replies.Count replies</button>
                                    }
                                </div>
                                @if (comment.ShowReplies)
                                {
                                    <div class="ms-3 mt-2">
                                        @foreach (var reply in comment.Replies)
                                        {
                                            <div class="border-start ps-2 mb-2">
                                                <div><strong>@reply.Author</strong> <small class="text-muted">@reply.Timestamp.ToString("g")</small></div>
                                                <div>@reply.Text</div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    @if (!projectComments.Any())
                    {
                        <p class="text-muted text-center">No comments yet. Add a comment to discuss your project!</p>
                    }
                </div>
            }
            else
            {
                <div class="backend-console bg-dark text-success p-3" style="height: calc(100% - 40px); overflow-y: auto; font-family: monospace;">
                    @foreach (var line in consoleOutput)
                    {
                        <div>@line</div>
                    }
                    @if (backendProcess != null && !backendProcess.HasExited)
                    {
                        <div class="text-warning mt-2">▶ Backend running (PID: @backendProcess.Id, Port: @currentBackendPort)</div>
                        <div class="text-info mt-1">⏱️ Will auto-terminate after @sandboxTimeoutMinutes minutes</div>
                    }
                    @if (longTermAppProcess != null && !longTermAppProcess.HasExited)
                    {
                        <div class="text-warning mt-2">▶ Long‑Term App running (PID: @longTermAppProcess.Id, Port: @longTermAppPort)</div>
                        <div class="text-info mt-1">⏱️ Will auto-terminate after 20 minutes</div>
                    }
                    @if (localDevProcess != null && !localDevProcess.HasExited)
                    {
                        <div class="text-warning mt-2">▶ Local Dev Mode running (PID: @localDevProcess.Id)</div>
                        <div class="text-info mt-1">⏱️ Uses custom sandbox settings</div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Status Bar -->
    <div class="status-bar bg-dark text-white p-1 px-3 small" style="border-top: 1px solid #444; position: fixed; bottom: 0; width: 100%; z-index: 1000;">
        <span>@statusMessage</span>
        <span class="float-end">Line: @cursorLine, Column: @cursorColumn | <span id="collaboratorCount">@activeCollaborators.Count active collaborators</span></span>
    </div>
</div>

<!-- Modal for Collaboration -->
<div class="modal fade" id="collaborationModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white">
            <div class="modal-header">
                <h5 class="modal-title">@modalTitle</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @if (modalType == "invite")
                {
                    <div class="mb-3">
                        <label class="form-label">Email or Username</label>
                        <input @bind="inviteEmail" class="form-control bg-dark text-white" placeholder="Enter email or username" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Permission Level</label>
                        <select @bind="invitePermission" class="form-select bg-dark text-white">
                            <option value="view">View Only</option>
                            <option value="comment">Can Comment</option>
                            <option value="edit">Can Edit</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                }
                else if (modalType == "comment")
                {
                    <div class="mb-3">
                        <label class="form-label">Comment</label>
                        <textarea @bind="newCommentText" class="form-control bg-dark text-white" rows="4" placeholder="Write your comment..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">File (optional)</label>
                        <select @bind="commentFile" class="form-select bg-dark text-white">
                            <option value="">General Project Comment</option>
                            @foreach (var file in projectFiles)
                            {
                                <option value="@file.Name">@file.Name</option>
                            }
                        </select>
                    </div>
                }
                else if (modalType == "template")
                {
                    <div class="row">
                        @foreach (var template in availableTemplates)
                        {
                            <div class="col-md-6 mb-3">
                                <div class="card bg-secondary">
                                    <div class="card-body">
                                        <h6>@template.Name</h6>
                                        <p class="small">@template.Description</p>
                                        <button class="btn btn-sm btn-primary" @onclick="@(() => ApplyTemplate(template))">Apply</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (modalType == "plugin")
                {
                    <div class="row">
                        @foreach (var plugin in availablePlugins)
                        {
                            <div class="col-md-12 mb-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@plugin.Name</strong>
                                        <p class="small mb-0">@plugin.Description</p>
                                    </div>
                                    <button class="btn btn-sm @(plugin.Installed ? "btn-secondary" : "btn-primary")" 
                                            @onclick="@(() => TogglePlugin(plugin))">
                                        @(plugin.Installed ? "Uninstall" : "Install")
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (modalType == "apimarket")
                {
                    <div class="row">
                        @foreach (var api in availableAPIs)
                        {
                            <div class="col-md-12 mb-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@api.Name</strong>
                                        <p class="small mb-0">@api.Description</p>
                                        <code class="small">@api.Endpoint</code>
                                    </div>
                                    <button class="btn btn-sm @(api.Connected ? "btn-success" : "btn-primary")" 
                                            @onclick="@(() => ConnectAPI(api))">
                                        @(api.Connected ? "Connected" : "Connect")
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="ExecuteModalAction">@modalActionText</button>
            </div>
        </div>
    </div>
</div>

<style>
    .file-item {
        padding: 4px 8px;
        margin: 2px 0;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    
    .file-item:hover {
        background: #3a3a3a;
    }
    
    .file-item.active {
        background: #0d6efd;
    }
    
    .file-icon {
        margin-right: 6px;
    }
    
    .btn-close-white {
        opacity: 0.5;
        font-size: 0.5rem;
    }
    
    .btn-close-white:hover {
        opacity: 1;
    }
    
    .backend-console {
        font-size: 0.9rem;
        white-space: pre-wrap;
    }
    
    .backend-console div {
        margin: 2px 0;
    }

    .dropdown-menu-dark .dropdown-item-text input,
    .dropdown-menu-dark .dropdown-item-text select {
        background-color: #333;
        border-color: #555;
        color: #fff;
    }
    
    .toolbar {
        gap: 8px;
        flex-wrap: wrap;
        min-height: 50px;
    }

    .toolbar .btn-sm {
        white-space: nowrap;
    }

    /* Fix dropdown being cut off */
    .row.g-0 {
        overflow: visible !important;
    }

    .col-md-6 {
        overflow: visible !important;
        position: relative;
        z-index: 1;
    }

    .toolbar {
        position: relative;
        z-index: 1000;
        overflow: visible !important;
    }

    .dropdown-menu {
        position: absolute !important;
        z-index: 1050 !important;
    }

    .dropdown {
        position: relative !important;
    }
    
    .comments-panel {
        font-size: 0.9rem;
    }
    
    .badge {
        cursor: pointer;
    }
</style>

<script>
    // Helper to get client IP (simple fallback)
    window.getClientIP = function() {
        return new Promise((resolve) => {
            fetch('https://api.ipify.org?format=json')
                .then(response => response.json())
                .then(data => resolve(data.ip))
                .catch(() => resolve('127.0.0.1'));
        });
    };
    
    window.startCollaboration = function(projectId, userId) {
        console.log('Collaboration started for project:', projectId);
    };
    
    window.openDebugger = function() {
        debugger;
    };
    
    window.showModal = function(modalId) {
        var modal = new bootstrap.Modal(document.getElementById(modalId));
        modal.show();
    };
    
    window.hideModal = function(modalId) {
        var modal = bootstrap.Modal.getInstance(document.getElementById(modalId));
        if (modal) modal.hide();
    };
</script>

@code {
    [Parameter] public string? ProjectName { get; set; }

    private string projectName = "";
    private List<ProjectFile> projectFiles = new();
    private string selectedFile = "";
    private string fileContent = "";
    private string statusMessage = "Ready";
    private int cursorLine = 1;
    private int cursorColumn = 1;
    private DotNetObjectReference<object>? dotNetRef;
    private string? clientIp;
    
    // Backend properties
    private string selectedTab = "preview";
    private string selectedFramework = "node";
    private bool isBackendRunning = false;
    private List<string> consoleOutput = new List<string> { "Console ready. Select a framework and click 'Start Backend' to run your server." };
    private Process? backendProcess = null;
    private IntPtr? currentJob = null;
    private string? currentTempDir = null;
    private CancellationTokenSource? terminationCts = null;
    private int currentBackendPort = 0;
    private static bool hasAdminPermission = false;
    private static bool adminPermissionRequested = false;
    
    // Long‑Term App properties
    private bool isLongTermAppRunning = false;
    private Process? longTermAppProcess = null;
    private IntPtr? longTermAppJob = null;
    private string? longTermAppTempDir = null;
    private CancellationTokenSource? longTermAppTerminationCts = null;
    private int longTermAppPort = 0;
    private const int LONG_TERM_APP_TIMEOUT_SECONDS = 1200;
    
    // Local Dev Mode
    private bool isLocalDevRunning = false;
    private Process? localDevProcess = null;
    private IntPtr? localDevJob = null;
    private string? localDevTempDir = null;
    private CancellationTokenSource? localDevTerminationCts = null;
    
    // Advanced Settings
    private int sandboxMemoryMB = 256;
    private string sandboxCpuPriority = "BelowNormal";
    private int sandboxTimeoutMinutes = 5;
    private bool disableNetwork = false;
    private bool enableReverseProxy = true;
    
    // Collaboration
    private bool isCollaboratorMode = false;
    private List<Collaborator> activeCollaborators = new();
    private List<ProjectComment> projectComments = new();
    private string modalType = "";
    private string modalTitle = "";
    private string modalActionText = "";
    private string inviteEmail = "";
    private string invitePermission = "view";
    private string newCommentText = "";
    private string commentFile = "";
    private string dataPath = "";
    
    // Ecosystem
    private List<Template> availableTemplates = new();
    private List<Plugin> availablePlugins = new();
    private List<APIEndpoint> availableAPIs = new();
    
    // Dev Tools
    private List<ErrorLog> errorLogs = new();
    private AnalyticsData analyticsData = new();
    private string analyticsPath = "";
    
    // Email configuration
    private SmtpClient? smtpClient;
    private string smtpServer = "";
    private int smtpPort = 465;
    private string smtpUsername = "";
    private string smtpPassword = "";
    private string smtpFrom = "";
    private bool smtpEnableSsl = true;
    
    // ========== SANDBOXING & BACKUP PROPERTIES ==========
    private readonly string backupPath = @"D:\PackArcade\BackUps";
    private readonly string appRunnersPath = @"D:\PackArcade\AppRunners";
    private readonly string functionsPath = @"D:\PackArcade\Functions";
    private readonly int maxCpuPercent = 25;
    private readonly int maxFunctionTimeSeconds = 30;

    // ========== WINDOWS JOB OBJECT API ==========
    [DllImport("kernel32.dll", SetLastError = true)]
    private static extern IntPtr CreateJobObject(IntPtr lpJobAttributes, string? lpName);

    [DllImport("kernel32.dll", SetLastError = true)]
    private static extern bool SetInformationJobObject(IntPtr hJob, int JobObjectInfoClass, 
        ref JOBOBJECT_EXTENDED_LIMIT_INFORMATION lpJobObjectInfo, uint cbJobObjectInfoLength);

    [DllImport("kernel32.dll", SetLastError = true)]
    private static extern bool AssignProcessToJobObject(IntPtr hJob, IntPtr hProcess);

    [DllImport("kernel32.dll", SetLastError = true)]
    private static extern bool TerminateJobObject(IntPtr hJob, uint uExitCode);

    [DllImport("kernel32.dll", SetLastError = true)]
    private static extern bool GenerateConsoleCtrlEvent(uint dwCtrlEvent, uint dwProcessGroupId);

    [StructLayout(LayoutKind.Sequential)]
    private struct JOBOBJECT_BASIC_LIMIT_INFORMATION
    {
        public long PerProcessUserTimeLimit;
        public long PerJobUserTimeLimit;
        public uint LimitFlags;
        public UIntPtr MinimumWorkingSetSize;
        public UIntPtr MaximumWorkingSetSize;
        public uint ActiveProcessLimit;
        public UIntPtr Affinity;
        public uint PriorityClass;
        public uint SchedulingClass;
    }

    [StructLayout(LayoutKind.Sequential)]
