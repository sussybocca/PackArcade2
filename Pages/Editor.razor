            }
            else
            {
                consoleOutput.Add($"> Reverse proxy disabled - long-term app not publicly accessible");
            }
            
            consoleOutput.Add($"> Long-Term AppRunner started successfully");
            consoleOutput.Add($"> Auto-termination in 20 minutes.");
            
            await ScheduleAutoTermination(longTermAppProcess.Id, longTermAppPort, longTermAppProcess, longTermAppJob.Value, LONG_TERM_APP_TIMEOUT_SECONDS, "longterm");
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"> Error starting Long-Term AppRunner: {ex.Message}");
            isLongTermAppRunning = false;
        }
