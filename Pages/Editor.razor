    protected override async Task OnInitializedAsync()
    {
        // Initialize paths
        dataPath = Path.Combine(Environment.WebRootPath, "data");
        analyticsPath = Path.Combine(dataPath, "analytics");
        
        Directory.CreateDirectory(dataPath);
        Directory.CreateDirectory(Path.Combine(dataPath, "comments"));
        Directory.CreateDirectory(Path.Combine(dataPath, "plugins"));
        Directory.CreateDirectory(Path.Combine(dataPath, "templates"));
        Directory.CreateDirectory(Path.Combine(dataPath, "apis"));
        Directory.CreateDirectory(analyticsPath);
        Directory.CreateDirectory(Path.Combine(dataPath, "errors"));
        
        // Load email configuration
        LoadEmailConfig();
        
        if (!string.IsNullOrEmpty(ProjectName))
        {
            projectName = ProjectName;
            await LoadProject();
        }
        else
        {
            projectName = "MyProject";
            CreateDefaultFiles();
        }
        
        Directory.CreateDirectory(backupPath);
        Directory.CreateDirectory(appRunnersPath);
        Directory.CreateDirectory(functionsPath);
        
        try
        {
            clientIp = await JSRuntime.InvokeAsync<string>("getClientIP");
            if (string.IsNullOrEmpty(clientIp)) clientIp = "unknown";
        }
        catch { clientIp = "unknown"; }
        
        if (!hasAdminPermission && !adminPermissionRequested)
        {
            await RequestAdminPermission();
        }
        
        await LoadCollaborationData();
        await LoadTemplates();
        await LoadPlugins();
        await LoadAPIs();
        await LoadAnalytics();
        await LoadErrorLogs();
        
        if (isCollaboratorMode)
        {
            await StartCollaboration();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this as object);
            await JSRuntime.InvokeVoidAsync("initializeEditor", dotNetRef);
            
            await Task.Delay(500);
            if (!string.IsNullOrEmpty(fileContent))
            {
                await JSRuntime.InvokeVoidAsync("setEditorContent", fileContent);
            }
        }
    }
    
    private void LoadEmailConfig()
    {
        try
        {
            smtpServer = Configuration["Email:SmtpServer"] ?? "smtp.gmail.com";
            smtpPort = int.Parse(Configuration["Email:Port"] ?? "465");
            smtpUsername = Configuration["Email:Username"] ?? "";
            smtpPassword = Configuration["Email:Password"] ?? "";
            smtpFrom = Configuration["Email:From"] ?? "support@packarcade.win";
            smtpEnableSsl = bool.Parse(Configuration["Email:EnableSsl"] ?? "true");
            
            smtpClient = new SmtpClient(smtpServer, smtpPort)
            {
                EnableSsl = smtpEnableSsl,
                Credentials = new NetworkCredential(smtpUsername, smtpPassword),
                DeliveryMethod = SmtpDeliveryMethod.Network,
                UseDefaultCredentials = false
            };
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"Error loading email config: {ex.Message}");
        }
    }
    
    private async Task SendEmailAsync(string to, string subject, string body)
    {
        if (smtpClient == null)
        {
            consoleOutput.Add("Email not configured. Invitation not sent.");
            return;
        }
        
        try
        {
            var mailMessage = new MailMessage
            {
                From = new MailAddress(smtpFrom),
                Subject = subject,
                Body = body,
                IsBodyHtml = true
            };
            mailMessage.To.Add(to);
            
            await smtpClient.SendMailAsync(mailMessage);
            consoleOutput.Add($"Email sent to {to}");
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"Error sending email: {ex.Message}");
            throw;
        }
    }

