            // Create GitHub Actions workflow if .github directory exists
            var githubDir = Path.Combine(projectPath, ".github", "workflows");
            Directory.CreateDirectory(githubDir);
            
            var workflowFile = Path.Combine(githubDir, "ci.yml");
            var workflowContent = @"name: CI/CD Pipeline

on:
  push:
    branches: [ main, master ]
  pull_request:
    branches: [ main, master ]

jobs:
  build:
    runs-on: ubuntu-latest
    
    steps:
    - uses: actions/checkout@v3
    
    - name: Setup Node.js
      uses: actions/setup-node@v3
      with:
        node-version: '18'
    
    - name: Install dependencies
      run: npm ci || pip install -r requirements.txt || echo 'No package manager detected'
    
    - name: Run tests
      run: npm test || python -m pytest || echo 'No tests configured'
    
    - name: Build
      run: npm run build || echo 'No build script configured'
    
    - name: Deploy
      if: github.ref == 'refs/heads/main'
      run: echo 'Deploying...'";
            
            await File.WriteAllTextAsync(workflowFile, workflowContent);
            
            // Create local build script
            var ciScript = Path.Combine(projectPath, "ci-build.bat");
            var ciContent = @"@echo off
echo ========================================
echo CI/CD Pipeline - Build Script
echo ========================================
