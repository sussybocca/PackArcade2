    public void Dispose()
    {
        dotNetRef?.Dispose();
        
        terminationCts?.Cancel();
        terminationCts?.Dispose();
        longTermAppTerminationCts?.Cancel();
        longTermAppTerminationCts?.Dispose();
        localDevTerminationCts?.Cancel();
        localDevTerminationCts?.Dispose();
        
        if (backendProcess != null && !backendProcess.HasExited)
        {
            try
            {
                if (currentJob.HasValue && currentJob.Value != IntPtr.Zero)
                    TerminateJobObject(currentJob.Value, 1);
                backendProcess.Kill();
                backendProcess.Dispose();
            }
            catch { }
        }
        
        if (longTermAppProcess != null && !longTermAppProcess.HasExited)
        {
            try
            {
                if (longTermAppJob.HasValue && longTermAppJob.Value != IntPtr.Zero)
                    TerminateJobObject(longTermAppJob.Value, 1);
                longTermAppProcess.Kill();
                longTermAppProcess.Dispose();
            }
            catch { }
        }
        
        if (localDevProcess != null && !localDevProcess.HasExited)
        {
            try
            {
                if (localDevJob.HasValue && localDevJob.Value != IntPtr.Zero)
                    TerminateJobObject(localDevJob.Value, 1);
                localDevProcess.Kill();
                localDevProcess.Dispose();
            }
            catch { }
        }
        
        if (!string.IsNullOrEmpty(currentTempDir) && Directory.Exists(currentTempDir))
            try { Directory.Delete(currentTempDir, true); } catch { }
        
        if (!string.IsNullOrEmpty(longTermAppTempDir) && Directory.Exists(longTermAppTempDir))
            try { Directory.Delete(longTermAppTempDir, true); } catch { }
        
        if (!string.IsNullOrEmpty(localDevTempDir) && Directory.Exists(localDevTempDir))
            try { Directory.Delete(localDevTempDir, true); } catch { }
    }

    private class ProjectFile
    {
        public string Name { get; set; } = "";
