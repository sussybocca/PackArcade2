    private async Task DeleteFile(string fileName)
    {
        if (projectFiles.Count <= 1)
        {
            statusMessage = "Cannot delete the last file";
            return;
        }

        var confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Delete {fileName}?");
        if (confirm)
        {
            var file = projectFiles.FirstOrDefault(f => f.Name == fileName);
            if (file?.Type == "apprunner")
            {
                string appRunnerFolder = Path.Combine(appRunnersPath, fileName);
                try
                {
                    Directory.Delete(appRunnerFolder, true);
                    consoleOutput.Add($"> Deleted AppRunner folder: {fileName}");
                }
                catch { }
            }

            projectFiles.RemoveAll(f => f.Name == fileName);
            
            if (selectedFile == fileName)
            {
                selectedFile = projectFiles.First().Name;
                fileContent = projectFiles.First().Content;
                await JSRuntime.InvokeVoidAsync("setEditorContent", fileContent);
            }
            
            StateHasChanged();
            statusMessage = $"Deleted {fileName}";
        }
    }

    private async Task SaveProject()
    {
        statusMessage = "Saving...";
        
        try
        {
            fileContent = await JSRuntime.InvokeAsync<string>("getEditorContent");
            
            var currentFile = projectFiles.FirstOrDefault(f => f.Name == selectedFile);
            if (currentFile != null)
            {
                currentFile.Content = fileContent;
                
                if (currentFile.Type == "apprunner")
                {
                    string appRunnerFolder = Path.Combine(appRunnersPath, currentFile.Name);
                    Directory.CreateDirectory(appRunnerFolder);
                    string tsFilePath = Path.Combine(appRunnerFolder, $"{currentFile.Name}.ts");
                    await File.WriteAllTextAsync(tsFilePath, fileContent);
                }
            }

            var subdomain = GetSubdomain();
            
            foreach (var file in projectFiles)
            {
                await ProjectService.SaveProjectFile(subdomain, file.Name, file.Content);
            }

            var projectInfo = new ProjectInfo
            {
                Name = projectName,
                Subdomain = subdomain,
                LastSaved = DateTime.Now
            };

            await ProjectService.SaveProject(subdomain, projectInfo, new List<ProjectComponent>());
            
            await CreateBackup(subdomain);
            
            analyticsData.Edits++;
            analyticsData.RecentActivity.Insert(0, new Activity { Timestamp = DateTime.Now, Description = $"Edited {selectedFile}" });
            if (analyticsData.RecentActivity.Count > 50) analyticsData.RecentActivity = analyticsData.RecentActivity.Take(50).ToList();
            
            // Update top files
            var fileStats = analyticsData.TopFiles.FirstOrDefault(f => f.Name == selectedFile);
            if (fileStats != null)
            {
                fileStats.Edits++;
            }
            else
            {
                analyticsData.TopFiles.Add(new FileStats { Name = selectedFile, Edits = 1 });
                analyticsData.TopFiles = analyticsData.TopFiles.OrderByDescending(f => f.Edits).Take(10).ToList();
            }
            
            await SaveAnalytics();
            
            statusMessage = "Project saved successfully!";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error saving: {ex.Message}";
            await SaveErrorLog(new ErrorLog { Level = "Error", Message = ex.Message, StackTrace = ex.StackTrace, Timestamp = DateTime.Now });
        }
    }

