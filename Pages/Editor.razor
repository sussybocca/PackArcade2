    private async Task StartLongTermAppRunner(string projectDir)
    {
        try
        {
            consoleOutput.Add($"> Starting Long-Term AppRunner...");
            isLongTermAppRunning = true;
            longTermAppPort = 3008;
            
            var appRunners = projectFiles.Where(f => f.Type == "apprunner").ToList();
            if (!appRunners.Any())
            {
                consoleOutput.Add($"> No AppRunner files found. Create an extensionless file to run a long-term app.");
                isLongTermAppRunning = false;
                return;
            }
            
            foreach (var app in appRunners)
            {
                string appFolder = Path.Combine(appRunnersPath, app.Name);
                Directory.CreateDirectory(appFolder);
                
                var startInfo = new ProcessStartInfo
                {
                    FileName = "node",
                    Arguments = $"{app.Name}.ts",
                    WorkingDirectory = appFolder,
                    UseShellExecute = false,
                    RedirectStandardOutput = true,
                    RedirectStandardError = true,
                    CreateNoWindow = true
                };
                
                longTermAppProcess = await StartSandboxedProcess(startInfo, isFunction: false, customTimeoutSeconds: LONG_TERM_APP_TIMEOUT_SECONDS);
                
                longTermAppProcess.OutputDataReceived += (s, e) =>
                {
                    if (!string.IsNullOrEmpty(e.Data))
                    {
                        InvokeAsync(() =>
                        {
                            consoleOutput.Add($"[LONG-TERM AppRunner] {e.Data}");
                            StateHasChanged();
                        });
                    }
                };
                
                longTermAppProcess.ErrorDataReceived += (s, e) =>
                {
                    if (!string.IsNullOrEmpty(e.Data))
                    {
                        InvokeAsync(() =>
                        {
                            consoleOutput.Add($"[LONG-TERM AppRunner ERROR] {e.Data}");
                            StateHasChanged();
                        });
                    }
                };
                
                longTermAppProcess.BeginOutputReadLine();
                longTermAppProcess.BeginErrorReadLine();
                
                consoleOutput.Add($"> Long-Term AppRunner '{app.Name}' started (PID: {longTermAppProcess.Id}) with Windows Job Object sandboxing");
            }
            
            if (enableReverseProxy)
            {
                try
                {
                    BackendTracker.RegisterBackend(GetSubdomain(), longTermAppPort, "apprunner-longterm");
                    consoleOutput.Add($"> Registered with reverse proxy on port {longTermAppPort}");
                }
                catch (Exception ex)
                {
                    consoleOutput.Add($"> Warning: Failed to register with reverse proxy: {ex.Message}");
