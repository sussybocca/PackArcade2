    private async Task ForkProject()
    {
        try
        {
            var subdomain = GetSubdomain();
            var newSubdomain = $"{subdomain}-fork-{DateTime.Now.Ticks}";
            var newProjectPath = Path.Combine(Environment.WebRootPath, "projects", newSubdomain);
            var oldProjectPath = Path.Combine(Environment.WebRootPath, "projects", subdomain);
            
            if (Directory.Exists(oldProjectPath))
            {
                await CopyDirectoryAsync(oldProjectPath, newProjectPath);
                
                // Copy collaboration data
                var oldCommentFile = Path.Combine(dataPath, "comments", $"{subdomain}.json");
                var newCommentFile = Path.Combine(dataPath, "comments", $"{newSubdomain}.json");
                if (File.Exists(oldCommentFile))
                {
                    File.Copy(oldCommentFile, newCommentFile);
                }
                
                analyticsData.Forks++;
                await SaveAnalytics();
                
                statusMessage = $"Project forked successfully! New URL: {newSubdomain}.packarcade.win";
                Navigation.NavigateTo($"/editor/{newSubdomain}");
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error forking project: {ex.Message}";
        }
    }
    
