            else
            {
                foreach (var log in errorLogs.Take(50))
                {
                    consoleOutput.Add($"[{log.Timestamp:yyyy-MM-dd HH:mm:ss}] {log.Level}: {log.Message}");
                    if (!string.IsNullOrEmpty(log.StackTrace))
                    {
                        var lines = log.StackTrace.Split('\n');
