    private async Task RunTests()
    {
        try
        {
            statusMessage = "Running tests...";
            consoleOutput.Add("🧪 Running tests...");
            
            var subdomain = GetSubdomain();
            var projectPath = Path.Combine(Environment.WebRootPath, "projects", subdomain);
            
            var testResults = new TestResults { Passed = 0, Failed = 0, Duration = 0 };
            var startTime = DateTime.Now;
            
            // Detect and run appropriate tests
            if (selectedFramework == "node" && File.Exists(Path.Combine(projectPath, "package.json")))
            {
                consoleOutput.Add("Detected Node.js project. Running npm test...");
                
                var testProcess = new Process
                {
                    StartInfo = new ProcessStartInfo
                    {
                        FileName = "npm.cmd",
                        Arguments = "test -- --watchAll=false",
                        WorkingDirectory = projectPath,
                        UseShellExecute = false,
                        RedirectStandardOutput = true,
                        RedirectStandardError = true,
                        CreateNoWindow = true
                    }
                };
                
                var output = new StringBuilder();
                testProcess.OutputDataReceived += (s, e) => { if (e.Data != null) output.AppendLine(e.Data); };
                testProcess.ErrorDataReceived += (s, e) => { if (e.Data != null) output.AppendLine(e.Data); };
                
                testProcess.Start();
                testProcess.BeginOutputReadLine();
                testProcess.BeginErrorReadLine();
                await testProcess.WaitForExitAsync();
                
                testResults.Passed = testProcess.ExitCode == 0 ? 1 : 0;
                testResults.Failed = testProcess.ExitCode != 0 ? 1 : 0;
                testResults.Output = output.ToString();
                
                consoleOutput.Add(testResults.Output);
            }
            else if (selectedFramework == "python" && File.Exists(Path.Combine(projectPath, "test.py")))
            {
                consoleOutput.Add("Detected Python project. Running pytest...");
                
                var testProcess = new Process
                {
                    StartInfo = new ProcessStartInfo
                    {
                        FileName = "python",
                        Arguments = "-m pytest test.py -v",
                        WorkingDirectory = projectPath,
                        UseShellExecute = false,
                        RedirectStandardOutput = true,
                        RedirectStandardError = true,
                        CreateNoWindow = true
                    }
                };
                
                var output = new StringBuilder();
                testProcess.OutputDataReceived += (s, e) => { if (e.Data != null) output.AppendLine(e.Data); };
                testProcess.ErrorDataReceived += (s, e) => { if (e.Data != null) output.AppendLine(e.Data); };
                
                testProcess.Start();
                testProcess.BeginOutputReadLine();
                testProcess.BeginErrorReadLine();
                await testProcess.WaitForExitAsync();
                
                testResults.Passed = testProcess.ExitCode == 0 ? 1 : 0;
                testResults.Failed = testProcess.ExitCode != 0 ? 1 : 0;
                testResults.Output = output.ToString();
                
                consoleOutput.Add(testResults.Output);
            }
            else
            {
                // Basic validation tests
                consoleOutput.Add("Running basic validation tests...");
                testResults.Passed = 1;
                testResults.Failed = 0;
                consoleOutput.Add("✅ Basic validation passed");
                consoleOutput.Add("ℹ️ No test framework detected. Create test files to run more tests.");
            }
            
            testResults.Duration = (int)(DateTime.Now - startTime).TotalMilliseconds;
            
            consoleOutput.Add("");
            consoleOutput.Add("=" + new string('=', 50));
            consoleOutput.Add($"✅ {testResults.Passed} tests passed");
            consoleOutput.Add($"❌ {testResults.Failed} tests failed");
            consoleOutput.Add($"⏱️ Duration: {testResults.Duration}ms");
            consoleOutput.Add("=" + new string('=', 50));
            
            statusMessage = $"Tests completed: {testResults.Passed} passed, {testResults.Failed} failed";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error running tests: {ex.Message}";
            consoleOutput.Add($"Error: {ex.Message}");
            await SaveErrorLog(new ErrorLog { Level = "Error", Message = ex.Message, StackTrace = ex.StackTrace, Timestamp = DateTime.Now });
        }
    }
    
