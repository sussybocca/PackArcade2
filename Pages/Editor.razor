    // ========== IP PERMISSION ==========
    private async Task RequestIPPermission()
    {
        try
        {
            var clientIP = await JSRuntime.InvokeAsync<string>("getClientIP");
            if (string.IsNullOrEmpty(clientIP))
            {
                consoleOutput.Add("Could not determine your IP address.");
                return;
            }
            
            consoleOutput.Add($"Your IP address: {clientIP}");
            bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Allow reverse proxy to use your IP ({clientIP}) for local testing? This will enable live server setup.");
            if (confirmed)
            {
                var ipFile = Path.Combine(dataPath, "ip_permissions", $"{GetSubdomain()}.txt");
                Directory.CreateDirectory(Path.GetDirectoryName(ipFile)!);
                await File.WriteAllTextAsync(ipFile, clientIP);
                consoleOutput.Add($"IP permission granted. Reverse proxy will use your IP for routing.");
            }
            else
            {
                consoleOutput.Add("IP permission denied. Reverse proxy will use default routing.");
            }
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"Error requesting IP permission: {ex.Message}");
        }
    }
    
