    private async Task RequestAdminPermission()
    {
        try
        {
            adminPermissionRequested = true;
            
            var psi = new ProcessStartInfo
            {
                FileName = "net",
                Arguments = "session",
                UseShellExecute = false,
                CreateNoWindow = true,
                RedirectStandardOutput = true,
                RedirectStandardError = true
            };
            
            var process = Process.Start(psi);
            await process.WaitForExitAsync();
            
            if (process.ExitCode == 0)
            {
                hasAdminPermission = true;
                consoleOutput.Add("✅ Already running with administrator privileges");
                return;
            }
            
            consoleOutput.Add("⚠️ Requesting administrator privileges for process termination...");
            
            var elevatePsi = new ProcessStartInfo
            {
                FileName = "powershell.exe",
                Arguments = "Start-Process cmd.exe -Verb RunAs",
                UseShellExecute = true,
                CreateNoWindow = true
            };
            
            Process.Start(elevatePsi);
            consoleOutput.Add("📢 Please accept the UAC prompt to enable admin commands");
            consoleOutput.Add("ℹ️ Admin permission only needed once. Subsequent terminations will work automatically.");
            
            await Task.Delay(3000);
            
            var testPsi = new ProcessStartInfo
            {
                FileName = "net",
                Arguments = "session",
                UseShellExecute = false,
                CreateNoWindow = true,
                RedirectStandardOutput = true,
                RedirectStandardError = true
            };
            
            var testProcess = Process.Start(testPsi);
            await testProcess.WaitForExitAsync();
            
            if (testProcess.ExitCode == 0)
            {
                hasAdminPermission = true;
                consoleOutput.Add("✅ Administrator privileges granted! Backend termination will work properly.");
            }
            else
            {
                consoleOutput.Add("⚠️ Administrator privileges not granted. Some termination methods may fail.");
            }
        }
        catch (Exception ex)
        {
            consoleOutput.Add($"⚠️ Could not request admin permission: {ex.Message}");
        }
    }

    private async Task LoadProject()
    {
        try
        {
            var subdomain = GetSubdomain();
            var files = await ProjectService.GetProjectFiles(subdomain);
            
            if (files != null && files.Any())
            {
                projectFiles = files.Select(f => new ProjectFile
                {
                    Name = f.Name,
                    Type = f.Type,
                    Content = f.Content
                }).ToList();
                
                selectedFile = projectFiles.First().Name;
                fileContent = projectFiles.First().Content;
            }
            else
            {
                CreateDefaultFiles();
            }
            
            statusMessage = "Project loaded successfully";
            await SaveAnalytics();
        }
        catch (Exception ex)
        {
            statusMessage = $"Error loading project: {ex.Message}";
            CreateDefaultFiles();
        }
    }

