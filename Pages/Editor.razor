    // ========== LOCAL DEV MODE ==========
    private async Task StartLocalDevMode()
    {
        if (selectedFramework == "static")
        {
            consoleOutput.Add("> Static site has no backend to start in Local Dev Mode.");
            return;
        }

        await SaveProject();
        
        var subdomain = GetSubdomain();
        var projectDir = Path.Combine(Environment.WebRootPath, "projects", subdomain);
        
        consoleOutput.Clear();
        consoleOutput.Add($"> Starting Local Dev Mode for {subdomain}...");
        consoleOutput.Add($"> Project directory: {projectDir}");
        consoleOutput.Add($"> Using custom sandbox settings: Memory={sandboxMemoryMB}MB, Priority={sandboxCpuPriority}, Timeout={sandboxTimeoutMinutes}min");
        
        if (localDevProcess != null && !localDevProcess.HasExited)
        {
            consoleOutput.Add($"> Stopping existing Local Dev Mode...");
            await TerminateProcessWithMultipleFallbacks(localDevProcess.Id, 0, localDevProcess, localDevJob);
            await Task.Delay(500);
        }
        
        if (!string.IsNullOrEmpty(localDevTempDir) && Directory.Exists(localDevTempDir))
        {
            try 
            { 
                await Task.Delay(500);
                Directory.Delete(localDevTempDir, true); 
            } 
            catch { }
            localDevTempDir = null;
        }
        
        string devTempDir = Path.Combine(Path.GetTempPath(), "PackArcade2_LocalDev", Guid.NewGuid().ToString());
        Directory.CreateDirectory(devTempDir);
        localDevTempDir = devTempDir;
        
        string mainFile = "";
        List<string> filesToCopy = new List<string>();
        
        switch (selectedFramework)
        {
            case "node":
                mainFile = "server.js";
                if (File.Exists(Path.Combine(projectDir, "app.js"))) mainFile = "app.js";
                if (File.Exists(Path.Combine(projectDir, "index.js"))) mainFile = "index.js";
                filesToCopy.Add(mainFile);
                if (File.Exists(Path.Combine(projectDir, "package.json")))
                    filesToCopy.Add("package.json");
                break;
            case "python":
                mainFile = "server.py";
                filesToCopy.Add(mainFile);
                break;
            case "csharp":
                mainFile = "Program.cs";
                filesToCopy.Add("Program.cs");
                if (File.Exists(Path.Combine(projectDir, "api.csproj")))
                    filesToCopy.Add("api.csproj");
                break;
            case "php":
                mainFile = "index.php";
                filesToCopy.Add(mainFile);
                break;
            default:
                consoleOutput.Add("> Framework not supported for Local Dev Mode.");
                return;
        }
        
        foreach (var file in filesToCopy)
        {
            var sourcePath = Path.Combine(projectDir, file);
            var destPath = Path.Combine(devTempDir, file);
            
            if (File.Exists(sourcePath))
            {
                string content = await File.ReadAllTextAsync(sourcePath);
                await File.WriteAllTextAsync(destPath, content);
                consoleOutput.Add($"> Copied: {file}");
            }
            else
            {
                consoleOutput.Add($"> Warning: {file} not found, using default");
                if (file == "package.json")
                {
                    var packageJson = new
                    {
                        name = Path.GetFileName(projectDir),
                        version = "1.0.0",
                        scripts = new { start = $"node {mainFile}" },
                        dependencies = new { express = "^4.18.2", cors = "^2.8.5" }
                    };
                    string json = JsonSerializer.Serialize(packageJson, new JsonSerializerOptions { WriteIndented = true });
                    await File.WriteAllTextAsync(Path.Combine(devTempDir, "package.json"), json);
                }
                else if (file == "api.csproj")
                {
                    string csprojContent = @"<Project Sdk=""Microsoft.NET.Sdk.Web"">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
  </PropertyGroup>
</Project>";
                    await File.WriteAllTextAsync(Path.Combine(devTempDir, "api.csproj"), csprojContent);
                }
                else if (file == "Program.cs")
                {
                    string programContent = @"using Microsoft.AspNetCore.Builder;
using Microsoft.AspNetCore.Http;
using Microsoft.Extensions.Hosting;

var builder = WebApplication.CreateBuilder(args);
builder.WebHost.UseUrls(""http://*:5005"");

var app = builder.Build();

app.MapGet(""/"", () => ""Hello World"");
app.MapGet(""/api/hello"", () => Results.Json(new { message = ""Hello from C#!"" }));

app.Run();";
                    await File.WriteAllTextAsync(Path.Combine(devTempDir, "Program.cs"), programContent);
                }
                else if (file == "server.py")
                {
                    string pythonContent = @"from flask import Flask, jsonify
from flask_cors import CORS

app = Flask(__name__)
CORS(app)

@app.route('/api/hello')
def hello():
    return jsonify({'message': 'Hello from Python!'})

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, debug=True)";
                    await File.WriteAllTextAsync(Path.Combine(devTempDir, "server.py"), pythonContent);
                }
                else if (file == "index.php")
                {
                    string phpContent = @"<?php
header('Content-Type: application/json');
echo json_encode(['message' => 'Hello from PHP!']);
?>";
                    await File.WriteAllTextAsync(Path.Combine(devTempDir, "index.php"), phpContent);
                }
            }
        }
        
        if (selectedFramework == "node")
        {
            string packageJsonPath = Path.Combine(devTempDir, "package.json");
            if (File.Exists(packageJsonPath))
            {
                consoleOutput.Add($"> Running npm install in temp directory...");
                
                string npmPath = @"D:\npm\npm.cmd";
                
                if (!File.Exists(npmPath))
                {
                    consoleOutput.Add($"> ERROR: npm not found at {npmPath}. Please check Node.js installation.");
                    return;
                }
                
                consoleOutput.Add($"> Using npm at: {npmPath}");
                
                var npmProcess = new Process
                {
                    StartInfo = new ProcessStartInfo
                    {
                        FileName = npmPath,
                        Arguments = "install",
                        WorkingDirectory = devTempDir,
                        UseShellExecute = false,
                        RedirectStandardOutput = true,
                        RedirectStandardError = true,
                        CreateNoWindow = true
                    }
                };
                
                npmProcess.Start();
                string npmOutput = await npmProcess.StandardOutput.ReadToEndAsync();
                string npmError = await npmProcess.StandardError.ReadToEndAsync();
                await npmProcess.WaitForExitAsync();
                
                if (!string.IsNullOrEmpty(npmOutput)) consoleOutput.Add($"> {npmOutput.Trim()}");
                if (!string.IsNullOrEmpty(npmError)) consoleOutput.Add($"> {npmError.Trim()}");
                
                if (npmProcess.ExitCode != 0)
                {
                    consoleOutput.Add($"> npm install failed with exit code: {npmProcess.ExitCode}");
                    consoleOutput.Add($"> Attempting to install express and cors directly...");
                    
                    var installProcess = new Process
                    {
                        StartInfo = new ProcessStartInfo
                        {
                            FileName = npmPath,
                            Arguments = "install express cors",
                            WorkingDirectory = devTempDir,
                            UseShellExecute = false,
                            RedirectStandardOutput = true,
                            RedirectStandardError = true,
                            CreateNoWindow = true
                        }
                    };
                    
                    installProcess.Start();
                    string installOutput = await installProcess.StandardOutput.ReadToEndAsync();
                    string installError = await installProcess.StandardError.ReadToEndAsync();
                    await installProcess.WaitForExitAsync();
                    
                    if (!string.IsNullOrEmpty(installOutput)) consoleOutput.Add($"> {installOutput.Trim()}");
                    if (!string.IsNullOrEmpty(installError)) consoleOutput.Add($"> {installError.Trim()}");
                    consoleOutput.Add($"> Direct install completed with exit code: {installProcess.ExitCode}");
                }
                else
                {
                    consoleOutput.Add($"> npm install completed successfully!");
                }
            }
        }
        
        var startInfo = new ProcessStartInfo
        {
            WorkingDirectory = devTempDir,
            UseShellExecute = false,
            RedirectStandardOutput = true,
            RedirectStandardError = true,
            CreateNoWindow = true,
            LoadUserProfile = false
        };
        
        switch (selectedFramework)
        {
            case "node":
                startInfo.FileName = "node";
                startInfo.Arguments = mainFile;
                break;
            case "python":
                startInfo.FileName = "python";
                startInfo.Arguments = mainFile;
                break;
            case "csharp":
                startInfo.FileName = "dotnet";
                startInfo.Arguments = "run";
                break;
            case "php":
                startInfo.FileName = "php";
                startInfo.Arguments = "-S localhost:0";
                break;
        }
        
        localDevProcess = new Process { StartInfo = startInfo };
        localDevProcess.Start();
        
        IntPtr job = CreateJobObject(IntPtr.Zero, null);
        localDevJob = job;
        
        int timeout = sandboxTimeoutMinutes * 60;
        
        uint limitFlags = JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE | JOB_OBJECT_LIMIT_PROCESS_TIME | 
                          JOB_OBJECT_LIMIT_JOB_TIME | JOB_OBJECT_LIMIT_PROCESS_MEMORY;
        
        uint priorityClass = BELOW_NORMAL_PRIORITY_CLASS;
        switch (sandboxCpuPriority)
        {
            case "Idle": priorityClass = IDLE_PRIORITY_CLASS; break;
            case "BelowNormal": priorityClass = BELOW_NORMAL_PRIORITY_CLASS; break;
            case "Normal": priorityClass = NORMAL_PRIORITY_CLASS; break;
        }
        
        var limits = new JOBOBJECT_EXTENDED_LIMIT_INFORMATION
        {
            BasicLimitInformation = new JOBOBJECT_BASIC_LIMIT_INFORMATION
            {
                LimitFlags = limitFlags,
                PerProcessUserTimeLimit = timeout * 10000000L,
                PerJobUserTimeLimit = timeout * 10000000L * 2,
                PriorityClass = priorityClass
            },
            ProcessMemoryLimit = new UIntPtr((ulong)sandboxMemoryMB * 1024 * 1024),
            JobMemoryLimit = new UIntPtr((ulong)sandboxMemoryMB * 1024 * 1024 * 2)
        };
        
        SetInformationJobObject(job, 9, ref limits, (uint)Marshal.SizeOf(limits));
        AssignProcessToJobObject(job, localDevProcess.Handle);
        
        localDevProcess.OutputDataReceived += (s, e) =>
        {
            if (!string.IsNullOrEmpty(e.Data))
            {
                InvokeAsync(() =>
                {
                    consoleOutput.Add($"[LOCAL DEV] {e.Data}");
                    StateHasChanged();
                });
            }
        };
        
        localDevProcess.ErrorDataReceived += (s, e) =>
        {
            if (!string.IsNullOrEmpty(e.Data))
            {
                InvokeAsync(() =>
                {
                    consoleOutput.Add($"[LOCAL DEV ERROR] {e.Data}");
                    StateHasChanged();
                });
            }
        };
        
        localDevProcess.BeginOutputReadLine();
        localDevProcess.BeginErrorReadLine();
        
        isLocalDevRunning = true;
        
        consoleOutput.Add($"> Local Dev Mode started (PID: {localDevProcess.Id}) with custom sandbox settings");
        consoleOutput.Add($"> Process running in: {devTempDir}");
        consoleOutput.Add($"> Auto-termination in {sandboxTimeoutMinutes} minutes");
        
        await ScheduleAutoTermination(localDevProcess.Id, 0, localDevProcess, localDevJob.Value, sandboxTimeoutMinutes * 60, "localdev");
    }
    
