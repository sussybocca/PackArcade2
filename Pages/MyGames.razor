@page "/my-games"
@using PackArcade2
@inject GameService GameService
@inject NavigationManager Navigation

<PageTitle>My Games - PackArcade2</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card bg-dark text-white">
                <div class="card-header">
                    <h2 class="mb-0">🎮 My Games</h2>
                </div>
                <div class="card-body">
                    @if (games == null)
                    {
                        <p class="text-center">Loading...</p>
                    }
                    else if (games.Count == 0)
                    {
                        <div class="text-center p-5">
                            <p class="mb-3">You haven't created any games yet.</p>
                            <a href="/upload" class="btn btn-success">Upload Your First Game</a>
                        </div>
                    }
                    else
                    {
                        <div class="row">
                            @foreach (var game in games)
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="card bg-secondary text-white h-100">
                                        <div class="card-body">
                                            <h5 class="card-title">@game.Name</h5>
                                            <p class="card-text">
                                                <small class="text-muted">@(game.Subdomain).packarcade.win</small><br />  @* FIXED *@
                                                <span class="badge bg-@(game.GameType == "exe" ? "danger" : "success")">@game.GameType.ToUpper()</span>
                                                <br />
                                                <small>Uploaded: @game.Uploaded.ToString("MMM dd, yyyy")</small>
                                            </p>
                                            <button class="btn btn-primary w-100" @onclick="() => PlayGame(game.Subdomain)">
                                                Play Game
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<GameInfo> games = new();

    protected override async Task OnInitializedAsync()
    {
        games = await GameService.GetAllGames();
    }

    private void PlayGame(string subdomain)
    {
        Navigation.NavigateTo($"/play/{subdomain}");
    }
}