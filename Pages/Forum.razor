<script>
    window.scrollToBottom = function() {
        const modalBody = document.querySelector('#viewTopicModal .modal-body');
        if (modalBody) modalBody.scrollTop = modalBody.scrollHeight;
    };
</script>

@code {
    private List<ForumTopic> topics = new();
    private List<ForumTopic> filteredTopics = new();
    private string searchQuery = "";
    private string currentCategory = "";
    private bool showCreateModal = false;
    private bool showTopicModal = false;
    private ForumTopic? selectedTopic = null;
    private NewTopic newTopic = new();
    private string newReply = "";
    private bool isCreating = false;
    private bool isReplying = false;
    private string? clientIp;
    private string dataPath = "";
    private bool showEcosystem = true;
    
    // Stats
    private int totalUsers = 0;
    private int totalProjects = 0;
    private int totalGames = 0;
    private int totalServers = 0;
    private int forumTopics = 0;
    private int forumReplies = 0;
    private int activeBackends = 0;
    private double storageUsed = 0;

    protected override async Task OnInitializedAsync()
    {
        dataPath = Path.Combine(Environment.WebRootPath, "data", "forum");
        Directory.CreateDirectory(dataPath);
        
        try
        {
            clientIp = await JSRuntime.InvokeAsync<string>("getClientIP") ?? "anonymous";
        }
        catch { clientIp = "anonymous"; }
        
        await LoadStats();
        await LoadTopics();
        filteredTopics = topics;
    }

    private void ToggleEcosystem()
    {
        showEcosystem = !showEcosystem;
        StateHasChanged();
    }

    private async Task LoadStats()
    {
        try
        {
            var games = await GameService.GetAllGames();
            totalGames = games?.Count ?? 0;
            
            var projectsPath = Path.Combine(Environment.WebRootPath, "projects");
            if (Directory.Exists(projectsPath))
                totalProjects = Directory.GetDirectories(projectsPath).Length;
            
            var backends = BackendTracker.GetAllBackends();
            activeBackends = backends?.Count ?? 0;
            
            var pointsPath = Path.Combine(Environment.WebRootPath, "data", "Points");
            if (Directory.Exists(pointsPath))
                totalUsers = Directory.GetFiles(pointsPath, "user_*.json").Length;
        }
        catch (Exception ex) { Logger.LogError(ex, "Failed to load stats"); }
    }

    private async Task LoadTopics()
    {
        try
        {
            var topicsFile = Path.Combine(dataPath, "topics.json");
            if (File.Exists(topicsFile))
            {
                var json = await File.ReadAllTextAsync(topicsFile);
                topics = JsonSerializer.Deserialize<List<ForumTopic>>(json) ?? new();
            }
            else
            {
                topics = new List<ForumTopic>
                {
                    new ForumTopic
                    {
                        Id = Guid.NewGuid().ToString(),
                        Title = "Welcome to PackArcade2 Community!",
                        Content = "Welcome to the official PackArcade2 community forum! This is a place to share your projects, get help, and connect with other developers.\n\n## Getting Started\n\n- Introduce yourself\n- Share your first project\n- Ask questions",
                        Author = "System",
                        Category = "announcements",
                        CreatedAt = DateTime.Now.AddDays(-7),
                        Pinned = true,
                        Sticky = true,
                        Views = 156,
                        Replies = new List<ForumReply>
                        {
                            new ForumReply { Id = Guid.NewGuid().ToString(), Author = "PackArcade Team", Content = "Welcome everyone!", CreatedAt = DateTime.Now.AddDays(-6) }
                        }
                    }
                };
                await SaveTopics();
            }
            forumTopics = topics.Count;
            forumReplies = topics.Sum(t => t.Replies.Count);
        }
        catch (Exception ex) { Logger.LogError(ex, "Failed to load topics"); }
    }

    private async Task SaveTopics()
    {
        var topicsFile = Path.Combine(dataPath, "topics.json");
        var json = JsonSerializer.Serialize(topics, new JsonSerializerOptions { WriteIndented = true });
        await File.WriteAllTextAsync(topicsFile, json);
    }

    private void SetCategory(string? category) { currentCategory = category ?? ""; FilterTopics(); }
    private void SearchTopics() { FilterTopics(); }
    private void FilterTopics()
    {
        filteredTopics = topics
            .Where(t => (string.IsNullOrEmpty(currentCategory) || t.Category == currentCategory) &&
                        (string.IsNullOrEmpty(searchQuery) || 
                         t.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                         t.Content.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)))
            .ToList();
        StateHasChanged();
    }

    private string GetCategoryName(string category) => category switch
    {
        "announcements" => "📢 Announcements",
        "projects" => "🎮 Projects",
        "help" => "🆘 Help",
        "showcase" => "🏆 Showcase",
        "feedback" => "💡 Feedback",
        _ => "💬 General"
    };

    private string FormatTime(DateTime time)
    {
        var diff = DateTime.Now - time;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return time.ToString("MMM d");
    }

    private MarkupString MarkdownToHtml(string markdown)
    {
        if (string.IsNullOrEmpty(markdown)) return new MarkupString("");
        var html = markdown;
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^### (.*?)$", "<h3>$1</h3>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^## (.*?)$", "<h2>$1</h2>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^# (.*?)$", "<h1>$1</h1>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*\*(.*?)\*\*", "<strong>$1</strong>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*(.*?)\*", "<em>$1</em>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"```(.*?)```", "<pre><code>$1</code></pre>", System.Text.RegularExpressions.RegexOptions.Singleline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"`(.*?)`", "<code>$1</code>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\[(.*?)\]\((.*?)\)", "<a href=\"$2\" target=\"_blank\">$1</a>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\n\n", "</p><p>");
        html = $"<p>{html}</p>";
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\n", "<br/>");
        return new MarkupString(html);
    }

    private void ShowCreateTopicModal() { newTopic = new NewTopic(); showCreateModal = true; StateHasChanged(); }
    private void CloseCreateModal() { showCreateModal = false; StateHasChanged(); }

    private async Task CreateTopic()
    {
        if (string.IsNullOrWhiteSpace(newTopic.Title)) { await ShowAlert("Please enter a title"); return; }
        if (string.IsNullOrWhiteSpace(newTopic.Content)) { await ShowAlert("Please enter content"); return; }
        
        isCreating = true; StateHasChanged();
        
        try
        {
            if (newTopic.Pinned && !await PointsService.SpendPoints(clientIp ?? "anonymous", 500, "Pin forum topic"))
            { await ShowAlert("Not enough points to pin topic! Need 500 points."); isCreating = false; return; }
            
            if (newTopic.Sticky && !await PointsService.SpendPoints(clientIp ?? "anonymous", 300, "Sticky forum topic"))
            { await ShowAlert("Not enough points to sticky topic! Need 300 points."); isCreating = false; return; }
            
            var topic = new ForumTopic
            {
                Id = Guid.NewGuid().ToString(),
                Title = newTopic.Title,
                Content = newTopic.Content,
                Author = clientIp ?? "anonymous",
                Category = newTopic.Category,
                Pinned = newTopic.Pinned,
                Sticky = newTopic.Sticky,
                CreatedAt = DateTime.Now,
                LastActivity = DateTime.Now,
                Views = 0,
                Replies = new List<ForumReply>()
            };
            
            topics.Insert(0, topic);
            await SaveTopics();
            await PointsService.AddPoints(clientIp ?? "anonymous", 10, "Created forum topic");
            await ShowAlert("Topic created successfully! +10 points");
            CloseCreateModal();
            FilterTopics();
        }
        catch (Exception ex) { await ShowAlert($"Error: {ex.Message}"); }
        finally { isCreating = false; StateHasChanged(); }
    }

    private async Task ViewTopic(string topicId)
    {
        var topic = topics.FirstOrDefault(t => t.Id == topicId);
        if (topic == null) return;
        selectedTopic = topic;
        topic.Views++;
        await SaveTopics();
        showTopicModal = true;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("scrollToBottom");
    }

    private void CloseTopicModal() { showTopicModal = false; selectedTopic = null; newReply = ""; StateHasChanged(); }

    private async Task AddReply()
    {
        if (string.IsNullOrWhiteSpace(newReply)) { await ShowAlert("Please enter a reply"); return; }
        if (selectedTopic == null) return;
        
        isReplying = true; StateHasChanged();
        
        try
        {
            var reply = new ForumReply
            {
                Id = Guid.NewGuid().ToString(),
                Author = clientIp ?? "anonymous",
                Content = newReply,
                CreatedAt = DateTime.Now
            };
            
            selectedTopic.Replies.Add(reply);
            selectedTopic.LastActivity = DateTime.Now;
            await SaveTopics();
            await PointsService.AddPoints(clientIp ?? "anonymous", 2, "Replied to forum topic");
            newReply = "";
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("scrollToBottom");
        }
        catch (Exception ex) { await ShowAlert($"Error: {ex.Message}"); }
        finally { isReplying = false; StateHasChanged(); }
    }

    private void NavigateTo(string path) { Navigation.NavigateTo(path); }
    private async Task ShowAlert(string message) => await JSRuntime.InvokeVoidAsync("alert", message);

    private class ForumTopic
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string Author { get; set; } = "";
        public string Category { get; set; } = "general";
        public bool Pinned { get; set; }
        public bool Sticky { get; set; }
        public DateTime CreatedAt { get; set; }
        public DateTime LastActivity { get; set; }
        public int Views { get; set; }
        public List<ForumReply> Replies { get; set; } = new();
        public string Preview => Content.Length > 150 ? Content[..150] + "..." : Content;
    }

    private class ForumReply
    {
        public string Id { get; set; } = "";
        public string Author { get; set; } = "";
        public string Content { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }

    private class NewTopic
    {
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string Category { get; set; } = "general";
        public bool Pinned { get; set; }
        public bool Sticky { get; set; }
    }
}