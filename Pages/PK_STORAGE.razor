    private async Task DeleteFile(string fileName)
    {
        var confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Delete {fileName}?");
        if (!confirm) return;
        
        var client = HttpClientFactory.CreateClient();
        client.DefaultRequestHeaders.Add("X-PK-API-Key", apiKey);
        var response = await client.DeleteAsync($"http://localhost:5000/api/pk-storage/delete/{fileName}");
        
        if (response.IsSuccessStatusCode)
        {
            await LoadFileList();
            await AddTerminalMessage($"🗑️ Deleted: {fileName}");
        }
        else
        {
            await AddTerminalMessage($"❌ Failed to delete: {fileName}");
        }
    }

