    }

    .tab-btn {
        background: rgba(0,0,0,0.4);
        border: 1px solid #2a2e3a;
        padding: 12px 24px;
        border-radius: 8px;
        color: #fff;
        cursor: pointer;
        font-size: 16px;
        transition: all 0.2s;
    }

    .tab-btn.active {
        background: #00ffaa;
        color: #0a0e1a;
        border-color: #00ffaa;
    }

    .tab-btn:hover:not(.active) {
        background: rgba(0,255,170,0.2);
    }

    .api-key-card, .storage-card, .files-card, .database-card, .docs-card, .embed-card {
        background: rgba(0,0,0,0.4);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 24px;
        border: 1px solid #2a2e3a;
    }

    .api-key-card h3, .storage-card h3, .files-card h3, .database-card h3, .docs-card h3, .embed-card h3 {
        color: #00ffaa;
        margin-bottom: 16px;
    }

    .key-display {
        background: #0a0e1a;
        padding: 15px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 15px;
    }

    .key-display code {
        flex: 1;
        background: #000;
        padding: 8px 12px;
        border-radius: 6px;
        font-family: monospace;
        color: #88ff88;
        word-break: break-all;
    }

    .copy-btn, .refresh-btn, .upload-btn, .refresh-files-btn, .refresh-db-btn, .create-db-btn, .execute-sql-btn, .copy-code-btn {
        background: #2a2e3a;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        color: #fff;
        cursor: pointer;
        font-size: 14px;
        transition: all 0.2s;
    }

    .copy-btn:hover, .refresh-btn:hover, .upload-btn:hover, .refresh-files-btn:hover, .refresh-db-btn:hover, .create-db-btn:hover, .execute-sql-btn:hover, .copy-code-btn:hover {
        background: #00ffaa;
        color: #0a0e1a;
    }

    .api-usage {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }

    .usage-stat {
        background: #1a1e2a;
        padding: 8px 16px;
        border-radius: 8px;
    }

    .stat-label {
        color: #6c7293;
        margin-right: 8px;
    }

    .stat-value {
        color: #00ffaa;
        font-weight: bold;
    }

    .progress-container {
        margin: 15px 0;
    }

    .progress-bar {
        background: #2a2e3a;
        height: 20px;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 10px;
    }

    .progress-fill {
        background: linear-gradient(90deg, #00ffaa, #44ff44);
        height: 100%;
        transition: width 0.3s;
    }

    .storage-stats {
        display: flex;
        justify-content: space-between;
        color: #aaa;
        font-size: 14px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .upload-area {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

    .file-list {
        max-height: 400px;
        overflow-y: auto;
    }

    .file-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px;
        border-bottom: 1px solid #2a2e3a;
        transition: background 0.2s;
    }

    .file-item:hover {
        background: rgba(0,255,170,0.05);
    }

    .file-info {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .file-icon {
        font-size: 20px;
    }

    .file-name {
        color: #fff;
        font-family: monospace;
    }

    .file-actions {
        display: flex;
        gap: 8px;
    }

    .download-btn, .delete-btn {
        padding: 4px 12px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 12px;
    }

    .download-btn {
        background: #44aa44;
        color: white;
    }

    .download-btn:hover {
        background: #55cc55;
    }

    .delete-btn {
        background: #aa4444;
        color: white;
    }

    .delete-btn:hover {
        background: #cc5555;
    }

    .empty-state {
        text-align: center;
        padding: 40px;
        color: #6c7293;
    }

    .empty-icon {
        font-size: 48px;
        display: block;
        margin-bottom: 16px;
    }

    .loading {
        text-align: center;
        padding: 40px;
        color: #00ffaa;
    }

    .db-section {
        margin-bottom: 24px;
        padding: 16px;
        background: rgba(0,0,0,0.2);
        border-radius: 8px;
    }

    .db-section h4 {
        color: #00ffaa;
        margin-bottom: 12px;
    }

    .db-create-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .db-input {
        background: #1a1e2a;
        border: 1px solid #2a2e3a;
        border-radius: 6px;
        padding: 10px;
        color: #00ffaa;
        font-family: monospace;
    }

    .db-select {
        background: #1a1e2a;
        border: 1px solid #2a2e3a;
        border-radius: 6px;
        padding: 10px;
        color: #00ffaa;
        font-family: monospace;
        width: 100%;
        margin-bottom: 10px;
    }

    .sql-textarea {
        width: 100%;
        background: #0a0e1a;
        border: 1px solid #2a2e3a;
        border-radius: 8px;
        padding: 12px;
        color: #88ff88;
        font-family: monospace;
        font-size: 13px;
        resize: vertical;
        margin-bottom: 12px;
    }

    .sql-textarea:focus {
        outline: none;
        border-color: #00ffaa;
    }

    .execute-sql-btn {
        width: 100%;
        background: #00ffaa;
        color: #0a0e1a;
        font-weight: bold;
    }

    .schema-display, .results-display {
        background: #0a0e1a;
        padding: 12px;
        border-radius: 6px;
        font-family: monospace;
        font-size: 12px;
        overflow-x: auto;
        color: #88ff88;
        max-height: 300px;
        overflow-y: auto;
    }

    .api-endpoints {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .endpoint {
        background: #0a0e1a;
        padding: 12px;
        border-radius: 8px;
        border-left: 4px solid;
    }

    .endpoint .method {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 4px;
        font-weight: bold;
        font-size: 11px;
        margin-right: 10px;
    }

    .method.post {
        background: #44aa44;
        color: white;
        border-left-color: #44aa44;
    }

    .method.get {
        background: #44aaff;
        color: white;
        border-left-color: #44aaff;
    }

    .method.delete {
        background: #aa4444;
        color: white;
        border-left-color: #aa4444;
    }

    .endpoint code {
        color: #88ff88;
        font-family: monospace;
        font-size: 12px;
    }

    .endpoint .desc {
        display: block;
        color: #aaa;
        margin-top: 4px;
        font-size: 11px;
    }

    .code-block {
        background: #0a0e1a;
        padding: 16px;
        border-radius: 8px;
        overflow-x: auto;
        margin: 16px 0;
    }

