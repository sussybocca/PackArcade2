        color: #88ff88;
        font-family: monospace;
        font-size: 12px;
        white-space: pre-wrap;
    }

    @@media (max-width: 768px) {
        .pk-container {
            padding: 20px;
        }
        
        .hero-card {
            padding: 20px;
        }
        
        .key-display {
            flex-direction: column;
        }
        
        .file-item {
            flex-direction: column;
            gap: 10px;
            align-items: flex-start;
        }
        
        .upload-area {
            flex-direction: column;
        }
        
        .tabs {
            flex-direction: column;
        }
    }
</style>

@code {
    private bool hasApiKey = false;
    private string apiKey = "";
    private bool isGenerating = false;
    private bool isLoading = false;
    private bool isDbLoading = false;
    private List<string> files = new();
    private ApiKeyInfo? keyInfo;
    private double storageUsedMB = 0;
    private double storageUsedPercent = 0;
    
    // Database tab
    private string activeTab = "files";
    private List<string> databases = new();
    private string selectedDb = "";
    private string newDbName = "";
    private bool enableRLS = true;
    private bool isPrivate = true;
    private string sqlQuery = "";
    private string queryResults = "";
    private string databaseSchema = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            apiKey = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "pk_api_key");
            if (!string.IsNullOrEmpty(apiKey))
            {
                hasApiKey = true;
                await LoadKeyInfo();
                await LoadFileList();
                await LoadDatabases();
            }
        }
        catch { }
    }

    private void SetTab(string tab)
    {
        activeTab = tab;
        StateHasChanged();
    }

    private async Task GenerateApiKey()
    {
        isGenerating = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient();
            var response = await client.PostAsync("http://localhost:5000/api/pk-storage/generate-key", null);
            
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var result = JsonSerializer.Deserialize<GenerateKeyResponse>(json);
                apiKey = result?.key ?? "";
                hasApiKey = true;
                
                await JSRuntime.InvokeVoidAsync("localStorage.setItem", "pk_api_key", apiKey);
                await LoadKeyInfo();
                await LoadFileList();
                await LoadDatabases();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                await JSRuntime.InvokeVoidAsync("alert", $"Failed to generate API key: {response.StatusCode} - {errorContent}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", $"Error generating API key: {ex.Message}");
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    private async Task LoadKeyInfo()
    {
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.Add("X-PK-API-Key", apiKey);
            var response = await client.GetAsync("http://localhost:5000/api/pk-storage/list");
            
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var result = JsonSerializer.Deserialize<ListResponse>(json);
                
                keyInfo = new ApiKeyInfo
                {
                    CreatedAt = DateTime.Now,
                    ExpiresAt = DateTime.Now.AddYears(1),
                    RequestsToday = result?.total_files ?? 0,
                    StorageUsed = result?.storage_used ?? 0
                };
                
                storageUsedMB = keyInfo.StorageUsed / (1024.0 * 1024.0);
                storageUsedPercent = (keyInfo.StorageUsed / (1024.0 * 1024 * 1024 * 1024)) * 100;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading key info: {ex.Message}");
        }
    }

    private async Task LoadFileList()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.Add("X-PK-API-Key", apiKey);
            var response = await client.GetAsync("http://localhost:5000/api/pk-storage/list");
            
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var result = JsonSerializer.Deserialize<ListResponse>(json);
                files = result?.files ?? new List<string>();
                storageUsedMB = result?.storage_used_mb ?? 0;
                storageUsedPercent = result?.storage_used_percent ?? 0;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading files: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDatabases()
    {
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.Add("X-PK-API-Key", apiKey);
            var response = await client.GetAsync("http://localhost:5000/api/pk-storage/database/list");
            
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var result = JsonSerializer.Deserialize<DatabaseListResponse>(json);
                databases = result?.databases ?? new List<string>();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading databases: {ex.Message}");
        }
    }

    private async Task CreateDatabase()
    {
        if (string.IsNullOrEmpty(newDbName))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Please enter a database name");
            return;
        }
        
        isDbLoading = true;
        StateHasChanged();
        
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.Add("X-PK-API-Key", apiKey);
            
            var payload = new { name = newDbName, enableRLS = enableRLS, isPrivate = isPrivate };
            var json = JsonSerializer.Serialize(payload);
            var content = new StringContent(json, Encoding.UTF8, "application/json");
            
            var response = await client.PostAsync("http://localhost:5000/api/pk-storage/database/create", content);
            var result = await response.Content.ReadAsStringAsync();
            
            await JSRuntime.InvokeVoidAsync("alert", result);
            
            if (response.IsSuccessStatusCode)
            {
                newDbName = "";
                await LoadDatabases();
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
        finally
        {
            isDbLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDatabaseSchema()
    {
        if (string.IsNullOrEmpty(selectedDb)) return;
        
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.Add("X-PK-API-Key", apiKey);
            var response = await client.GetAsync($"http://localhost:5000/api/pk-storage/database/schema?database={selectedDb}");
            
            if (response.IsSuccessStatusCode)
            {
                databaseSchema = await response.Content.ReadAsStringAsync();
            }
            else
            {
                databaseSchema = "Failed to load schema";
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            databaseSchema = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task ExecuteSql()
    {
        if (string.IsNullOrEmpty(selectedDb))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Please select a database");
            return;
        }
        
        if (string.IsNullOrEmpty(sqlQuery))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Please enter a SQL query");
            return;
        }
        
        isDbLoading = true;
        StateHasChanged();
        
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.Add("X-PK-API-Key", apiKey);
            
            var payload = new { database = selectedDb, sql = sqlQuery };
            var json = JsonSerializer.Serialize(payload);
            var content = new StringContent(json, Encoding.UTF8, "application/json");
            
            var response = await client.PostAsync("http://localhost:5000/api/pk-storage/database/query", content);
            queryResults = await response.Content.ReadAsStringAsync();
            
            if (!response.IsSuccessStatusCode)
            {
                queryResults = $"Error: {queryResults}";
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            queryResults = $"Error: {ex.Message}";
            StateHasChanged();
        }
        finally
        {
            isDbLoading = false;
        }
    }

    private async Task RefreshKeyInfo()
    {
        await LoadKeyInfo();
        await LoadFileList();
        await LoadDatabases();
    }

    private async Task TriggerFileUpload()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('fileInput').click()");
    }

  private async Task OnFileSelected(ChangeEventArgs e)
{
    try
    {
        var results = await JSRuntime.InvokeAsync<object[]>("uploadToPKStorage", apiKey, "fileInput");
        
        if (results != null)
        {
            foreach (var resultObj in results)
            {
                var result = JsonSerializer.Deserialize<UploadResult>(JsonSerializer.Serialize(resultObj));
                if (result.success)
                {
                    await ShowAlert($"✅ Uploaded: {result.name}");
                }
                else
                {
                    await ShowAlert($"❌ Failed: {result.name} - {result.message}");
                }
            }
        }
        
        await LoadFileList();
        
        // Clear the file input
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('fileInput').value = ''");
    }
    catch (Exception ex)
    {
        Console.WriteLine($"OnFileSelected error: {ex.Message}");
        await ShowAlert($"Error: {ex.Message}");
    }
}

