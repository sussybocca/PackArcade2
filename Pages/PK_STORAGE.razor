@page "/pk-storage"
@using PackArcade2.Services
@using System.Text.Json
@using System.Net.Http
@using System.Text
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory

<PageTitle>PK Storage - 1TB Free Cloud Storage - PackArcade2</PageTitle>

<div class="pk-container">
    <div class="pk-header">
        <h1>💾 PK STORAGE</h1>
        <p>1TB Free Cloud Storage + SQL Database | Powered by PackArcade2 VHD Storage Array</p>
    </div>

    @if (!hasApiKey)
    {
        <div class="generate-section">
            <div class="hero-card">
                <div class="hero-icon">🚀</div>
                <h2>Get Your Free 1TB Storage</h2>
                <p>Generate your API key and start storing files instantly! No credit card required.</p>
                <div class="features">
                    <div class="feature">
                        <span class="feature-icon">💾</span>
                        <span>1TB Storage</span>
                    </div>
                    <div class="feature">
                        <span class="feature-icon">🗄️</span>
                        <span>SQL Database</span>
                    </div>
                    <div class="feature">
                        <span class="feature-icon">🔒</span>
                        <span>RLS Protection</span>
                    </div>
                    <div class="feature">
                        <span class="feature-icon">🌐</span>
                        <span>REST API Access</span>
                    </div>
                </div>
                <button class="generate-btn" @onclick="GenerateApiKey" disabled="@isGenerating">
                    @(isGenerating ? "Generating..." : "🔑 Generate API Key")
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="storage-dashboard">
            <!-- API Key Display -->
            <div class="api-key-card">
                <h3>🔐 Your API Key</h3>
                <div class="key-display">
                    <code>@apiKey</code>
                    <button class="copy-btn" @onclick="(() => CopyToClipboard(apiKey))">📋 Copy</button>
                    <button class="refresh-btn" @onclick="RefreshKeyInfo">🔄 Refresh</button>
                </div>
                <div class="api-usage">
                    <div class="usage-stat">
                        <span class="stat-label">Created:</span>
                        <span class="stat-value">@(keyInfo?.CreatedAt.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</span>
                    </div>
                    <div class="usage-stat">
                        <span class="stat-label">Expires:</span>
                        <span class="stat-value">@(keyInfo?.ExpiresAt.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</span>
                    </div>
                    <div class="usage-stat">
                        <span class="stat-label">Requests Today:</span>
                        <span class="stat-value">@(keyInfo?.RequestsToday ?? 0)</span>
                    </div>
                </div>
            </div>

            <!-- Tabs -->
            <div class="tabs">
                <button class="tab-btn @(activeTab == "files" ? "active" : "")" @onclick='() => SetTab("files")'>📁 Files</button>
                <button class="tab-btn @(activeTab == "database" ? "active" : "")" @onclick='() => SetTab("database")'>🗄️ SQL Database</button>
            </div>

            <!-- Files Tab -->
            @if (activeTab == "files")
            {
                <div class="files-card">
                    <h3>📁 Your Files</h3>
                    <div class="upload-area">
                        <input type="file" id="fileInput" @onchange="OnFileSelected" style="display: none;" multiple />
                        <button class="upload-btn" @onclick="TriggerFileUpload">📤 Upload Files</button>
                        <button class="refresh-files-btn" @onclick="LoadFileList">🔄 Refresh List</button>
                    </div>

                    @if (isLoading)
                    {
                        <div class="loading">Loading files...</div>
                    }
                    else if (files.Count == 0)
                    {
                        <div class="empty-state">
                            <span class="empty-icon">📂</span>
                            <p>No files uploaded yet. Click "Upload Files" to get started!</p>
                        </div>
                    }
                    else
                    {
                        <div class="file-list">
                            @foreach (var file in files)
                            {
                                <div class="file-item">
                                    <div class="file-info">
                                        <span class="file-icon">📄</span>
                                        <span class="file-name">@file</span>
                                    </div>
                                    <div class="file-actions">
                                        <button class="download-btn" @onclick='(() => DownloadFile(file))'>📥 Download</button>
                                        <button class="delete-btn" @onclick='(() => DeleteFile(file))'>🗑️ Delete</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <!-- Database Tab -->
            @if (activeTab == "database")
            {
                <div class="database-card">
                    <h3>🗄️ SQL Database Manager</h3>
                    
                    <!-- Create Database -->
                    <div class="db-section">
                        <h4>Create New Database</h4>
                        <div class="db-create-form">
                            <input @bind="newDbName" placeholder="Database name" class="db-input" />
                            <label>
                                <input type="checkbox" @bind="enableRLS" />
                                Enable Row Level Security (RLS)
                            </label>
                            <label>
                                <input type="checkbox" @bind="isPrivate" />
                                Private Database
                            </label>
                            <button class="create-db-btn" @onclick="CreateDatabase" disabled="@isDbLoading">Create Database</button>
                        </div>
                    </div>

                    <!-- Database Selector -->
                    <div class="db-section">
                        <h4>Select Database</h4>
                        <select @bind="selectedDb" class="db-select">
                            <option value="">-- Select a database --</option>
                            @foreach (var db in databases)
                            {
                                <option value="@db">@db</option>
                            }
                        </select>
                        <button class="refresh-db-btn" @onclick="LoadDatabases">🔄 Refresh</button>
                        <button class="refresh-db-btn" @onclick="LoadDatabaseSchema">📋 Load Schema</button>
                    </div>

                    <!-- SQL Query Editor -->
                    @if (!string.IsNullOrEmpty(selectedDb))
                    {
                        <div class="db-section">
                            <h4>SQL Query Editor</h4>
                            <div class="sql-editor">
                                <textarea @bind="sqlQuery" class="sql-textarea" placeholder="Enter your SQL query...
                                
Examples:
PK_INSERT: INSERT INTO users (name, email) VALUES ('John', 'john@example.com')
PK_SELECT: SELECT * FROM users
PK_UPDATE: UPDATE users SET name = 'Jane' WHERE id = 1
PK_DELETE: DELETE FROM users WHERE id = 1

Or regular SQL:
CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT)
SELECT * FROM users" rows="8"></textarea>
                                <button class="execute-sql-btn" @onclick="ExecuteSql" disabled="@isDbLoading">▶ Execute Query</button>
                            </div>
                        </div>

                        <!-- Schema Display -->
                        <div class="db-section">
                            <h4>Database Schema</h4>
                            <pre class="schema-display">@databaseSchema</pre>
                        </div>

                        <!-- Query Results -->
                        @if (!string.IsNullOrEmpty(queryResults))
                        {
                            <div class="db-section">
                                <h4>Query Results</h4>
                                <pre class="results-display">@queryResults</pre>
                            </div>
                        }
                    }
                </div>
            }

            <!-- API Documentation -->
            <div class="docs-card">
                <h3>📚 API Documentation</h3>
                <div class="api-endpoints">
                    <div class="endpoint">
                        <span class="method post">POST</span>
                        <code>/api/pk-storage/upload</code>
                        <span class="desc">Upload a file</span>
                    </div>
                    <div class="endpoint">
                        <span class="method get">GET</span>
                        <code>/api/pk-storage/download/{filename}</code>
                        <span class="desc">Download a file</span>
                    </div>
                    <div class="endpoint">
                        <span class="method delete">DELETE</span>
                        <code>/api/pk-storage/delete/{filename}</code>
                        <span class="desc">Delete a file</span>
                    </div>
                    <div class="endpoint">
                        <span class="method get">GET</span>
                        <code>/api/pk-storage/list</code>
                        <span class="desc">List all files</span>
                    </div>
                    <div class="endpoint">
                        <span class="method post">POST</span>
                        <code>/api/pk-storage/database/create</code>
                        <span class="desc">Create a database</span>
                    </div>
                    <div class="endpoint">
                        <span class="method post">POST</span>
                        <code>/api/pk-storage/database/query</code>
                        <span class="desc">Execute SQL query</span>
                    </div>
                    <div class="endpoint">
                        <span class="method get">GET</span>
                        <code>/api/pk-storage/database/list</code>
                        <span class="desc">List all databases</span>
                    </div>
                </div>
            </div>

            <!-- Embed Example -->
            <div class="embed-card">
                <h3>🔌 Embed in Your Website</h3>
                <p>Use this simple JavaScript to interact with PK Storage from your site:</p>
                <pre class="code-block"><code>&lt;script&gt;
// Initialize with your API key
const PK_API = "@apiKey";

// Upload a file
async function uploadToPK(file) {
    const formData = new FormData();
    formData.append('file', file);
    
    const response = await fetch('https://packarcade.win/api/pk-storage/upload', {
        method: 'POST',
        headers: { 'X-PK-API-Key': PK_API },
        body: formData
    });
    return await response.json();
}

// Execute SQL query
async function executeSQL(database, sql) {
    const response = await fetch('https://packarcade.win/api/pk-storage/database/query', {
        method: 'POST',
        headers: { 
            'X-PK-API-Key': PK_API,
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ database, sql })
    });
    return await response.text();
}
&lt;/script&gt;</code></pre>
                <button class="copy-code-btn" @onclick="CopyCodeExample">📋 Copy Example Code</button>
            </div>
        </div>
    }
</div>

<style>
    .pk-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #0a0e1a 0%, #0f111a 100%);
        padding: 40px 20px;
        font-family: 'Segoe UI', monospace;
    }

    .pk-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .pk-header h1 {
        color: #00ffaa;
        font-size: 48px;
        margin-bottom: 10px;
        text-shadow: 0 0 10px rgba(0,255,170,0.3);
    }

    .pk-header p {
        color: #6c7293;
        font-size: 16px;
    }

    .generate-section {
        max-width: 800px;
        margin: 0 auto;
    }

    .hero-card {
        background: rgba(0,0,0,0.5);
        border-radius: 20px;
        padding: 40px;
        text-align: center;
        border: 1px solid #00ffaa30;
        backdrop-filter: blur(10px);
