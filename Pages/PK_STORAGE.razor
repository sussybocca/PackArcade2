        align-items: center;
        justify-content: center;
        gap: 10px;
        font-weight: bold;
        color: #00ffaa;
    }

    .feature-icon {
        font-size: 24px;
    }

    .generate-btn {
        background: linear-gradient(135deg, #00ffaa, #00cc88);
        color: #0a0e1a;
        border: none;
        padding: 15px 40px;
        font-size: 18px;
        font-weight: bold;
        border-radius: 50px;
        cursor: pointer;
        transition: transform 0.2s;
