@page "/server-offline"
@using PackArcade2
@inject ServerStatusService StatusService
@inject NavigationManager Navigation

<div class="server-offline-container">
    <div class="offline-card">
        <div class="offline-icon">🔧</div>
        <h1>Server is Currently Offline</h1>
        
        <div class="status-box @(status.InOfflineWindow ? "warning" : "danger")">
            <div class="status-icon">@status.StatusIcon</div>
            <div class="status-message">@status.StatusMessage</div>
        </div>
        
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">Current Time</span>
                <span class="info-value">@status.CurrentTime</span>
            </div>
            <div class="info-item">
                <span class="info-label">Server Uptime</span>
                <span class="info-value">@status.Uptime</span>
            </div>
            <div class="info-item">
                <span class="info-label">Started At</span>
                <span class="info-value">@status.StartTime</span>
            </div>
            @if (status.InOfflineWindow && !string.IsNullOrEmpty(status.EstimatedReturn))
            {
                <div class="info-item">
                    <span class="info-label">Expected Return</span>
                    <span class="info-value">@status.EstimatedReturn</span>
                </div>
            }
        </div>
        
        <div class="schedule-box">
            <h3>📅 Server Schedule</h3>
            <div class="schedule-grid">
                <div class="schedule-item">
                    <div class="time">6:00 AM - 3:00 PM</div>
                    <div class="status-badge online">✅ Online</div>
                </div>
                <div class="schedule-item">
                    <div class="time">3:00 PM - 7:00 PM</div>
                    <div class="status-badge maintenance">⚠️ Maintenance</div>
                </div>
                <div class="schedule-item">
                    <div class="time">7:00 PM - 9:00 PM</div>
                    <div class="status-badge online">✅ Online</div>
                </div>
                <div class="schedule-item">
                    <div class="time">9:00 PM - 6:00 AM</div>
                    <div class="status-badge offline">❌ Offline</div>
                </div>
            </div>
            <p class="schedule-note">* Times are approximate and may vary based on real-life schedules</p>
        </div>
        
        <div class="actions">
            <button class="btn btn-primary" @onclick="RefreshStatus">🔄 Refresh Status</button>
            <button class="btn btn-secondary" @onclick="GoHome">🏠 Return to Home</button>
        </div>
        
        <div class="heart-message">
            <p>We're doing our best to get back online! <span class="heart">❤️</span></p>
            <p class="small">- The PackArcade2 Team</p>
        </div>
    </div>
</div>

<style>
    .server-offline-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1a1a2e, #16213e);
        padding: 20px;
    }
    
    .offline-card {
        max-width: 600px;
        width: 100%;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 2px rgba(255,215,0,0.3);
        text-align: center;
        color: white;
    }
    
    .offline-icon {
        font-size: 5em;
        margin-bottom: 20px;
        animation: spin 4s linear infinite;
    }
    
    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    
    h1 {
        margin-bottom: 30px;
        font-size: 2em;
        text-shadow: 0 0 20px cyan;
    }
    
    .status-box {
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    .status-box.warning {
        background: rgba(255, 193, 7, 0.2);
        border-left: 5px solid #ffc107;
    }
    
    .status-box.danger {
        background: rgba(220, 53, 69, 0.2);
        border-left: 5px solid #dc3545;
    }
    
    .status-icon {
        font-size: 2em;
    }
    
    .status-message {
        font-size: 1.2em;
        text-align: left;
    }
    
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .info-item {
        background: rgba(255,255,255,0.1);
        padding: 15px;
        border-radius: 10px;
    }
    
    .info-label {
        display: block;
        font-size: 0.9em;
        color: #aaa;
        margin-bottom: 5px;
    }
    
    .info-value {
        font-size: 1.1em;
        font-weight: bold;
        color: #00ffff;
    }
    
    .schedule-box {
        background: rgba(0,0,0,0.5);
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 30px;
        border: 1px solid rgba(255,255,255,0.2);
    }
    
    .schedule-box h3 {
        color: #ffd700;
        margin-bottom: 20px;
    }
    
    .schedule-grid {
        display: grid;
        gap: 10px;
        margin-bottom: 15px;
    }
    
    .schedule-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px;
        background: rgba(255,255,255,0.05);
        border-radius: 5px;
    }
    
    .status-badge {
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 0.9em;
        font-weight: bold;
    }
    
    .status-badge.online {
        background: rgba(40, 167, 69, 0.3);
        color: #28a745;
    }
    
    .status-badge.maintenance {
        background: rgba(255, 193, 7, 0.3);
        color: #ffc107;
    }
    
    .status-badge.offline {
        background: rgba(220, 53, 69, 0.3);
        color: #dc3545;
    }
    
    .schedule-note {
        font-size: 0.9em;
        color: #aaa;
        margin-top: 10px;
    }
    
    .actions {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-bottom: 20px;
    }
    
    .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 1em;
        transition: all 0.3s;
    }
    
    .btn-primary {
        background: #007bff;
        color: white;
    }
    
    .btn-primary:hover {
        background: #0056b3;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,123,255,0.3);
    }
    
    .btn-secondary {
        background: #6c757d;
        color: white;
    }
    
    .btn-secondary:hover {
        background: #545b62;
        transform: translateY(-2px);
    }
    
    .heart-message {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid rgba(255,255,255,0.2);
    }
    
    .heart {
        color: #ff4444;
        animation: pulse 1.5s infinite;
        display: inline-block;
    }
    
    @@keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.2); }
        100% { transform: scale(1); }
    }
    
    .small {
        font-size: 0.9em;
        color: #aaa;
        margin-top: 10px;
    }
</style>

@code {
    private ServerStatus status = new();

    protected override void OnInitialized()
    {
        RefreshStatus();
    }

    private void RefreshStatus()
    {
        status = StatusService.GetCurrentStatus();
        StateHasChanged();
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/");
    }
}