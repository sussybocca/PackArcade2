    private async Task AddCivilization()
    {
        if (selectedWorld == null) return;
        var civNames = new[] { "Eldoria", "Nexus Prime", "Avalon", "Crystalium", "Shadowfen", "Starhaven", "Ironhold", "Mystfall" };
        var newCiv = new Civilization
        {
            Name = civNames[_random.Next(civNames.Length)],
            Level = _random.Next(1, 8),
            Description = $"A {(_random.Next(2) == 0 ? "peaceful" : "warlike")} civilization that thrives on {(new[] { "magic", "technology", "nature", "commerce" })[_random.Next(4)]}"
        };
        selectedWorld.Civilizations.Add(newCiv);
        selectedWorld.Population += _random.Next(1000, 50000);
        
        if (selectedWorld.TerrainMap != null && selectedWorld.TerrainMap.Count > 0 && selectedWorld.TerrainMap[0].Count > 0)
        {
            var centerX = selectedWorld.TerrainWidth / 2;
            var centerY = selectedWorld.TerrainHeight / 2;
            if (centerY < selectedWorld.TerrainMap.Count && centerX < selectedWorld.TerrainMap[centerY].Count)
            {
                selectedWorld.TerrainMap[centerY][centerX].Type = "City";
            }
        }
        
        selectedWorld.History.Add($"🏛️ New civilization '{newCiv.Name}' emerged!");
        await SaveData();
        StateHasChanged();
    }
    
