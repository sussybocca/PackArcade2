@page "/world-game"
@using System.Text.Json
@using System.Text
@using Microsoft.JSInterop
@using Newtonsoft.Json
@using Microsoft.ML
@using Microsoft.ML.Transforms
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<PageTitle>🌍 Tonit: World Creation & Destruction - PackArcade2</PageTitle>

<style>
    .world-game-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #0a0a2a 0%, #1a0033 100%);
        padding: 20px;
        font-family: 'Courier New', monospace;
        color: #fff;
        outline: none;
    }
    
    .game-header {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 2px solid #ff00aa;
        padding-bottom: 20px;
    }
    
    .game-header h1 {
        color: #ff00aa;
        text-shadow: 0 0 10px rgba(255,0,170,0.5);
        font-size: 48px;
    }
    
    .key-hint {
        background: #333;
        padding: 4px 12px;
        border-radius: 8px;
        font-weight: bold;
        color: #ffaa00;
        margin: 0 4px;
    }
    
    .stats-bar {
        display: flex;
        justify-content: center;
        gap: 30px;
        margin-top: 15px;
        background: rgba(0,0,0,0.5);
        padding: 10px;
        border-radius: 12px;
    }
    
    .game-main {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 20px;
    }
    
    .world-list {
        background: rgba(0,0,0,0.6);
        border-radius: 16px;
        padding: 15px;
        max-height: 80vh;
        overflow-y: auto;
    }
    
    .world-card {
        background: rgba(50,0,80,0.5);
        border: 1px solid #ff00aa;
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 10px;
        cursor: pointer;
        transition: all 0.3s;
    }
    
    .world-card:hover {
        background: rgba(255,0,170,0.2);
        transform: translateX(5px);
    }
    
    .world-card.selected {
        background: rgba(255,0,170,0.3);
        border: 2px solid #ffaa00;
    }
    
    .world-name {
        font-size: 18px;
        font-weight: bold;
        color: #ffaa00;
    }
    
    .world-stats {
        font-size: 11px;
        display: flex;
        gap: 10px;
        margin: 5px 0;
    }
    
    .game-area {
        background: rgba(0,0,0,0.6);
        border-radius: 16px;
        padding: 20px;
        max-height: 80vh;
        overflow-y: auto;
    }
    
    .builder-controls {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }
    
    .builder-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        color: white;
        cursor: pointer;
        font-weight: bold;
        transition: all 0.3s;
    }
    
    .builder-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 0 10px rgba(102,126,234,0.5);
    }
    
    .builder-btn.danger {
        background: linear-gradient(135deg, #ff4444 0%, #cc0000 100%);
    }
    
    .world-visualization {
        text-align: center;
        margin: 20px 0;
        background: #000;
        border-radius: 12px;
        padding: 10px;
    }
    
    .world-map {
        display: grid;
        grid-template-columns: repeat(20, 15px);
        gap: 0px;
        justify-content: center;
        background: #0a0a2a;
        padding: 10px;
        border-radius: 8px;
    }
    
    .world-tile {
        width: 15px;
        height: 15px;
        display: inline-block;
        cursor: pointer;
        transition: transform 0.1s;
    }
    
    .world-tile:hover {
        transform: scale(1.2);
        z-index: 10;
    }
    
    .legend {
        display: flex;
        gap: 15px;
        justify-content: center;
        margin-top: 10px;
        font-size: 10px;
        flex-wrap: wrap;
    }
    
    .legend-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }
    
    .legend-color {
        width: 12px;
        height: 12px;
        border-radius: 2px;
    }
    
    .info-section {
        background: rgba(0,0,0,0.4);
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 15px;
    }
    
    .history-log {
        max-height: 150px;
        overflow-y: auto;
        font-size: 12px;
    }
    
    .history-entry {
        padding: 4px;
        border-left: 2px solid #ffaa00;
        margin: 4px 0;
        padding-left: 8px;
    }
    
    .civ-card {
        background: rgba(0,0,0,0.3);
        padding: 8px;
        border-radius: 8px;
        margin: 8px 0;
    }
    
    .character-creator, .npc-creator {
        background: rgba(0,0,0,0.4);
        border-radius: 12px;
        padding: 15px;
        margin-top: 20px;
    }
    
    .char-input {
        background: #1a1a2a;
        border: 1px solid #ff00aa;
        border-radius: 8px;
        padding: 8px;
        color: white;
        margin: 5px 0;
        width: 100%;
    }
    
    .create-btn {
        background: #ff00aa;
        border: none;
        padding: 10px;
        border-radius: 8px;
        color: white;
        cursor: pointer;
        width: 100%;
        margin-top: 10px;
    }
    
    .character-list, .npc-list {
        margin-top: 15px;
        max-height: 200px;
        overflow-y: auto;
    }
    
    .character-card, .npc-card {
        background: rgba(255,0,170,0.1);
        border: 1px solid #ff00aa;
        border-radius: 8px;
        padding: 8px;
        margin: 5px 0;
        cursor: pointer;
    }
    
    .character-actions {
        margin-top: 20px;
        background: rgba(0,0,0,0.4);
        border-radius: 12px;
        padding: 15px;
    }
    
    .action-buttons {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin: 15px 0;
    }
    
    .action-btn {
        background: #44aa44;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        color: white;
        cursor: pointer;
    }
    
    .action-log {
        max-height: 150px;
        overflow-y: auto;
        font-size: 12px;
        background: rgba(0,0,0,0.3);
        padding: 10px;
        border-radius: 8px;
    }
    
    .action-entry {
        padding: 4px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    
    .interaction-panel {
        margin-top: 20px;
        background: rgba(0,0,0,0.6);
        border-radius: 12px;
        padding: 15px;
        border: 1px solid #ffaa00;
    }
    
    .dialogue-box {
        margin: 15px 0;
    }
    
    .npc-dialogue-text {
        background: rgba(0,0,0,0.5);
        padding: 15px;
        border-radius: 12px;
        font-style: italic;
        margin-bottom: 15px;
    }
    
    .dialogue-options {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin: 10px 0;
    }
    
    .dialogue-option {
        background: #667eea;
        border: none;
        padding: 8px 16px;
        border-radius: 20px;
        cursor: pointer;
    }
    
    .custom-dialogue {
        width: 100%;
        background: #1a1a2a;
        border: 1px solid #ff00aa;
        border-radius: 8px;
        padding: 8px;
        color: white;
        margin: 10px 0;
    }
    
    .empty-worlds {
        text-align: center;
        padding: 40px;
        color: #888;
    }
</style>

<div class="world-game-container" @onkeydown="HandleKeyPress" tabindex="0">
    <div class="game-header">
        <h1>🌑 TONIT - WORLD CREATION & DESTRUCTION</h1>
        <p>Press <span class="key-hint">K</span> to Create World | <span class="key-hint">D</span> to Destroy | <span class="key-hint">C</span> to Create Character | <span class="key-hint">N</span> to Create NPC</p>
        <div class="stats-bar">
            <span>🔮 Power Level: @powerLevel</span>
            <span>🌍 Worlds Created: @worlds.Count</span>
            <span>👤 Characters: @characters.Count</span>
            <span>🤖 NPCs: @npcs.Count</span>
        </div>
    </div>

    <div class="game-main">
        <div class="world-list">
            <h3>✨ YOUR WORLDS</h3>
            @if (worlds.Count == 0)
            {
                <div class="empty-worlds">Press K to create your first world...</div>
            }
            else
            {
                @foreach (var world in worlds.Values)
                {
                    <div class="world-card @(selectedWorld?.Id == world.Id ? "selected" : "")" @onclick="() => SelectWorld(world.Id)">
                        <div class="world-name">🌌 @world.Name</div>
                        <div class="world-stats">
                            <span>🏔️ Size: @world.Size km²</span>
                            <span>👥 Pop: @world.Population</span>
                            <span>⚡ Power: @world.PowerConsumption</span>
                        </div>
                        <div class="world-description">@world.Description</div>
                    </div>
                }
            }
        </div>

        <div class="game-area">
            @if (selectedWorld != null)
            {
                <div class="world-builder">
                    <h3>🌍 BUILDING: @selectedWorld.Name</h3>
                    
                    <div class="builder-controls">
                        <button class="builder-btn" @onclick="GenerateTerrain">🏔️ Regenerate Terrain</button>
                        <button class="builder-btn" @onclick="GenerateBiomes">🌿 Generate Biomes</button>
                        <button class="builder-btn" @onclick="AddCivilization">🏛️ Add Civilization</button>
                        <button class="builder-btn" @onclick="TriggerWorldEvent">⚡ Random Event</button>
                        <button class="builder-btn danger" @onclick="DestroySelectedWorld">💀 Destroy World</button>
                    </div>

                    <div class="world-visualization">
                        @if (selectedWorld.TerrainMap != null && selectedWorld.TerrainMap.Count > 0)
                        {
                            <div class="world-map" style="grid-template-columns: repeat(@selectedWorld.TerrainWidth, 15px);">
                                @for (int y = 0; y < selectedWorld.TerrainHeight && y < selectedWorld.TerrainMap.Count; y++)
                                {
                                    var row = selectedWorld.TerrainMap[y];
                                    if (row != null)
                                    {
                                        for (int x = 0; x < selectedWorld.TerrainWidth && x < row.Count; x++)
                                        {
                                            var tile = row[x];
                                            if (tile != null)
                                            {
                                                <div class="world-tile" style="background: @GetTileColor(tile.Type);" title="@tile.Type" @onclick="() => OnTileClick(x, y)"></div>
                                            }
                                            else
                                            {
                                                <div class="world-tile" style="background: #3a6ea5;" title="Unknown"></div>
                                            }
                                        }
                                    }
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-worlds">Generating terrain...</div>
                        }
                        <div class="legend">
                            <div class="legend-item"><div class="legend-color" style="background: #3a6ea5;"></div><span>🌊 Ocean</span></div>
                            <div class="legend-item"><div class="legend-color" style="background: #d4af37;"></div><span>🏜️ Desert</span></div>
                            <div class="legend-item"><div class="legend-color" style="background: #2c5e2e;"></div><span>🌲 Forest</span></div>
                            <div class="legend-item"><div class="legend-color" style="background: #8b5a2b;"></div><span>⛰️ Mountain</span></div>
                            <div class="legend-item"><div class="legend-color" style="background: #6b8e23;"></div><span>🌾 Plains</span></div>
                            <div class="legend-item"><div class="legend-color" style="background: #5d8c6b;"></div><span>🏞️ Swamp</span></div>
                            <div class="legend-item"><div class="legend-color" style="background: #e0e0e0;"></div><span>❄️ Tundra</span></div>
                            <div class="legend-item"><div class="legend-color" style="background: #b8860b;"></div><span>🏛️ City</span></div>
                        </div>
                    </div>

                    <div class="world-info">
                        <div class="info-section">
                            <h4>📜 World History</h4>
                            <div class="history-log">
                                @foreach (var history in selectedWorld.History.TakeLast(5))
                                {
                                    <div class="history-entry">@history</div>
                                }
                            </div>
                        </div>

                        <div class="info-section">
                            <h4>🏙️ Civilizations</h4>
                            @if (selectedWorld.Civilizations != null && selectedWorld.Civilizations.Any())
                            {
                                @foreach (var civ in selectedWorld.Civilizations)
                                {
                                    <div class="civ-card">
                                        <strong>@civ.Name</strong> - Level @civ.Level
                                        <div class="civ-desc">@civ.Description</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="empty-worlds">No civilizations yet...</div>
                            }
                        </div>

                        <div class="info-section">
                            <h4>🧬 Active Life Forms</h4>
                            @if (selectedWorld.LifeForms != null && selectedWorld.LifeForms.Any())
                            {
                                @foreach (var life in selectedWorld.LifeForms.Take(10))
                                {
                                    <div class="life-form">🧬 @life</div>
                                }
                            }
                            else
                            {
                                <div class="empty-worlds">No life forms yet...</div>
                            }
                        </div>
                    </div>
                </div>

                <div class="character-creator">
                    <h3>👤 CHARACTER CREATION</h3>
                    <input @bind="newCharacterName" placeholder="Character Name" class="char-input" />
                    <select @bind="newCharacterClass" class="char-input">
                        <option value="Warrior">⚔️ Warrior</option>
                        <option value="Mage">🔮 Mage</option>
                        <option value="Rogue">🗡️ Rogue</option>
                        <option value="Cleric">✨ Cleric</option>
                        <option value="DarkLord">🌑 Dark Lord</option>
                    </select>
                    <button class="create-btn" @onclick="CreateCharacter">Create Character</button>
                    
                    @if (characters.Count > 0)
                    {
                        <div class="character-list">
                            <h4>⭐ YOUR CHARACTERS</h4>
                            @foreach (var chara in characters.Values)
                            {
                                <div class="character-card" @onclick="() => SelectCharacter(chara.Id)">
                                    <div class="char-name">@chara.Name</div>
                                    <div class="char-class">@chara.Class</div>
                                    <div class="char-level">Level @chara.Level</div>
                                    <div class="char-stats">
                                        ❤️ @chara.Health | ⚔️ @chara.Attack | 🛡️ @chara.Defense
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="npc-creator">
                    <h3>🤖 NPC CREATION</h3>
                    <input @bind="newNPCName" placeholder="NPC Name" class="char-input" />
                    <input @bind="newNPCDialogue" placeholder="Default Dialogue" class="char-input" />
                    <select @bind="newNPCPersonality" class="char-input">
                        <option value="Friendly">😊 Friendly</option>
                        <option value="Hostile">😠 Hostile</option>
                        <option value="Neutral">😐 Neutral</option>
                        <option value="Mysterious">🔮 Mysterious</option>
                        <option value="Wise">📚 Wise</option>
                    </select>
                    <button class="create-btn" @onclick="CreateNPC">Create NPC</button>
                    
                    @if (npcs.Count > 0)
                    {
                        <div class="npc-list">
                            <h4>🤖 ACTIVE NPCS</h4>
                            @foreach (var npc in npcs.Values)
                            {
                                <div class="npc-card" @onclick="() => InteractWithNPC(npc.Id)">
                                    <div class="npc-name">@npc.Name</div>
                                    <div class="npc-personality">@npc.Personality</div>
                                    <div class="npc-dialogue">"@npc.CurrentDialogue"</div>
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (selectedCharacter != null)
                {
                    <div class="character-actions">
                        <h3>⚔️ @selectedCharacter.Name - ACTIONS</h3>
                        <div class="action-buttons">
                            <button class="action-btn" @onclick="ExploreWorld">🌍 Explore World</button>
                            <button class="action-btn" @onclick="TalkToNPCs">💬 Talk to NPCs</button>
                            <button class="action-btn" @onclick="BattleMode">⚔️ Enter Battle</button>
                            <button class="action-btn" @onclick="CastSpell">🔮 Cast Spell</button>
                            <button class="action-btn" @onclick="LevelUp">⬆️ Level Up</button>
                        </div>
                        <div class="action-log">
                            @foreach (var action in selectedCharacter.ActionLog.TakeLast(10))
                            {
                                <div class="action-entry">@action</div>
                            }
                        </div>
                    </div>
                }

                @if (selectedNPC != null)
                {
                    <div class="interaction-panel">
                        <h3>💬 TALKING TO: @selectedNPC.Name</h3>
                        <div class="dialogue-box">
                            <div class="npc-dialogue-text">"@selectedNPC.CurrentDialogue"</div>
                            <div class="dialogue-options">
                                @foreach (var option in selectedNPC.DialogueOptions)
                                {
                                    <button class="dialogue-option" @onclick="() => ChooseDialogueOption(option)">@option</button>
                                }
                            </div>
                            <textarea @bind="customDialogue" placeholder="Say something..." class="custom-dialogue"></textarea>
                            <button class="create-btn" @onclick="SendCustomDialogue">💬 Send</button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private Random _random = new Random();
    private int powerLevel = 1000;
    private Dictionary<string, World> worlds = new();
    private Dictionary<string, Character> characters = new();
    private Dictionary<string, NPC> npcs = new();
    private World? selectedWorld;
    private Character? selectedCharacter;
    private NPC? selectedNPC;
    private string newCharacterName = "";
    private string newCharacterClass = "Warrior";
    private string newNPCName = "";
    private string newNPCDialogue = "Hello, traveler!";
    private string newNPCPersonality = "Friendly";
    private string customDialogue = "";
    
    private MLContext? mlContext;
    private ITransformer? npcModel;

    protected override async Task OnInitializedAsync()
    {
        await InitializeML();
        await LoadSavedData();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('.world-game-container')?.focus()");
            }
            catch { }
            StateHasChanged();
        }
    }
    
    private string GetTileColor(string tileType)
    {
        return tileType switch
        {
            "Ocean" => "#3a6ea5",
            "Desert" => "#d4af37",
            "Forest" => "#2c5e2e",
            "Mountain" => "#8b5a2b",
            "Plains" => "#6b8e23",
            "Swamp" => "#5d8c6b",
            "Tundra" => "#e0e0e0",
            "City" => "#b8860b",
            _ => "#3a6ea5"
        };
    }
    
    private async Task InitializeML()
    {
        try
        {
            mlContext = new MLContext();
            
            var trainingData = new List<NPCData>();
            var personalityTypes = new[] { "Friendly", "Hostile", "Neutral", "Mysterious", "Wise" };
            var personalityScores = new Dictionary<string, float>
            {
                ["Friendly"] = 0.2f,
                ["Hostile"] = 0.8f,
                ["Neutral"] = 0.5f,
                ["Mysterious"] = 0.6f,
                ["Wise"] = 0.3f
            };
            
            for (int i = 0; i < 100; i++)
            {
                var personality = personalityTypes[_random.Next(personalityTypes.Length)];
                var interactionCount = _random.Next(0, 100);
                var baseScore = personalityScores[personality];
                var responseScore = baseScore + (interactionCount / 200f);
                responseScore = Math.Min(1f, responseScore);
                
                trainingData.Add(new NPCData
                {
                    PersonalityScore = personalityScores[personality],
                    InteractionCount = interactionCount,
                    ResponseScore = responseScore
                });
            }
            
            var data = mlContext.Data.LoadFromEnumerable(trainingData);
            
            var pipeline = mlContext.Transforms.Concatenate("Features", nameof(NPCData.PersonalityScore), nameof(NPCData.InteractionCount))
                .Append(mlContext.Regression.Trainers.Sdca(labelColumnName: nameof(NPCData.ResponseScore), maximumNumberOfIterations: 100));
            
            npcModel = pipeline.Fit(data);
            Console.WriteLine("ML Model trained successfully with " + trainingData.Count + " samples");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ML Initialization error: {ex.Message}");
            npcModel = null;
        }
    }
    
    private float PredictNPCPersonalityScore(NPC npc)
    {
        if (npcModel == null || mlContext == null) return 0.5f;
        
        try
        {
            var personalityScore = npc.Personality switch
            {
                "Friendly" => 0.2f,
                "Hostile" => 0.8f,
                "Neutral" => 0.5f,
                "Mysterious" => 0.6f,
                "Wise" => 0.3f,
                _ => 0.5f
            };
            
            var engine = mlContext.Model.CreatePredictionEngine<NPCData, NPCResponsePrediction>(npcModel);
            var input = new NPCData
            {
                PersonalityScore = personalityScore,
                InteractionCount = npc.InteractionHistory.Count,
                ResponseScore = 0
            };
            
            var prediction = engine.Predict(input);
            return prediction.PredictedScore;
        }
        catch
        {
            return 0.5f;
        }
    }
    
    private async Task LoadSavedData()
    {
        try
        {
            var savedWorlds = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "tonit_worlds");
            if (!string.IsNullOrEmpty(savedWorlds))
                worlds = JsonConvert.DeserializeObject<Dictionary<string, World>>(savedWorlds) ?? new();
                
            var savedChars = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "tonit_characters");
            if (!string.IsNullOrEmpty(savedChars))
                characters = JsonConvert.DeserializeObject<Dictionary<string, Character>>(savedChars) ?? new();
                
            var savedNPCs = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "tonit_npcs");
            if (!string.IsNullOrEmpty(savedNPCs))
                npcs = JsonConvert.DeserializeObject<Dictionary<string, NPC>>(savedNPCs) ?? new();
                
            if (worlds.Any()) selectedWorld = worlds.Values.First();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Load error: {ex.Message}");
        }
    }
    
    private async Task SaveData()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "tonit_worlds", JsonConvert.SerializeObject(worlds));
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "tonit_characters", JsonConvert.SerializeObject(characters));
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "tonit_npcs", JsonConvert.SerializeObject(npcs));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Save error: {ex.Message}");
        }
        StateHasChanged();
    }
    
    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        switch (e.Key.ToLower())
        {
            case "k":
                await CreateWorld();
                break;
            case "d":
                if (selectedWorld != null)
                    await DestroySelectedWorld();
                break;
            case "c":
                await CreateCharacter();
                break;
            case "n":
                await CreateNPC();
                break;
        }
    }
    
    private void OnTileClick(int x, int y)
    {
        if (selectedWorld == null) return;
        if (selectedWorld.TerrainMap != null && y < selectedWorld.TerrainMap.Count && x < selectedWorld.TerrainMap[y].Count)
        {
            var tile = selectedWorld.TerrainMap[y][x];
            if (tile != null)
            {
                selectedWorld.History.Add($"Explored {tile.Type} at coordinates ({x}, {y})");
                StateHasChanged();
                _ = SaveData();
            }
        }
    }
    
    private async Task CreateWorld()
    {
        var worldId = Guid.NewGuid().ToString();
        var world = new World
        {
            Id = worldId,
            Name = $"World of {DateTime.Now:HHmmss}",
            Size = _random.Next(1000, 50000),
            Population = _random.Next(0, 100000),
            PowerConsumption = _random.Next(10, 500),
            Description = $"A mystical world created by Tonit at {DateTime.Now}",
            History = new List<string> { $"✨ World created at {DateTime.Now}" },
            Civilizations = new List<Civilization>(),
            LifeForms = new List<string>(),
            TerrainMap = GenerateProceduralTerrain(20, 20),
            TerrainWidth = 20,
            TerrainHeight = 20
        };
        
        var initialLifeForms = new[] { "Primordial slime", "Ancient trees", "Crystal formations", "Magical spores" };
        world.LifeForms.Add(initialLifeForms[_random.Next(initialLifeForms.Length)]);
        
        worlds[worldId] = world;
        selectedWorld = world;
        powerLevel += 100;
        
        await SaveData();
        StateHasChanged();
    }
    
    private List<List<TerrainTile>> GenerateProceduralTerrain(int width, int height)
    {
        var terrain = new List<List<TerrainTile>>();
        
        for (int y = 0; y < height; y++)
        {
            var row = new List<TerrainTile>();
            for (int x = 0; x < width; x++)
            {
                var noise = Math.Sin(x * 0.3) * Math.Cos(y * 0.3) + (_random.NextDouble() - 0.5) * 0.3;
                string type;
                
                if (noise < -0.5) type = "Ocean";
                else if (noise < -0.2) type = "Swamp";
                else if (noise < 0) type = "Plains";
                else if (noise < 0.3) type = "Forest";
                else if (noise < 0.6) type = "Mountain";
                else type = "Desert";
                
                if ((x < 3 || x > width - 4) && (y < 3 || y > height - 4))
                    type = "Tundra";
                
                row.Add(new TerrainTile { Type = type, Elevation = (float)noise });
            }
            terrain.Add(row);
        }
        return terrain;
    }
    
    private async Task GenerateTerrain()
    {
        if (selectedWorld == null) return;
        selectedWorld.TerrainMap = GenerateProceduralTerrain(selectedWorld.TerrainWidth, selectedWorld.TerrainHeight);
        selectedWorld.History.Add($"🏔️ New terrain generated at {DateTime.Now}");
        await SaveData();
        StateHasChanged();
    }
    
