        var discovery = discoveries[_random.Next(discoveries.Length)];
        
        selectedCharacter.ActionLog.Add($"{selectedCharacter.Name} explored {selectedWorld.Name} and {discovery}!");
        selectedCharacter.Experience += _random.Next(10, 50);
        
        await SaveData();
        StateHasChanged();
    }
    
    private async Task TalkToNPCs()
    {
        if (selectedCharacter == null || npcs.Count == 0) return;
        
        var randomNPC = npcs.Values.ElementAt(_random.Next(npcs.Count));
        var dialogue = GenerateNPCResponse(randomNPC, "Hello");
        randomNPC.CurrentDialogue = dialogue;
        selectedCharacter.ActionLog.Add($"{selectedCharacter.Name} spoke with {randomNPC.Name}: {dialogue}");
        
        await SaveData();
        StateHasChanged();
    }
    
    private async Task BattleMode()
    {
        if (selectedCharacter == null) return;
        
        var enemies = new[] { "Goblin", "Orc", "Dark Knight", "Dragon", "Skeleton Warrior", "Vampire" };
        var enemy = enemies[_random.Next(enemies.Length)];
        var enemyHealth = _random.Next(50, 150);
        var damage = selectedCharacter.Attack + _random.Next(1, 20);
        enemyHealth -= damage;
        
        selectedCharacter.ActionLog.Add($"{selectedCharacter.Name} attacked the {enemy}! Dealt {damage} damage!");
        
        if (enemyHealth <= 0)
        {
            var exp = _random.Next(20, 100);
            selectedCharacter.Experience += exp;
            selectedCharacter.ActionLog.Add($"⚔️ Victory! Defeated the {enemy}! Gained {exp} experience!");
        }
        else
        {
            selectedCharacter.ActionLog.Add($"The {enemy} survived with {enemyHealth} health remaining!");
        }
        
        await SaveData();
        StateHasChanged();
    }
    
    private async Task CastSpell()
    {
        if (selectedCharacter == null) return;
        
        var spells = new[] { "Fireball", "Ice Storm", "Lightning Bolt", "Heal", "Darkness", "Time Stop" };
        var spell = spells[_random.Next(spells.Length)];
        var power = selectedCharacter.Magic + _random.Next(1, 30);
        
        selectedCharacter.ActionLog.Add($"{selectedCharacter.Name} cast {spell}! Power: {power}");
        selectedCharacter.Experience += _random.Next(5, 25);
        
        await SaveData();
        StateHasChanged();
    }
    
    private async Task LevelUp()
    {
        if (selectedCharacter == null) return;
        
        var requiredExp = selectedCharacter.Level * 100;
        if (selectedCharacter.Experience >= requiredExp)
        {
            selectedCharacter.Level++;
            selectedCharacter.Experience -= requiredExp;
            selectedCharacter.Health += 20;
            selectedCharacter.MaxHealth += 20;
            selectedCharacter.Attack += 5;
            selectedCharacter.Defense += 5;
            selectedCharacter.Magic += 5;
            
            selectedCharacter.ActionLog.Add($"✨ {selectedCharacter.Name} reached Level {selectedCharacter.Level}! ✨");
        }
        else
        {
            selectedCharacter.ActionLog.Add($"Need {requiredExp - selectedCharacter.Experience} more EXP to level up");
        }
        
        await SaveData();
        StateHasChanged();
    }
    
