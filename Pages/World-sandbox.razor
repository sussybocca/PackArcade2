    private async Task ChooseDialogueOption(string option)
    {
        if (selectedNPC == null || selectedCharacter == null) return;
        
        var response = GenerateNPCResponse(selectedNPC, option);
        selectedNPC.CurrentDialogue = response;
        selectedNPC.InteractionHistory.Add($"{selectedCharacter.Name}: {option} -> {selectedNPC.Name}: {response}");
        selectedNPC.Relationship += _random.Next(-5, 15);
        
        await SaveData();
        StateHasChanged();
    }
    
    private async Task SendCustomDialogue()
    {
        if (selectedNPC == null || selectedCharacter == null) 
        {
            await JSRuntime.InvokeVoidAsync("alert", "Select a character and NPC first!");
            return;
        }
        if (string.IsNullOrEmpty(customDialogue))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Type something to say!");
            return;
        }
        
        var response = GenerateNPCResponse(selectedNPC, customDialogue);
        selectedNPC.CurrentDialogue = response;
        selectedNPC.InteractionHistory.Add($"{selectedCharacter.Name}: {customDialogue} -> {selectedNPC.Name}: {response}");
        
        customDialogue = "";
        await SaveData();
        StateHasChanged();
    }
    
    private string GenerateNPCResponse(NPC npc, string playerMessage)
    {
        float predictionScore = PredictNPCPersonalityScore(npc);
        
        var responses = new Dictionary<string, List<string>>
        {
            ["Friendly"] = new List<string> { 
                "Wonderful to see you!", 
                "May your journey be blessed!", 
                "The stars shine bright for you today!",
                "Your kindness warms my heart!"
            },
            ["Hostile"] = new List<string> {
                "Stay back!", 
                "I'll destroy you!", 
                "You're not welcome here!",
                "Face my wrath!"
            },
            ["Mysterious"] = new List<string> {
                "The shadows whisper your name...",
                "I see things you cannot imagine...",
                "The truth lies beyond the veil...",
                "Your destiny is not yet written..."
            },
            ["Wise"] = new List<string> {
                "Wisdom comes to those who listen...",
                "The path of light is not always bright...",
                "Patience reveals all truths...",
                "Knowledge is the greatest weapon..."
            }
        };
        
        var possibleResponses = responses.ContainsKey(npc.Personality) ? responses[npc.Personality] : responses["Friendly"];
        var baseResponse = possibleResponses[_random.Next(possibleResponses.Count)];
        
        if (predictionScore > 0.7f)
        {
            return baseResponse + " (I feel a strong connection to you!)";
        }
        else if (predictionScore < 0.3f)
        {
            return baseResponse + " (I'm not sure I trust you...)";
        }
        
        return baseResponse;
    }
    
