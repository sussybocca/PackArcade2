    private async Task DestroySelectedWorld()
    {
        if (selectedWorld == null) return;
        var confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to destroy {selectedWorld.Name}?");
        if (confirm)
        {
            worlds.Remove(selectedWorld.Id);
            selectedWorld = worlds.Values.FirstOrDefault();
            powerLevel -= 50;
            await SaveData();
            StateHasChanged();
        }
    }
    
    private async Task CreateCharacter()
    {
        if (string.IsNullOrEmpty(newCharacterName)) return;
        
        var characterId = Guid.NewGuid().ToString();
        var stats = GetClassStats(newCharacterClass);
        var character = new Character
        {
            Id = characterId,
            Name = newCharacterName,
            Class = newCharacterClass,
            Level = 1,
            Health = stats.Health,
            MaxHealth = stats.Health,
            Attack = stats.Attack,
            Defense = stats.Defense,
            Magic = stats.Magic,
            Experience = 0,
            ActionLog = new List<string> { $"✨ Character {newCharacterName} was born!" }
        };
        
        characters[characterId] = character;
        selectedCharacter = character;
        newCharacterName = "";
        
        await SaveData();
        StateHasChanged();
    }
    
    private (int Health, int Attack, int Defense, int Magic) GetClassStats(string className)
    {
        return className switch
        {
            "Warrior" => (120, 25, 20, 5),
            "Mage" => (70, 10, 10, 35),
            "Rogue" => (90, 22, 15, 10),
            "Cleric" => (100, 15, 18, 25),
            "DarkLord" => (150, 30, 25, 30),
            _ => (100, 15, 15, 15)
        };
    }
    
